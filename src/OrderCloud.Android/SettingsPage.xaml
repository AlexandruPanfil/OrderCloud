<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderCloud.Android.SettingsPage"
             Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Configuration" FontSize="20" FontAttributes="Bold" />

            <VerticalStackLayout Spacing="5">
                <Label Text="API Base URL" />
                <Entry x:Name="ApiUrlEntry" Keyboard="Url" />
                <Label Text="E.g., http://10.0.2.2:5126 (emulator) or https://YOUR_IP:7173 (device)" 
                       FontSize="Micro" TextColor="Gray" />
            </VerticalStackLayout>

            <Button Text="Save Settings" Clicked="OnSaveClicked" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>