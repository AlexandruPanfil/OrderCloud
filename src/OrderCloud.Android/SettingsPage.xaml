<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderCloud.Android.SettingsPage"
             Title="Settings"
             BackgroundColor="White"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="15">
                <Button Grid.Column="0"
                        Text="☰"
                        Clicked="OnMenuClicked"
                        BackgroundColor="Transparent"
                        TextColor="#333333"
                        WidthRequest="40"
                        HeightRequest="40"
                        BorderWidth="1"
                        BorderColor="#E0E0E0"
                        FontSize="18"
                        VerticalOptions="Start"/>

                <VerticalStackLayout Grid.Column="1" Spacing="4">
                    <Label Text="Configuration" FontSize="18" FontAttributes="Bold" TextColor="#333333" />
                    <Label Text="Manage the Android app connection settings" FontSize="12" TextColor="#777777" />
                </VerticalStackLayout>
            </Grid>

            <VerticalStackLayout Spacing="8">
                <Label Text="API Base URL" TextColor="#333333" FontSize="13" />
                <Entry x:Name="ApiUrlEntry" Keyboard="Url" BackgroundColor="White" />
                <Label Text="E.g., http://10.0.2.2:5126 (emulator) or https://YOUR_IP:7173 (device)" 
                       FontSize="11" TextColor="#777777" />
            </VerticalStackLayout>

            <Button Text="Save Settings"
                    Clicked="OnSaveClicked"
                    BackgroundColor="#333333"
                    TextColor="White" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
