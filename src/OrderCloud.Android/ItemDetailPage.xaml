<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderCloud.Android.ItemDetailPage"
             Title="Item Details">
    
    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">
            
            <Label
                x:Name="TitleLabel"
                Text="Add New Item"
                FontSize="24"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label Text="Name *" FontSize="14" />
            <Entry
                x:Name="NameEntry"
                Placeholder="Enter item name"
                MaxLength="200" />

            <Label Text="Price *" FontSize="14" Margin="0,10,0,0" />
            <Entry
                x:Name="PriceEntry"
                Placeholder="0.00"
                Keyboard="Numeric" />

            <Label Text="TVA" FontSize="14" Margin="0,10,0,0" />
            <Entry
                x:Name="TVAEntry"
                Placeholder="Enter TVA (e.g., 20%)"
                MaxLength="50" />

            <Label Text="Tenant ID *" FontSize="14" Margin="0,10,0,0" />
            <Entry
                x:Name="TenantIdEntry"
                Placeholder="Enter tenant ID (GUID)"
                MaxLength="36" />

            <Label
                x:Name="ErrorLabel"
                Text=""
                TextColor="Red"
                FontSize="12"
                IsVisible="False"
                Margin="0,10,0,0" />

            <HorizontalStackLayout Spacing="10" Margin="0,20,0,0">
                <Button
                    x:Name="SaveBtn"
                    Text="Save"
                    Clicked="OnSaveClicked"
                    HorizontalOptions="FillAndExpand"
                    BackgroundColor="#4CAF50"
                    TextColor="White" />

                <Button
                    x:Name="CancelBtn"
                    Text="Cancel"
                    Clicked="OnCancelClicked"
                    HorizontalOptions="FillAndExpand"
                    BackgroundColor="#9E9E9E"
                    TextColor="White" />
            </HorizontalStackLayout>
            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
