<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderCloud.Android.ItemDetailPage"
             Title="Item Details"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="20">

            <Label
                x:Name="TitleLabel"
                Text="Add New Item"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="#333333"
                HorizontalOptions="Center" />

            <Label Text="Name *" FontSize="13" TextColor="#333333" />
            <Entry
                x:Name="NameEntry"
                Placeholder="Enter item name"
                MaxLength="200" />

            <Label Text="Price *" FontSize="13" TextColor="#333333" Margin="0,10,0,0" />
            <Entry
                x:Name="PriceEntry"
                Placeholder="0.00"
                Keyboard="Numeric" />

            <Label Text="TVA" FontSize="13" TextColor="#333333" Margin="0,10,0,0" />
            <Entry
                x:Name="TVAEntry"
                Placeholder="Enter TVA (e.g., 20%)"
                MaxLength="50" />

            <Label Text="Tenant ID *" FontSize="13" TextColor="#333333" Margin="0,10,0,0" />
            <Entry
                x:Name="TenantIdEntry"
                Placeholder="Enter tenant ID (GUID)"
                MaxLength="36" />

            <Label
                x:Name="ErrorLabel"
                Text=""
                TextColor="#CC0000"
                FontSize="12"
                IsVisible="False"
                Margin="0,10,0,0" />

            <HorizontalStackLayout Spacing="2" Margin="0,20,0,0">
                <Button
                    x:Name="SaveBtn"
                    Text="Save"
                    Clicked="OnSaveClicked"
                    HorizontalOptions="FillAndExpand"
                    BackgroundColor="#333333"
                    TextColor="White" />

                <Button
                    x:Name="CancelBtn"
                    Text="Cancel"
                    Clicked="OnCancelClicked"
                    HorizontalOptions="FillAndExpand"
                    BackgroundColor="Transparent"
                    TextColor="#333333"
                    BorderWidth="1"
                    BorderColor="#E0E0E0" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
