<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderCloud.Android.MainPage"
             BackgroundColor="White"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*" Padding="20">

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,20,0,30" ColumnDefinitions="*,Auto">
            <VerticalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                <Label Text="OrderCloud"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#333333"
                       HorizontalOptions="Start"/>
                <Label Text="Select an option to continue"
                       FontSize="13"
                       TextColor="#777777"
                       HorizontalOptions="Start"/>
            </VerticalStackLayout>

            <Button Grid.Column="1"
                    Text="☰"
                    Clicked="OnMenuClicked"
                    BackgroundColor="Transparent"
                    TextColor="#333333"
                    WidthRequest="44"
                    HeightRequest="44"
                    CornerRadius="0"
                    FontSize="20"
                    BorderWidth="1"
                    BorderColor="#E0E0E0"
                    VerticalOptions="Start"/>
        </Grid>

        <!-- Menu Buttons -->
        <VerticalStackLayout Grid.Row="1" Spacing="2" VerticalOptions="Start">

            <!-- New Sale Card -->
            <Border StrokeThickness="1"
                    Stroke="#E0E0E0"
                    BackgroundColor="White"
                    Padding="20">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Label Grid.Column="0"
                           Text="$"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#333333"
                           VerticalOptions="Center"
                           WidthRequest="40"
                           HorizontalTextAlignment="Center"/>

                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                        <Label Text="New Sale"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#333333"/>
                        <Label Text="Create a new sale and add items"
                               FontSize="12"
                               TextColor="#777777"/>
                    </VerticalStackLayout>
                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewSaleTapped"/>
                </Border.GestureRecognizers>
            </Border>

            <!-- Orders Card -->
            <Border StrokeThickness="1"
                    Stroke="#E0E0E0"
                    BackgroundColor="White"
                    Padding="20">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Label Grid.Column="0"
                           Text="☰"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#333333"
                           VerticalOptions="Center"
                           WidthRequest="40"
                           HorizontalTextAlignment="Center"/>

                    <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                        <Label Text="Orders"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#333333"/>
                        <Label Text="View and pay existing orders"
                               FontSize="12"
                               TextColor="#777777"/>
                    </VerticalStackLayout>
                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOrdersTapped"/>
                </Border.GestureRecognizers>
            </Border>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
