<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderCloud.Android.MainPage"
             BackgroundColor="#FAFAFA"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*" Padding="24">

        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="4" Margin="0,40,0,40">
            <Label Text="OrderCloud"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="#1A1A1A"
                   HorizontalOptions="Center"/>
            <Label Text="Select an option to continue"
                   FontSize="14"
                   TextColor="#8C8C8C"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- Menu Buttons -->
        <VerticalStackLayout Grid.Row="1" Spacing="16" VerticalOptions="Start">
            
            <!-- New Sale Card -->
            <Border StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    BackgroundColor="#FFFFFF"
                    HeightRequest="140">
                <Border.Shadow>
                    <Shadow Brush="#000000"
                            Opacity="0.06"
                            Radius="8"
                            Offset="0,2"/>
                </Border.Shadow>

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16" Padding="24">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            BackgroundColor="#1A1A1A"
                            WidthRequest="56"
                            HeightRequest="56"
                            VerticalOptions="Center">
                        <Label Text="$"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#FFFFFF"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                        <Label Text="New Sale"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"/>
                        <Label Text="Create a new sale and add items"
                               FontSize="13"
                               TextColor="#8C8C8C"/>
                    </VerticalStackLayout>
                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnNewSaleTapped"/>
                </Border.GestureRecognizers>
            </Border>

            <!-- Orders Card -->
            <Border StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    BackgroundColor="#FFFFFF"
                    HeightRequest="140">
                <Border.Shadow>
                    <Shadow Brush="#000000"
                            Opacity="0.06"
                            Radius="8"
                            Offset="0,2"/>
                </Border.Shadow>

                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16" Padding="24">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            BackgroundColor="#2ECC71"
                            WidthRequest="56"
                            HeightRequest="56"
                            VerticalOptions="Center">
                        <Label Text="📋"
                               FontSize="24"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                        <Label Text="Orders"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"/>
                        <Label Text="View and pay existing orders"
                               FontSize="13"
                               TextColor="#8C8C8C"/>
                    </VerticalStackLayout>
                </Grid>

                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOrdersTapped"/>
                </Border.GestureRecognizers>
            </Border>

        </VerticalStackLayout>

    </Grid>

</ContentPage>
