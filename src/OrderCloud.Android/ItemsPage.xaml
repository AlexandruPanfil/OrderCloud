<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderCloud.Android.ItemsPage"
             BackgroundColor="#FAFAFA"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto" 
          Padding="16" 
          RowSpacing="12">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="8,0">
            <Button Grid.Column="0"
                    Text="☰"
                    Clicked="OnMenuClicked"
                    BackgroundColor="#FFFFFF"
                    TextColor="#1A1A1A"
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"
                    FontSize="18"/>

            <VerticalStackLayout Grid.Column="1" Spacing="2">
                <Label Text="New Sale" 
                       FontSize="22" 
                       FontAttributes="Bold"
                       TextColor="#1A1A1A"/>
                <Label x:Name="StatusLabel"
                       Text="Select items to sell" 
                       FontSize="12" 
                       TextColor="#8C8C8C"/>
            </VerticalStackLayout>
            
            <Button Grid.Column="2"
                    x:Name="RefreshBtn"
                    Text="↻"
                    Clicked="OnRefreshClicked"
                    BackgroundColor="Transparent"
                    TextColor="#666666"
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"
                    FontSize="18"/>
        </Grid>

        <!-- Main Content: Two Columns -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="16">

            <!-- Left: Catalog Items -->
            <Border Grid.Column="0" 
                    StrokeShape="RoundRectangle 12" 
                    StrokeThickness="0"
                    BackgroundColor="#FFFFFF"
                    Padding="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" 
                            Opacity="0.06" 
                            Radius="8" 
                            Offset="0,2"/>
                </Border.Shadow>
                
                <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="16">
                    <Label Grid.Row="0" 
                           Text="Catalog" 
                           FontSize="15" 
                           FontAttributes="Bold"
                           TextColor="#1A1A1A"
                           Margin="0,0,0,8"/>
                    
                    <BoxView Grid.Row="1" 
                             HeightRequest="1" 
                             Color="#F0F0F0"
                             Margin="0,0,0,8"/>
                    
                    <!-- Search Bar -->
                    <Border Grid.Row="2"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0"
                            BackgroundColor="#F5F5F5"
                            Margin="0,0,0,12">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Padding="12,8">
                            <Label Grid.Column="0"
                                   Text="🔍"
                                   FontSize="14"
                                   VerticalOptions="Center"/>
                            <Entry Grid.Column="1"
                                   x:Name="SearchEntry"
                                   Placeholder="Search items..."
                                   FontSize="13"
                                   BackgroundColor="Transparent"
                                   TextChanged="OnSearchTextChanged"/>
                        </Grid>
                    </Border>

                    <!-- Items List -->
                    <ScrollView Grid.Row="3" VerticalOptions="FillAndExpand">
                        <CollectionView x:Name="CatalogItemsCollectionView" 
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeShape="RoundRectangle 8"
                                            StrokeThickness="0"
                                            BackgroundColor="#FAFAFA"
                                            Padding="12">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <VerticalStackLayout Grid.Column="0" Spacing="3">
                                                <Label Text="{Binding Name}" 
                                                       FontSize="13" 
                                                       FontAttributes="Bold"
                                                       TextColor="#1A1A1A"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"/>
                                                <Label Text="{Binding Price, StringFormat='${0:F2}'}" 
                                                       FontSize="12" 
                                                       TextColor="#2ECC71"/>
                                            </VerticalStackLayout>
                                            
                                            <Button Grid.Column="1"
                                                    Text="+"
                                                    WidthRequest="32"
                                                    HeightRequest="32"
                                                    CornerRadius="16"
                                                    BackgroundColor="#1A1A1A"
                                                    TextColor="#FFFFFF"
                                                    FontSize="16"
                                                    FontAttributes="Bold"
                                                    Clicked="OnAddToCartClicked"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </ScrollView>
                </Grid>
            </Border>

            <!-- Right: Cart -->
            <Border Grid.Column="1" 
                    StrokeShape="RoundRectangle 12" 
                    StrokeThickness="0"
                    BackgroundColor="#FFFFFF"
                    Padding="0">
                <Border.Shadow>
                    <Shadow Brush="#000000" 
                            Opacity="0.06" 
                            Radius="8" 
                            Offset="0,2"/>
                </Border.Shadow>
                
                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Padding="16">
                    <Label Grid.Row="0" 
                           Text="Cart" 
                           FontSize="15" 
                           FontAttributes="Bold"
                           TextColor="#1A1A1A"
                           Margin="0,0,0,8"/>
                    
                    <BoxView Grid.Row="1" 
                             HeightRequest="1" 
                             Color="#F0F0F0"
                             Margin="0,0,0,8"/>
                    
                    <!-- Cart Items -->
                    <CollectionView Grid.Row="2"
                                    x:Name="CartCollectionView" 
                                    SelectionMode="None"
                                    VerticalOptions="FillAndExpand">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="6"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Spacing="8" VerticalOptions="CenterAndExpand">
                                <Label Text="No items in cart" 
                                       FontSize="14" 
                                       TextColor="#8C8C8C"
                                       HorizontalOptions="Center"/>
                                <Label Text="Tap + to add items" 
                                       FontSize="12" 
                                       TextColor="#B0B0B0"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border StrokeShape="RoundRectangle 8"
                                        StrokeThickness="0"
                                        BackgroundColor="#FAFAFA"
                                        Padding="12">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                                            <Label Text="{Binding Name}" 
                                                   FontSize="13" 
                                                   FontAttributes="Bold"
                                                   TextColor="#1A1A1A"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                            <Label Text="{Binding Price, StringFormat='${0:F2}'}" 
                                                   FontSize="11" 
                                                   TextColor="#8C8C8C"/>
                                        </VerticalStackLayout>
                                        
                                        <!-- Quantity - -->
                                        <Button Grid.Column="1"
                                                Text="−"
                                                WidthRequest="28"
                                                HeightRequest="28"
                                                CornerRadius="14"
                                                BackgroundColor="#F5F5F5"
                                                TextColor="#1A1A1A"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                Clicked="OnDecreaseQuantityClicked"
                                                CommandParameter="{Binding .}"/>
                                        
                                        <!-- Quantity -->
                                        <Label Grid.Column="2"
                                               Text="{Binding Quantity}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="#1A1A1A"
                                               WidthRequest="24"
                                               HorizontalTextAlignment="Center"
                                               VerticalOptions="Center"/>
                                        
                                        <!-- Quantity + -->
                                        <Button Grid.Column="3"
                                                Text="+"
                                                WidthRequest="28"
                                                HeightRequest="28"
                                                CornerRadius="14"
                                                BackgroundColor="#F5F5F5"
                                                TextColor="#1A1A1A"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                Clicked="OnIncreaseQuantityClicked"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    
                    <!-- Totals -->
                    <BoxView Grid.Row="3" 
                             HeightRequest="1" 
                             Color="#F0F0F0"
                             Margin="0,12,0,12"/>
                    
                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0"
                               Text="Total" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"/>
                        <Label Grid.Column="1"
                               x:Name="TotalLabel"
                               Text="$0.00" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               TextColor="#2ECC71"
                               HorizontalTextAlignment="End"/>
                    </Grid>
                </Grid>
            </Border>

        </Grid>

        <!-- Payment Actions -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*,Auto" ColumnSpacing="10">
            <Button Grid.Column="0"
                    x:Name="PayCashBtn"
                    Text="💵 Cash"
                    Clicked="OnPayCashClicked"
                    BackgroundColor="#1A1A1A"
                    TextColor="#FFFFFF"
                    FontSize="14"
                    FontAttributes="Bold"
                    HeightRequest="48"
                    CornerRadius="8"/>

            <Button Grid.Column="1"
                    x:Name="PayCardBtn"
                    Text="💳 Card"
                    Clicked="OnPayCardClicked"
                    BackgroundColor="#2ECC71"
                    TextColor="#FFFFFF"
                    FontSize="14"
                    FontAttributes="Bold"
                    HeightRequest="48"
                    CornerRadius="8"/>
            
            <Button Grid.Column="2"
                    x:Name="ClearCartBtn"
                    Text="Clear"
                    Clicked="OnClearCartClicked"
                    BackgroundColor="#F5F5F5"
                    TextColor="#8C8C8C"
                    FontSize="14"
                    FontAttributes="Bold"
                    HeightRequest="48"
                    CornerRadius="8"
                    WidthRequest="80"/>
        </Grid>

    </Grid>

</ContentPage>
