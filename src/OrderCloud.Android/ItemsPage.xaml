<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderCloud.Android.ItemsPage"
             BackgroundColor="White"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto" 
          Padding="20" 
          RowSpacing="15">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15" Padding="0">
            <Button Grid.Column="0"
                    Text="☰"
                    Clicked="OnMenuClicked"
                    BackgroundColor="Transparent"
                    TextColor="#333333"
                    WidthRequest="40"
                    HeightRequest="40"
                    BorderWidth="1"
                    BorderColor="#E0E0E0"
                    FontSize="18"/>

            <VerticalStackLayout Grid.Column="1" Spacing="4">
                <Label Text="New Sale" 
                       FontSize="18" 
                       FontAttributes="Bold"
                       TextColor="#333333"/>
                <Label x:Name="StatusLabel"
                       Text="Select items to sell" 
                       FontSize="12" 
                       TextColor="#777777"/>
            </VerticalStackLayout>

            <Button Grid.Column="2"
                    x:Name="RefreshBtn"
                    Text="↻"
                    Clicked="OnRefreshClicked"
                    BackgroundColor="Transparent"
                    TextColor="#333333"
                    WidthRequest="40"
                    HeightRequest="40"
                    BorderWidth="1"
                    BorderColor="#E0E0E0"
                    FontSize="18"/>
        </Grid>

        <!-- Main Content: Two Columns -->
        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="2">

            <!-- Left: Catalog Items -->
            <Border Grid.Column="0" 
                    Stroke="#E0E0E0"
                    StrokeThickness="1"
                    BackgroundColor="White"
                    Padding="15">

                <Grid RowDefinitions="Auto,Auto,Auto,*">
                    <Label Grid.Row="0" 
                           Text="Catalog" 
                           FontSize="14" 
                           FontAttributes="Bold"
                           TextColor="#333333"
                           Margin="0,0,0,10"/>

                    <BoxView Grid.Row="1" 
                             HeightRequest="1" 
                             Color="#E0E0E0"
                             Margin="0,0,0,10"/>

                    <!-- Search Bar -->
                    <Border Grid.Row="2"
                            Stroke="#E0E0E0"
                            StrokeThickness="1"
                            BackgroundColor="White"
                            Padding="10"
                            Margin="0,0,0,15">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Label Grid.Column="0"
                                   Text="🔍"
                                   FontSize="14"
                                   VerticalOptions="Center"/>
                            <Entry Grid.Column="1"
                                   x:Name="SearchEntry"
                                   Placeholder="Search items..."
                                   FontSize="13"
                                   BackgroundColor="Transparent"
                                   TextChanged="OnSearchTextChanged"/>
                        </Grid>
                    </Border>

                    <!-- Items List -->
                    <ScrollView Grid.Row="3" VerticalOptions="FillAndExpand">
                        <CollectionView x:Name="CatalogItemsCollectionView" 
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="0"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border Stroke="#E0E0E0"
                                            StrokeThickness="0,0,0,1"
                                            BackgroundColor="White"
                                            Padding="10">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                                <Label Text="{Binding Name}" 
                                                       FontSize="13" 
                                                       TextColor="#333333"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="1"/>
                                                <Label Text="{Binding Price, StringFormat='${0:F2}'}" 
                                                       FontSize="12" 
                                                       TextColor="#777777"/>
                                            </VerticalStackLayout>

                                            <Button Grid.Column="1"
                                                    Text="+"
                                                    WidthRequest="32"
                                                    HeightRequest="32"
                                                    BackgroundColor="#333333"
                                                    TextColor="White"
                                                    FontSize="16"
                                                    FontAttributes="Bold"
                                                    Clicked="OnAddToCartClicked"
                                                    CommandParameter="{Binding .}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </ScrollView>
                </Grid>
            </Border>

            <!-- Right: Cart -->
            <Border Grid.Column="1" 
                    Stroke="#E0E0E0"
                    StrokeThickness="1"
                    BackgroundColor="White"
                    Padding="15">

                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
                    <Label Grid.Row="0" 
                           Text="Cart" 
                           FontSize="14" 
                           FontAttributes="Bold"
                           TextColor="#333333"
                           Margin="0,0,0,10"/>

                    <BoxView Grid.Row="1" 
                             HeightRequest="1" 
                             Color="#E0E0E0"
                             Margin="0,0,0,10"/>

                    <!-- Cart Items -->
                    <CollectionView Grid.Row="2"
                                    x:Name="CartCollectionView" 
                                    SelectionMode="None"
                                    VerticalOptions="FillAndExpand">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="0"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <VerticalStackLayout Spacing="8" VerticalOptions="CenterAndExpand">
                                <Label Text="No items in cart" 
                                       FontSize="13" 
                                       TextColor="#777777"
                                       HorizontalOptions="Center"/>
                                <Label Text="Tap + to add items" 
                                       FontSize="12" 
                                       TextColor="#999999"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#E0E0E0"
                                        StrokeThickness="0,0,0,1"
                                        BackgroundColor="White"
                                        Padding="10">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                                            <Label Text="{Binding Name}" 
                                                   FontSize="13" 
                                                   TextColor="#333333"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"/>
                                            <Label Text="{Binding Price, StringFormat='${0:F2}'}" 
                                                   FontSize="11" 
                                                   TextColor="#777777"/>
                                        </VerticalStackLayout>

                                        <!-- Quantity - -->
                                        <Button Grid.Column="1"
                                                Text="−"
                                                WidthRequest="28"
                                                HeightRequest="28"
                                                BackgroundColor="Transparent"
                                                TextColor="#333333"
                                                BorderWidth="1"
                                                BorderColor="#E0E0E0"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                Clicked="OnDecreaseQuantityClicked"
                                                CommandParameter="{Binding .}"/>

                                        <!-- Quantity -->
                                        <Label Grid.Column="2"
                                               Text="{Binding Quantity}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="#333333"
                                               WidthRequest="24"
                                               HorizontalTextAlignment="Center"
                                               VerticalOptions="Center"/>

                                        <!-- Quantity + -->
                                        <Button Grid.Column="3"
                                                Text="+"
                                                WidthRequest="28"
                                                HeightRequest="28"
                                                BackgroundColor="Transparent"
                                                TextColor="#333333"
                                                BorderWidth="1"
                                                BorderColor="#E0E0E0"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                Clicked="OnIncreaseQuantityClicked"
                                                CommandParameter="{Binding .}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Totals -->
                    <BoxView Grid.Row="3" 
                             HeightRequest="1" 
                             Color="#E0E0E0"
                             Margin="0,15,0,15"/>

                    <Grid Grid.Row="4" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Label Grid.Column="0"
                               Text="Total" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="#333333"/>
                        <Label Grid.Column="1"
                               x:Name="TotalLabel"
                               Text="$0.00" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               TextColor="#333333"
                               HorizontalTextAlignment="End"/>
                    </Grid>
                </Grid>
            </Border>

        </Grid>

        <!-- Payment Actions -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*,Auto" ColumnSpacing="2">
            <Button Grid.Column="0"
                    x:Name="PayCashBtn"
                    Text="Cash"
                    Clicked="OnPayCashClicked"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="13"
                    FontAttributes="Bold"
                    HeightRequest="44"/>

            <Button Grid.Column="1"
                    x:Name="PayCardBtn"
                    Text="Card"
                    Clicked="OnPayCardClicked"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="13"
                    FontAttributes="Bold"
                    HeightRequest="44"/>

            <Button Grid.Column="2"
                    x:Name="ClearCartBtn"
                    Text="Clear"
                    Clicked="OnClearCartClicked"
                    BackgroundColor="Transparent"
                    TextColor="#333333"
                    BorderWidth="1"
                    BorderColor="#E0E0E0"
                    FontSize="13"
                    FontAttributes="Bold"
                    HeightRequest="44"
                    WidthRequest="80"/>
        </Grid>

    </Grid>

</ContentPage>
