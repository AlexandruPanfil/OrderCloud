<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderCloud.Android.OrdersPage"
             Title="Orders">
    
    <VerticalStackLayout Spacing="10" Padding="15">
        
        <HorizontalStackLayout Spacing="10">
            <Button
                x:Name="RefreshBtn"
                Text="🔄 Refresh"
                Clicked="OnRefreshClicked"
                HorizontalOptions="FillAndExpand" />
        </HorizontalStackLayout>

        <Label
            x:Name="StatusLabel"
            Text="Loading orders..."
            FontSize="14"
            Margin="0,10,0,0" />

        <CollectionView x:Name="OrdersCollectionView">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame
                        BorderColor="#CCCCCC"
                        CornerRadius="10"
                        Padding="15"
                        Margin="0,5">
                        
                        <VerticalStackLayout Spacing="8">
                            <HorizontalStackLayout Spacing="10">
                                <Label
                                    Text="Order #"
                                    FontSize="14"
                                    FontAttributes="Bold" />
                                <Label
                                    Text="{Binding Id, StringFormat='{0:N}'}"
                                    FontSize="12"
                                    LineBreakMode="MiddleTruncation"
                                    HorizontalOptions="FillAndExpand" />
                            </HorizontalStackLayout>

                            <BoxView HeightRequest="1" Color="#EEEEEE" />
                            
                            <HorizontalStackLayout Spacing="20">
                                <Label
                                    Text="{Binding Status, StringFormat='Status: {0}'}"
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    TextColor="#2196F3" />
                                <Label
                                    Text="{Binding Total, StringFormat='Total: ${0:F2}'}"
                                    FontSize="14"
                                    FontAttributes="Bold"
                                    TextColor="#4CAF50" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10">
                                <Label
                                    Text="📅"
                                    FontSize="14" />
                                <Label
                                    Text="{Binding CreatedAt, StringFormat='Created: {0:MMM dd, yyyy HH:mm}'}"
                                    FontSize="12"
                                    TextColor="#666666" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="10">
                                <Label
                                    Text="📦"
                                    FontSize="14" />
                                <Label
                                    Text="{Binding Items.Count, StringFormat='{0} items'}"
                                    FontSize="12"
                                    TextColor="#666666" />
                            </HorizontalStackLayout>

                            <Label
                                Text="{Binding TenantId, StringFormat='Tenant: {0}'}"
                                FontSize="10"
                                TextColor="#999999" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>
