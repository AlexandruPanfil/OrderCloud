<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderCloud.Android.OrdersPage"
             BackgroundColor="White"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*,Auto" 
          Padding="20">

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,20,0,30" ColumnDefinitions="*,Auto">
            <VerticalStackLayout Grid.Column="0" Spacing="8" VerticalOptions="Center">
                <Label Text="Orders" 
                       FontSize="24" 
                       FontAttributes="Bold"
                       TextColor="#333333"
                       HorizontalOptions="Start"/>
                <Label x:Name="StatusLabel"
                       Text="View and manage orders" 
                       FontSize="13" 
                       TextColor="#777777"
                       HorizontalOptions="Start"/>
            </VerticalStackLayout>

            <HorizontalStackLayout Grid.Column="1" Spacing="10">
                <Button x:Name="RefreshBtn"
                        Text="↻"
                        Clicked="OnRefreshClicked"
                        BackgroundColor="Transparent"
                        TextColor="#333333"
                        WidthRequest="44"
                        HeightRequest="44"
                        BorderWidth="1"
                        BorderColor="#E0E0E0"
                        FontSize="20"
                        VerticalOptions="Start"/>

                <Button Text="☰"
                        Clicked="OnMenuClicked"
                        BackgroundColor="Transparent"
                        TextColor="#333333"
                        WidthRequest="44"
                        HeightRequest="44"
                        BorderWidth="1"
                        BorderColor="#E0E0E0"
                        FontSize="20"
                        VerticalOptions="Start"/>
            </HorizontalStackLayout>
        </Grid>

        <!-- Orders List (shown when no order selected) -->
        <ScrollView Grid.Row="1" VerticalOptions="FillAndExpand">
            <CollectionView x:Name="OrdersCollectionView"
                            SelectionMode="Single"
                            SelectionChanged="OnOrderSelected">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="2"/>
                </CollectionView.ItemsLayout>
                <CollectionView.EmptyView>
                    <VerticalStackLayout Spacing="8" VerticalOptions="CenterAndExpand" HorizontalOptions="Center" Margin="0,100,0,0">
                        <Label Text="No orders found" 
                               FontSize="16" 
                               TextColor="#777777"
                               HorizontalOptions="Center"/>
                        <Label Text="Orders will appear here once created" 
                               FontSize="12" 
                               TextColor="#999999"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="1"
                                Stroke="#E0E0E0"
                                BackgroundColor="White"
                                Padding="20">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0"
                                           FontSize="16" 
                                           FontAttributes="Bold"
                                           TextColor="#333333">
                                        <Label.Text>
                                            <MultiBinding StringFormat="Order #{0}">
                                                <Binding Path="Id"/>
                                            </MultiBinding>
                                        </Label.Text>
                                    </Label>

                                    <Label Grid.Column="1"
                                           Text="{Binding Status}" 
                                           FontSize="12" 
                                           TextColor="#777777"
                                           VerticalOptions="Center"/>
                                </Grid>

                                <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="15">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <Label Text="Total" 
                                               FontSize="11" 
                                               TextColor="#777777"/>
                                        <Label Text="{Binding Total, StringFormat='${0:F2}'}" 
                                               FontSize="14" 
                                               FontAttributes="Bold"
                                               TextColor="#333333"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <Label Text="Created" 
                                               FontSize="11" 
                                               TextColor="#777777"/>
                                        <Label Text="{Binding CreatedAt, StringFormat='{0:MMM dd}'}" 
                                               FontSize="13" 
                                               TextColor="#333333"/>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="2" Spacing="4">
                                        <Label Text="Items" 
                                               FontSize="11" 
                                               TextColor="#777777"/>
                                        <Label Text="{Binding Items.Count}" 
                                               FontSize="13" 
                                               TextColor="#333333"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

        <!-- Order Detail (shown when order selected) -->
        <Border Grid.Row="1"
                x:Name="OrderDetailCard"
                StrokeThickness="1"
                Stroke="#E0E0E0"
                BackgroundColor="White"
                Padding="20"
                IsVisible="False">

            <Grid RowDefinitions="Auto,Auto,*,Auto">
                <!-- Order Header -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Button Grid.Column="0"
                            Text="←"
                            Clicked="OnBackToOrdersClicked"
                            BackgroundColor="Transparent"
                            TextColor="#333333"
                            WidthRequest="44"
                            HeightRequest="44"
                            BorderWidth="1"
                            BorderColor="#E0E0E0"
                            FontSize="20"
                            FontAttributes="Bold"
                            VerticalOptions="Start"/>

                    <VerticalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                        <Label x:Name="OrderTitle"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#333333"/>
                        <HorizontalStackLayout Spacing="15">
                            <Label x:Name="OrderDate"
                                   FontSize="12"
                                   TextColor="#777777"/>
                            <Label x:Name="OrderStatus"
                                   FontSize="12"
                                   TextColor="#777777"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- Divider -->
                <BoxView Grid.Row="1"
                         HeightRequest="1"
                         Color="#E0E0E0"
                         Margin="0,20"/>

                <!-- Items List -->
                <ScrollView Grid.Row="2" VerticalOptions="FillAndExpand">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Items"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="#333333"
                               Margin="0,0,0,15"/>

                        <CollectionView x:Name="OrderItemsCollectionView"
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="0"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border StrokeThickness="0,0,0,1"
                                            Stroke="#E0E0E0"
                                            BackgroundColor="White"
                                            Padding="0,12">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                            <Label Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   FontSize="13"
                                                   TextColor="#333333"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1"
                                                   VerticalOptions="Center"/>

                                            <Label Grid.Column="1"
                                                   Text="{Binding Quantity, StringFormat='× {0}'}"
                                                   FontSize="12"
                                                   TextColor="#777777"
                                                   VerticalOptions="Center"/>

                                            <Label Grid.Column="2"
                                                   Text="{Binding Total, StringFormat='${0:F2}'}"
                                                   FontSize="13"
                                                   FontAttributes="Bold"
                                                   TextColor="#333333"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Total -->
                <Grid Grid.Row="3" ColumnDefinitions="*,Auto" Margin="0,20,0,0">
                    <Label Grid.Column="0"
                           Text="Total"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="#333333"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="1"
                           x:Name="OrderTotalLabel"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#333333"
                           VerticalOptions="Center"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Payment Buttons (shown when order selected) -->
        <HorizontalStackLayout Grid.Row="2"
                               x:Name="PaymentActions"
                               Spacing="2"
                               IsVisible="False">
            <Button x:Name="PayCashBtn"
                    Text="Pay Cash"
                    Clicked="OnPayCashClicked"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="13"
                    FontAttributes="Bold"
                    HeightRequest="48"
                    HorizontalOptions="FillAndExpand"/>

            <Button x:Name="PayCardBtn"
                    Text="Pay Card"
                    Clicked="OnPayCardClicked"
                    BackgroundColor="#333333"
                    TextColor="White"
                    FontSize="13"
                    FontAttributes="Bold"
                    HeightRequest="48"
                    HorizontalOptions="FillAndExpand"/>
        </HorizontalStackLayout>

    </Grid>

</ContentPage>
