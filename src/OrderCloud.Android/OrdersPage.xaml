<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderCloud.Android.OrdersPage"
             BackgroundColor="#FAFAFA"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto" 
          Padding="16" 
          RowSpacing="12">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10" Padding="8,0">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Orders" 
                       FontSize="22" 
                       FontAttributes="Bold"
                       TextColor="#1A1A1A"
                       FontFamily="SegoeUI"/>
                <Label x:Name="StatusLabel"
                       Text="Loading orders..." 
                       FontSize="12" 
                       TextColor="#8C8C8C"/>
            </VerticalStackLayout>
            
            <Button Grid.Column="1"
                    x:Name="RefreshBtn"
                    Text="↻"
                    Clicked="OnRefreshClicked"
                    BackgroundColor="Transparent"
                    TextColor="#666666"
                    WidthRequest="40"
                    HeightRequest="40"
                    CornerRadius="20"
                    FontSize="18"/>
        </Grid>

        <!-- Orders List (shown when no order selected) -->
        <CollectionView Grid.Row="2" 
                        x:Name="OrdersCollectionView"
                        SelectionMode="Single"
                        SelectionChanged="OnOrderSelected">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="8"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 12" 
                            StrokeThickness="0"
                            BackgroundColor="#FFFFFF"
                            Padding="16">
                        <Border.Shadow>
                            <Shadow Brush="#000000" 
                                    Opacity="0.06" 
                                    Radius="8" 
                                    Offset="0,2"/>
                        </Border.Shadow>
                        
                        <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       FontSize="14" 
                                       FontAttributes="Bold"
                                       TextColor="#1A1A1A">
                                    <Label.Text>
                                        <MultiBinding StringFormat="Order #{0:N}">
                                            <Binding Path="Id"/>
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                                
                                <Label Grid.Column="1"
                                       Text="{Binding Status}" 
                                       FontSize="12" 
                                       FontAttributes="Bold"
                                       TextColor="#FFFFFF"
                                       Padding="10,4"
                                       VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Completed">
                                            <Setter Property="BackgroundColor" Value="#2ECC71"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Pending">
                                            <Setter Property="BackgroundColor" Value="#F39C12"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Cancelled">
                                            <Setter Property="BackgroundColor" Value="#E74C3C"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Processing">
                                            <Setter Property="BackgroundColor" Value="#3498DB"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="">
                                            <Setter Property="BackgroundColor" Value="#8C8C8C"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Grid>

                            <BoxView Grid.Row="1" 
                                     HeightRequest="1" 
                                     Color="#F0F0F0"/>

                            <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="Total" 
                                           FontSize="10" 
                                           TextColor="#8C8C8C"/>
                                    <Label Text="{Binding Total, StringFormat='${0:F2}'}" 
                                           FontSize="14" 
                                           FontAttributes="Bold"
                                           TextColor="#2ECC71"/>
                                </VerticalStackLayout>
                                
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="Created" 
                                           FontSize="10" 
                                           TextColor="#8C8C8C"/>
                                    <Label Text="{Binding CreatedAt, StringFormat='{0:MMM dd, yyyy}'}" 
                                           FontSize="12" 
                                           TextColor="#1A1A1A"/>
                                </VerticalStackLayout>
                                
                                <VerticalStackLayout Grid.Column="2" Spacing="2">
                                    <Label Text="Items" 
                                           FontSize="10" 
                                           TextColor="#8C8C8C"/>
                                    <Label Text="{Binding Items.Count}" 
                                           FontSize="12" 
                                           TextColor="#1A1A1A"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Order Detail (shown when order selected) -->
        <Border Grid.Row="2"
                x:Name="OrderDetailCard"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="0"
                BackgroundColor="#FFFFFF"
                Padding="0"
                IsVisible="False">
            <Border.Shadow>
                <Shadow Brush="#000000"
                        Opacity="0.06"
                        Radius="8"
                        Offset="0,2"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto,*">
                <!-- Order Header -->
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" Padding="16">
                    <Button Grid.Column="0"
                            Text="←"
                            Clicked="OnBackToOrdersClicked"
                            BackgroundColor="#F5F5F5"
                            TextColor="#1A1A1A"
                            WidthRequest="36"
                            HeightRequest="36"
                            CornerRadius="18"
                            FontSize="18"
                            FontAttributes="Bold"/>
                    
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label x:Name="OrderTitle"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="#1A1A1A"/>
                        <Label x:Name="OrderDate"
                               FontSize="12"
                               TextColor="#8C8C8C"/>
                    </VerticalStackLayout>

                    <Label Grid.Column="2"
                           x:Name="OrderStatus"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF"
                           Padding="10,4"
                           VerticalOptions="Center"/>
                </Grid>

                <BoxView Grid.Row="1"
                         HeightRequest="1"
                         Color="#F0F0F0"
                         Margin="16,0"/>

                <!-- Items Header -->
                <Label Grid.Row="2"
                       Text="Items"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#1A1A1A"
                       Margin="16,12,16,8"/>

                <!-- Items List -->
                <CollectionView Grid.Row="3"
                                x:Name="OrderItemsCollectionView"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="6"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    BackgroundColor="#FAFAFA"
                                    Margin="16,0,16,0"
                                    Padding="12">
                                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                                    <Label Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="#1A1A1A"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="1"/>
                                    
                                    <Label Grid.Column="1"
                                           Text="{Binding Quantity, StringFormat='× {0}'}"
                                           FontSize="13"
                                           TextColor="#8C8C8C"
                                           VerticalOptions="Center"/>
                                    
                                    <Label Grid.Column="2"
                                           Text="{Binding Total, StringFormat='${0:F2}'}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#2ECC71"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>

        <!-- Payment Buttons (shown when order selected) -->
        <Grid Grid.Row="3"
              x:Name="PaymentActions"
              ColumnDefinitions="*,*"
              ColumnSpacing="10"
              IsVisible="False">
            <Button Grid.Column="0"
                    x:Name="PayCashBtn"
                    Text="💵 Cash"
                    Clicked="OnPayCashClicked"
                    BackgroundColor="#1A1A1A"
                    TextColor="#FFFFFF"
                    FontSize="14"
                    FontAttributes="Bold"
                    HeightRequest="48"
                    CornerRadius="8"/>

            <Button Grid.Column="1"
                    x:Name="PayCardBtn"
                    Text="💳 Card"
                    Clicked="OnPayCardClicked"
                    BackgroundColor="#2ECC71"
                    TextColor="#FFFFFF"
                    FontSize="14"
                    FontAttributes="Bold"
                    HeightRequest="48"
                    CornerRadius="8"/>
        </Grid>

    </Grid>

</ContentPage>
