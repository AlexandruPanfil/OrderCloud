<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="OrderCloud.Android.LoginPage"
             Title="Login"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="20"
            VerticalOptions="Center">

            <Label
                Text="Login"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="#333333"
                HorizontalOptions="Center" />

            <Label
                Text="Sign in to your account"
                FontSize="14"
                TextColor="#777777"
                HorizontalOptions="Center"
                Margin="0,0,0,20" />

            <Border
                Stroke="#E0E0E0"
                StrokeThickness="1"
                Padding="20"
                BackgroundColor="White"
                Margin="0,10,0,0">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Device Activation"
                           FontAttributes="Bold"
                           TextColor="#333333"
                           FontSize="14" />

                    <Label x:Name="ActivationStatusLabel"
                           Text="Device is not activated"
                           FontSize="12"
                           TextColor="#777777" />

                    <Entry
                        x:Name="ActivationCodeEntry"
                        Placeholder="Activation Code (Device ID)" />

                    <Button
                        x:Name="ActivateDeviceBtn"
                        Text="Activate Device"
                        Clicked="OnActivateDeviceClicked"
                        HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>

            <Entry
                x:Name="UsernameEntry"
                Placeholder="Local User ID (Guid)"
                Margin="0,20,0,0" />

            <Entry
                x:Name="PasswordEntry"
                Placeholder="PIN Code"
                IsPassword="True" />

            <Button
                x:Name="LoginBtn"
                Text="Login"
                Clicked="OnLoginClicked"
                HorizontalOptions="Fill"
                Margin="0,10,0,0" />

            <Button
                x:Name="LogoutBtn"
                Text="Logout"
                Clicked="OnLogoutClicked"
                HorizontalOptions="Fill"
                BackgroundColor="Transparent"
                TextColor="#333333"
                BorderWidth="1"
                BorderColor="#E0E0E0"
                IsVisible="False" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
