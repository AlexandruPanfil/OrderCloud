@implements IDisposable
@using OrderCloud.Blazor.Models
@using OrderCloud.Blazor.Services
@using Microsoft.JSInterop

@inject NavigationManager NavigationManager
@inject ITenantSelectionService TenantSelectionService
@inject IJSRuntime JS

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">OrderCloud.Blazor</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3" @onclick:stopPropagation="true">
            <div class="text-white-50 small mb-1">Tenant filter</div>
            <select class="form-select form-select-sm"
                    id="tenant-selector"
                    value="@SelectedTenantIdStr"
                    @onchange="OnTenantSelectionChanged"
                    @onchange:stopPropagation="true"
                    disabled="@(!VisibleTenants.Any())"
                    @onclick:stopPropagation="true">
                <option value="">@(VisibleTenants.Any() ? "All tenants" : "No tenants assigned")</option>
                @foreach (var tenant in VisibleTenants)
                {
                    <option value="@tenant.Id">@tenant.Name</option>
                }
            </select>
            <div class="text-white-50 small mt-1">Selected: @(TenantSelectionService.SelectedTenantId?.ToString() ?? "None")</div>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tenants">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Tenants
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="items">
                <span class="bi bi-box-seam-fill-nav-menu" aria-hidden="true"></span> Items
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="orders">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Orders
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="bills">
                <span class="bi bi-receipt-nav-menu" aria-hidden="true"></span> Bills
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="localusers">
                <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Local Users
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="devices">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Devices
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="users">
                <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Users
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="auth">
                <span class="bi bi-lock-nav-menu" aria-hidden="true"></span> Auth Required
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Manage">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> @context.User.Identity?.Name
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                        <button type="submit" class="nav-link">
                            <span class="bi bi-arrow-bar-left-nav-menu" aria-hidden="true"></span> Logout
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Register">
                        <span class="bi bi-person-nav-menu" aria-hidden="true"></span> Register
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="Account/Login">
                        <span class="bi bi-person-badge-nav-menu" aria-hidden="true"></span> Login
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private string? currentUrl;
    private DotNetObjectReference<NavMenu>? dotNetHelper;

    private IReadOnlyList<TenantDTO> VisibleTenants => TenantSelectionService.AvailableTenants;

    // Property for getting the current value for <select>
    private string SelectedTenantIdStr => TenantSelectionService.SelectedTenantId?.ToString() ?? string.Empty;

    // Handle tenant selection change
    private async Task OnTenantSelectionChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        Console.WriteLine($"NavMenu: Tenant selection changed to '{value}'");
        
        var tenantId = Guid.TryParse(value, out var id) ? id : (Guid?)null;
        Console.WriteLine($"NavMenu: Parsed tenant ID: {tenantId}");
        
        await TenantSelectionService.SetTenantAsync(tenantId);
        Console.WriteLine("NavMenu: SetTenantAsync completed");
        
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("NavMenu: OnInitializedAsync called");
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        TenantSelectionService.Changed += OnTenantChanged;
        await TenantSelectionService.EnsureInitializedAsync();
        Console.WriteLine($"NavMenu: Initialized with {VisibleTenants.Count} tenants, selected: {SelectedTenantIdStr}");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            Console.WriteLine("NavMenu: OnAfterRenderAsync (first render)");
            try
            {
                dotNetHelper = DotNetObjectReference.Create(this);
                
                // Simple test to see if JS interop works
                await JS.InvokeVoidAsync("console.log", "NavMenu: Testing JS interop from Blazor");
                
                // Setup the event listener
                await JS.InvokeVoidAsync("eval", @"
                    (function(dotNetHelper) {
                        console.log('JS: setupTenantSelector function called');
                        const selector = document.getElementById('tenant-selector');
                        console.log('JS: Selector element:', selector);
                        
                        if (selector) {
                            console.log('JS: Adding change event listener to selector');
                            selector.addEventListener('change', async function(e) {
                                console.log('JS: Change event fired! New value:', e.target.value);
                                try {
                                    console.log('JS: Calling .NET method OnTenantChangedFromJS');
                                    await dotNetHelper.invokeMethodAsync('OnTenantChangedFromJS', e.target.value);
                                    console.log('JS: .NET method call completed');
                                } catch (error) {
                                    console.error('JS: Error calling .NET method:', error);
                                }
                            });
                            console.log('JS: Event listener added successfully');
                        } else {
                            console.error('JS: Tenant selector element NOT FOUND!');
                        }
                    })(arguments[0]);
                ", dotNetHelper);
                
                Console.WriteLine("NavMenu: JavaScript setup complete");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"NavMenu: ERROR setting up JS: {ex.GetType().Name}: {ex.Message}");
                Console.WriteLine($"Stack trace: {ex.StackTrace}");
            }
        }
    }

    [JSInvokable]
    public async Task OnTenantChangedFromJS(string value)
    {
        Console.WriteLine($"NavMenu: OnTenantChangedFromJS called with value '{value}'");
        
        var tenantId = Guid.TryParse(value, out var id) ? id : (Guid?)null;
        Console.WriteLine($"NavMenu: Parsed tenant ID from JS: {tenantId}");
        
        await TenantSelectionService.SetTenantAsync(tenantId);
        Console.WriteLine("NavMenu: SetTenantAsync completed from JS");
        
        await InvokeAsync(StateHasChanged);
    }

    private void OnTenantChanged()
    {
        Console.WriteLine("NavMenu: OnTenantChanged event received");
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
        TenantSelectionService.Changed -= OnTenantChanged;
        dotNetHelper?.Dispose();
    }
}