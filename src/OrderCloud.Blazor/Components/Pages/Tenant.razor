@page "/tenants"
@implements IDisposable
@using OrderCloud.Shared.Models
@using OrderCloud.Blazor.Services
@inject ITenantService TenantService
@inject ITenantSelectionService TenantSelectionService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Tenants</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-0">Tenants</h1>
            <div class="text-muted">@FilteredTenants.Count() tenant@(FilteredTenants.Count() == 1 ? "" : "s")</div>
        </div>
        <button class="btn btn-primary" @onclick="StartCreate">New Tenant</button>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-md-8">
            <input class="form-control" placeholder="Search tenants..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <div class="col-md-4">
            <button class="btn btn-outline-secondary w-100" @onclick="LoadTenantsAsync" disabled="@isLoading">Refresh</button>
        </div>
    </div>

    @if (showPanel)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>@(isViewMode ? "Tenant Details" : "Create Tenant")</strong>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClosePanel">Close</button>
            </div>
            <div class="card-body">
                @if (!isViewMode)
                {
                    <EditForm Model="formTenant" OnSubmit="HandleSubmitAsync">
                        <div>
                            <label class="form-label">Tenant Name</label>
                            <InputText class="form-control" @bind-Value="formTenant.Name" />
                        </div>

                        @if (!string.IsNullOrWhiteSpace(formError))
                        {
                            <div class="alert alert-danger mt-3 mb-0">@formError</div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-3">
                            <button type="button" class="btn btn-secondary" @onclick="ClosePanel">Cancel</button>
                            <button type="submit" class="btn btn-primary" disabled="@isSubmitting">Create</button>
                        </div>
                    </EditForm>
                }
                else
                {
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Name</dt>
                        <dd class="col-sm-9">@formTenant.Name</dd>
                        <dt class="col-sm-3">API Key</dt>
                        <dd class="col-sm-9"><code>@formTenant.ApiKey</code></dd>
                        <dt class="col-sm-3">API Secret</dt>
                        <dd class="col-sm-9"><code>@MaskSecret(formTenant.ApiSecret)</code></dd>
                        <dt class="col-sm-3">Id</dt>
                        <dd class="col-sm-9"><code>@formTenant.Id</code></dd>
                    </dl>

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <button type="button" class="btn btn-danger" @onclick="() => DeleteFromPanel(formTenant.Id, formTenant.Name)">Delete</button>
                        <button type="button" class="btn btn-secondary" @onclick="ClosePanel">Close</button>
                    </div>
                }
            </div>
        </div>
    }

    <div class="card">
        <div class="card-header">Assigned Tenants</div>
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>API Key</th>
                        <th style="width: 180px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredTenants.Any())
                    {
                        @foreach (var tenant in FilteredTenants)
                        {
                            <tr>
                                <td>@tenant.Name</td>
                                <td><code>@TruncateKey(tenant.ApiKey)</code></td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ViewTenant(tenant)">View</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(tenant.Id, tenant.Name)">Delete</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">No tenants found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private readonly List<TenantDTO> tenants = new();
    private string searchTerm = string.Empty;
    private TenantDTO formTenant = new();
    private bool isLoading;
    private bool isSubmitting;
    private bool showPanel;
    private bool isViewMode;
    private string? formError;

    private Guid? CurrentTenantId => TenantSelectionService.SelectedTenantId;

    private IEnumerable<TenantDTO> FilteredTenants => tenants
        .Where(tenant => !CurrentTenantId.HasValue || tenant.Id == CurrentTenantId.Value)
        .Where(tenant => string.IsNullOrWhiteSpace(searchTerm)
            || (tenant.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(tenant => tenant.Name);

    protected override async Task OnInitializedAsync()
    {
        await TenantSelectionService.EnsureInitializedAsync();
        TenantSelectionService.Changed += OnTenantChanged;
        await LoadTenantsAsync();
    }

    private async Task LoadTenantsAsync()
    {
        isLoading = true;

        try
        {
            await TenantSelectionService.RefreshAsync();
            tenants.Clear();
            tenants.AddRange(TenantSelectionService.AvailableTenants);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void StartCreate()
    {
        formTenant = new TenantDTO
        {
            Id = Guid.Empty,
            Name = string.Empty,
            ApiKey = string.Empty,
            ApiSecret = string.Empty
        };

        formError = null;
        isViewMode = false;
        showPanel = true;
    }

    private void ViewTenant(TenantDTO tenant)
    {
        formTenant = new TenantDTO
        {
            Id = tenant.Id,
            Name = tenant.Name,
            ApiKey = tenant.ApiKey,
            ApiSecret = tenant.ApiSecret,
            ApplicationUserId = tenant.ApplicationUserId
        };

        formError = null;
        isViewMode = true;
        showPanel = true;
    }

    private void ClosePanel()
    {
        showPanel = false;
        formError = null;
        isSubmitting = false;
    }

    private async Task HandleSubmitAsync()
    {
        formError = null;

        if (string.IsNullOrWhiteSpace(formTenant.Name))
        {
            formError = "Name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(TenantSelectionService.CurrentUserId))
        {
            formError = "You must be logged in to create a tenant.";
            return;
        }

        isSubmitting = true;

        try
        {
            var created = await TenantService.CreateAsync(new TenantDTO
            {
                Id = Guid.Empty,
                Name = formTenant.Name,
                ApiKey = string.Empty,
                ApiSecret = string.Empty,
                ApplicationUserId = TenantSelectionService.CurrentUserId
            });

            await LoadTenantsAsync();
            formTenant = created;
            isViewMode = true;
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteAsync(Guid id, string? name)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", $"Delete tenant '{name}'?");
        if (!confirm)
        {
            return;
        }

        try
        {
            await TenantService.DeleteAsync(id);
            await LoadTenantsAsync();

            if (showPanel && formTenant.Id == id)
            {
                ClosePanel();
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private async Task DeleteFromPanel(Guid id, string? name)
    {
        ClosePanel();
        await DeleteAsync(id, name);
    }

    private void OnTenantChanged()
    {
        tenants.Clear();
        tenants.AddRange(TenantSelectionService.AvailableTenants);
        _ = InvokeAsync(StateHasChanged);
    }

    private static string TruncateKey(string? key)
    {
        if (string.IsNullOrEmpty(key))
        {
            return "—";
        }

        return key.Length > 16 ? key[..8] + "..." + key[^4..] : key;
    }

    private static string MaskSecret(string? secret)
    {
        if (string.IsNullOrEmpty(secret))
        {
            return "—";
        }

        return new string('*', Math.Min(secret.Length, 24));
    }

    public void Dispose()
    {
        TenantSelectionService.Changed -= OnTenantChanged;
    }
}

