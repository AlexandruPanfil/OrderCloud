@code {
    private List<TenantDTO> tenants = new();
    private string searchTerm = string.Empty;
    private TenantDTO formTenant = new();
    private bool isLoading = false;
    private bool isSubmitting = false;
    private string? formError;
    private bool submitted = false;
    private bool showModal = false;
    private bool IsViewMode { get; set; }
    private string? copied;
    private bool showSecret = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadTenantsAsync();
    }

    private IEnumerable<TenantDTO> FilteredTenants =>
        tenants.Where(t => string.IsNullOrWhiteSpace(searchTerm) ||
            (t.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    private async Task LoadTenantsAsync()
    {
        isLoading = true;
        try
        {
            tenants = await TenantService.GetAllAsync();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void StartCreate()
    {
        formTenant = new() { Id = Guid.Empty, Name = string.Empty, ApiKey = string.Empty, ApiSecret = string.Empty };
        formError = null;
        submitted = false;
        IsViewMode = false;
        showModal = true;
    }

    private void ViewTenant(TenantDTO tenant)
    {
        formTenant = new TenantDTO
        {
            Id = tenant.Id,
            Name = tenant.Name,
            ApiKey = tenant.ApiKey,
            ApiSecret = tenant.ApiSecret
        };
        formError = null;
        IsViewMode = true;
        showSecret = false;
        copied = null;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        formError = null;
        submitted = false;
        showSecret = false;
        copied = null;
    }

    private async Task HandleSubmitAsync()
    {
        submitted = true;
        if (string.IsNullOrWhiteSpace(formTenant.Name))
        {
            formError = "Name is required.";
            return;
        }

        isSubmitting = true;
        formError = null;
        try
        {
            var toCreate = new TenantDTO
            {
                Id = Guid.Empty,
                Name = formTenant.Name,
                ApiKey = string.Empty,
                ApiSecret = string.Empty
            };
            var created = await TenantService.CreateAsync(toCreate);
            tenants.Add(created);
            // Switch to view mode to show the new keys
            formTenant = created;
            IsViewMode = true;
            submitted = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteAsync(Guid id, string? name)
    {
        var confirm = await JS.InvokeAsync<bool>("confirm", $"Delete tenant '{name}'?");
        if (!confirm) return;

        try
        {
            await TenantService.DeleteAsync(id);
            tenants.RemoveAll(t => t.Id == id);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private async Task DeleteFromModal(Guid id, string? name)
    {
        CloseModal();
        await DeleteAsync(id, name);
    }

    private async Task CopyToClipboardAsync(string? text)
    {
        if (string.IsNullOrEmpty(text)) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            copied = text == formTenant.ApiKey ? "key" : "secret";
            StateHasChanged();
            await Task.Delay(1800);
            copied = null;
            StateHasChanged();
        }
        catch { /* ignore clipboard errors */ }
    }

    private static string TruncateKey(string? key)
    {
        if (string.IsNullOrEmpty(key)) return "—";
        return key.Length > 16 ? key[..8] + "…" + key[^4..] : key;
    }

    private static string MaskSecret(string? secret)
    {
        if (string.IsNullOrEmpty(secret)) return "—";
        return new string('•', Math.Min(secret.Length, 24));
    }
}
