@page "/tenants"
@using OrderCloud.Blazor.Models
@inject OrderCloud.Blazor.Services.ITenantService TenantService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Tenants</PageTitle>

<div class="tenants-page">
    <div class="page-header">
        <div class="header-left">
            <h1 class="page-title">Tenants</h1>
            <span class="tenant-count">@tenants.Count tenant@(tenants.Count == 1 ? "" : "s")</span>
        </div>
        <button class="btn-create" @onclick="StartCreate">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2z" />
            </svg>
            New Tenant
        </button>
    </div>

    <div class="toolbar">
        <div class="search-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="search-icon">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z" />
            </svg>
            <input class="search-input" placeholder="Search tenants…" @bind="searchTerm" @bind:event="oninput" />
        </div>
        <button class="btn-refresh" @onclick="LoadTenantsAsync" title="Refresh">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z" />
            </svg>
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Loading tenants…</span>
        </div>
    }
    else if (!FilteredTenants.Any())
    {
        <div class="empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16" class="empty-icon">
                <path d="M1 2.5A1.5 1.5 0 0 1 2.5 1h3A1.5 1.5 0 0 1 7 2.5v3A1.5 1.5 0 0 1 5.5 7h-3A1.5 1.5 0 0 1 1 5.5zm8 0A1.5 1.5 0 0 1 10.5 1h3A1.5 1.5 0 0 1 15 2.5v3A1.5 1.5 0 0 1 13.5 7h-3A1.5 1.5 0 0 1 9 5.5zm-8 8A1.5 1.5 0 0 1 2.5 9h3A1.5 1.5 0 0 1 7 10.5v3A1.5 1.5 0 0 1 5.5 15h-3A1.5 1.5 0 0 1 1 13.5zm8 0A1.5 1.5 0 0 1 10.5 9h3A1.5 1.5 0 0 1 15 10.5v3A1.5 1.5 0 0 1 13.5 15h-3A1.5 1.5 0 0 1 9 13.5z" />
            </svg>
            <p>@(string.IsNullOrEmpty(searchTerm) ? "No tenants yet. Create your first one." : $"No tenants match \"{searchTerm}\"")</p>
        </div>
    }
    else
    {
        <div class="tenants-grid">
            @foreach (var t in FilteredTenants)
            {
                <div class="tenant-card" @onclick="() => ViewTenant(t)">
                    <div class="tenant-avatar">@(t.Name?.Length > 0 ? t.Name[0].ToString().ToUpper() : "?")</div>
                    <div class="tenant-info">
                        <div class="tenant-name">@t.Name</div>
                        <div class="tenant-key">
                            <span class="key-label">API Key</span>
                            <code class="key-value">@TruncateKey(t.ApiKey)</code>
                        </div>
                    </div>
                    <div class="tenant-actions" @onclick:stopPropagation="true">
                        <button class="btn-icon btn-view" title="View details" @onclick="() => ViewTenant(t)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                            </svg>
                        </button>
                        <button class="btn-icon btn-delete" title="Delete tenant" @onclick="() => DeleteAsync(t.Id, t.Name)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" />
                                <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                            </svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Modal Backdrop -->
@if (showModal)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-panel" @onclick:stopPropagation="true">
            <div class="modal-header">
                <div class="modal-title-group">
                    @if (IsViewMode)
                    {
                        <div class="modal-avatar">@(formTenant.Name?.Length > 0 ? formTenant.Name[0].ToString().ToUpper() : "?")</div>
                    }
                    <h2 class="modal-title">@(IsViewMode? formTenant.Name: "New Tenant")</h2>
                </div>
                <button class="modal-close" @onclick="CloseModal">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                    </svg>
                </button>
            </div>

            <div class="modal-body">
                @if (!IsViewMode)
                {
                    <!-- CREATE FORM -->
                    <EditForm Model="formTenant" OnValidSubmit="HandleSubmitAsync">
                        <div class="field-group">
                            <label class="field-label">Tenant Name <span class="required">*</span></label>
                            <input class="field-input @(string.IsNullOrEmpty(formTenant.Name) && submitted ? "input-error" : "")"
                                   @bind="formTenant.Name"
                                   placeholder="e.g. Acme Corporation"
                                   autofocus />
                            @if (string.IsNullOrWhiteSpace(formTenant.Name) && submitted)
                            {
                                <span class="field-error">Name is required.</span>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(formError))
                        {
                            <div class="alert-error">@formError</div>
                        }

                        <div class="modal-footer">
                            <button type="button" class="btn-secondary-action" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="btn-primary-action" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-sm"></span>
                                    <span>Creating…</span>
                                }
                                else
                                {
                                    <span>Create Tenant</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
                else
                {
                    <!-- VIEW MODE -->
                    <div class="detail-rows">
                        <div class="detail-row">
                            <span class="detail-label">Name</span>
                            <span class="detail-value">@formTenant.Name</span>
                        </div>

                        @if (!string.IsNullOrEmpty(formTenant.ApiKey))
                        {
                            <div class="detail-row">
                                <span class="detail-label">API Key</span>
                                <div class="copy-field">
                                    <code class="detail-code">@formTenant.ApiKey</code>
                                    <button class="btn-copy" @onclick="() => CopyToClipboardAsync(formTenant.ApiKey)" title="Copy API Key">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1z" />
                                            <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0z" />
                                        </svg>
                                        @(copied == "key" ? "Copied!" : "Copy")
                                    </button>
                                </div>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(formTenant.ApiSecret))
                        {
                            <div class="detail-row">
                                <span class="detail-label">API Secret</span>
                                <div class="copy-field">
                                    <code class="detail-code secret">@(showSecret? formTenant.ApiSecret: MaskSecret(formTenant.ApiSecret))</code>
                                    <button class="btn-copy" @onclick="() => showSecret = !showSecret" title="@(showSecret ? "Hide" : "Reveal")">
                                        @if (showSecret)
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755q-.247.248-.517.486z" />
                                                <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829" />
                                                <path d="M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12z" />
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                                            </svg>
                                        }
                                        @(showSecret ? "Hide" : "Reveal")
                                    </button>
                                    <button class="btn-copy" @onclick="() => CopyToClipboardAsync(formTenant.ApiSecret)" title="Copy Secret">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1z" />
                                            <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0z" />
                                        </svg>
                                        @(copied == "secret" ? "Copied!" : "Copy")
                                    </button>
                                </div>
                            </div>
                        }

                        <div class="detail-row">
                            <span class="detail-label">ID</span>
                            <span class="detail-value id-value">@formTenant.Id</span>
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn-danger-action" @onclick="() => DeleteFromModal(formTenant.Id, formTenant.Name)">
                            Delete Tenant
                        </button>
                        <button type="button" class="btn-secondary-action" @onclick="CloseModal">Close</button>
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    /* ── Page Layout ── */
    .tenants-page {
        padding: 2rem 2.5rem;
        max-width: 1100px;
        font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .header-left {
        display: flex;
        align-items: baseline;
        gap: 0.75rem;
    }

    .page-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
        letter-spacing: -0.02em;
    }

    .tenant-count {
        font-size: 0.85rem;
        color: #64748b;
        background: #f1f5f9;
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
        font-weight: 500;
    }

    /* ── Buttons ── */
    .btn-create {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.55rem 1.1rem;
        background: #1e40af;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
    }

        .btn-create:hover {
            background: #1d3ba8;
            transform: translateY(-1px);
        }

        .btn-create:active {
            transform: translateY(0);
        }

    .btn-refresh {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem;
        background: transparent;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        color: #64748b;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
    }

        .btn-refresh:hover {
            border-color: #94a3b8;
            color: #334155;
        }

    /* ── Toolbar ── */
    .toolbar {
        display: flex;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .search-box {
        position: relative;
        flex: 1;
    }

    .search-icon {
        position: absolute;
        left: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        pointer-events: none;
    }

    .search-input {
        width: 100%;
        padding: 0.55rem 0.75rem 0.55rem 2.25rem;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.9rem;
        color: #0f172a;
        background: #fff;
        transition: border-color 0.15s, box-shadow 0.15s;
        box-sizing: border-box;
    }

        .search-input:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }

    /* ── States ── */
    .loading-state {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: #64748b;
        padding: 3rem 0;
        justify-content: center;
    }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        color: #94a3b8;
        padding: 4rem 0;
    }

    .empty-icon {
        opacity: 0.4;
    }

    .empty-state p {
        font-size: 0.95rem;
        margin: 0;
    }

    /* ── Spinner ── */
    .spinner {
        width: 20px;
        height: 20px;
        border: 2px solid #e2e8f0;
        border-top-color: #3b82f6;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }

    .spinner-sm {
        display: inline-block;
        width: 14px;
        height: 14px;
        border: 2px solid rgba(255,255,255,0.4);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* ── Tenant Grid ── */
    .tenants-grid {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .tenant-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.9rem 1.1rem;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        cursor: pointer;
        transition: border-color 0.15s, box-shadow 0.15s, transform 0.1s;
    }

        .tenant-card:hover {
            border-color: #bfdbfe;
            box-shadow: 0 2px 10px rgba(59,130,246,0.08);
            transform: translateY(-1px);
        }

    .tenant-avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        color: #fff;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .tenant-info {
        flex: 1;
        min-width: 0;
    }

    .tenant-name {
        font-weight: 600;
        color: #0f172a;
        font-size: 0.95rem;
        margin-bottom: 0.2rem;
    }

    .tenant-key {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
    }

    .key-label {
        color: #94a3b8;
        font-weight: 500;
    }

    .key-value {
        color: #475569;
        font-family: 'Cascadia Code', 'Fira Code', monospace;
        font-size: 0.78rem;
    }

    .tenant-actions {
        display: flex;
        gap: 0.4rem;
        opacity: 0;
        transition: opacity 0.15s;
    }

    .tenant-card:hover .tenant-actions {
        opacity: 1;
    }

    .btn-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        border: 1px solid #e2e8f0;
        border-radius: 7px;
        background: transparent;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s, color 0.15s;
    }

    .btn-view {
        color: #3b82f6;
    }

        .btn-view:hover {
            background: #eff6ff;
            border-color: #bfdbfe;
        }

    .btn-delete {
        color: #ef4444;
    }

        .btn-delete:hover {
            background: #fef2f2;
            border-color: #fecaca;
        }

    /* ── Modal ── */
    .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.5);
        backdrop-filter: blur(4px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
        animation: fadeIn 0.15s ease;
    }

    .modal-panel {
        background: #fff;
        border-radius: 16px;
        width: 100%;
        max-width: 520px;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 20px 60px rgba(0,0,0,0.2);
        animation: slideUp 0.2s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .modal-title-group {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .modal-avatar {
        width: 38px;
        height: 38px;
        background: linear-gradient(135deg, #3b82f6, #1d4ed8);
        color: #fff;
        border-radius: 9px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        font-weight: 700;
    }

    .modal-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
        letter-spacing: -0.01em;
    }

    .modal-close {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: transparent;
        border: none;
        border-radius: 8px;
        color: #94a3b8;
        cursor: pointer;
        transition: background 0.15s, color 0.15s;
    }

        .modal-close:hover {
            background: #f1f5f9;
            color: #334155;
        }

    .modal-body {
