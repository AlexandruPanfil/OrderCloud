@page "/devices"
@implements IDisposable
@using OrderCloud.Shared.Models
@using OrderCloud.Blazor.Services
@inject IDeviceService DeviceService
@inject ITenantSelectionService TenantSelectionService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Devices</PageTitle>

<div class="devices-page">
    <div class="page-header">
        <div class="header-left">
            <h1 class="page-title">Devices</h1>
            <span class="count-badge">@FilteredDevices.Count() device@(FilteredDevices.Count() == 1 ? "" : "s")</span>
        </div>
        <div class="header-actions">
            <button class="btn-refresh" @onclick="LoadDataAsync" disabled="@isLoading" title="Refresh devices">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                    <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z" />
                </svg>
                Refresh
            </button>
            <button class="btn-create" @onclick="StartCreate">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                </svg>
                New Device
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(pageError))
    {
        <div class="alert alert-danger">@pageError</div>
    }

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Loading devices…</span>
        </div>
    }
    else if (!devices.Any())
    {
        <div class="empty-state">
            <p>No devices found. Create your first device to get started.</p>
        </div>
    }
    else
    {
        <div class="master-detail-container">
            <div class="devices-list-panel">
                <h2 class="panel-title">Devices</h2>

                <div class="filters-container">
                    <div class="filter-group">
                        <label class="filter-label">Status</label>
                        <select class="filter-select" @bind="statusFilter">
                            <option value="">All Statuses</option>
                            @foreach (var status in Statuses)
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="search-container">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                    </svg>
                    <input type="text" 
                           class="search-input" 
                           placeholder="Search devices..." 
                           @bind="searchTerm"
                           @bind:event="oninput" />
                    @if (!string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <button class="clear-search" @onclick="() => searchTerm = string.Empty" title="Clear search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                            </svg>
                        </button>
                    }
                </div>

                <div class="devices-list">
                    @if (!SearchFilteredDevices.Any())
                    {
                        <div class="no-results">No devices match your search or filter</div>
                    }
                    else
                    {
                        @foreach (var device in SearchFilteredDevices)
                        {
                            <div class="device-list-item @(selectedDevice?.Id == device.Id ? "selected" : "")" 
                                 @onclick="() => SelectDevice(device)">
                                <div class="device-info">
                                    <div class="device-header">
                                        <span class="device-name">@device.Name</span>
                                        <span class="status-badge status-@device.Status?.ToLower()">@device.Status</span>
                                    </div>
                                    <div class="device-meta">
                                        <span class="device-tenant">@ResolveTenantName(device.TenantId)</span>
                                    </div>
                                    <div class="device-date">
                                        Active until @device.ActiveTill.ToString("MMM dd, yyyy")
                                    </div>
                                </div>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                                </svg>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="device-details-panel">
                @if (isCreating)
                {
                    @* CREATE MODE *@
                    <div class="details-header">
                        <h2>Create New Device</h2>
                        <button class="btn-close" @onclick="CancelCreate">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                            </svg>
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <EditForm Model="formDevice" OnSubmit="SaveAsync" class="device-form">
                        <div class="form-row two-columns">
                            <div class="form-group">
                                <label class="form-label">Device Name</label>
                                <InputText class="form-input" @bind-Value="formDevice.Name" placeholder="Enter device name" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Status</label>
                                <InputSelect class="form-select" @bind-Value="formDevice.Status">
                                    <option value="">Select status</option>
                                    @foreach (var status in Statuses)
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <div class="form-row two-columns">
                            <div class="form-group">
                                <label class="form-label">Active Until</label>
                                <InputDate class="form-input" @bind-Value="formDevice.ActiveTill" />
                                <small class="form-hint">Device will be inactive after this date</small>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Tenant</label>
                                <select class="form-select" @bind="TenantIdStr">
                                    <option value="">Select tenant</option>
                                    @foreach (var tenant in VisibleTenants)
                                    {
                                        <option value="@tenant.Id">@tenant.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="button" class="btn-secondary" @onclick="CancelCreate">Cancel</button>
                            <button type="submit" class="btn-primary" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner spinner-sm"></span>
                                    <span>Creating…</span>
                                }
                                else
                                {
                                    <span>Create Device</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
                else if (selectedDevice == null)
                {
                    @* EMPTY STATE *@
                    <div class="empty-selection">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M11 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h6zM5 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H5z"/>
                            <path d="M8 14a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
                        </svg>
                        <p>Select a device to view details and manage</p>
                    </div>
                }
                else if (isEditing)
                {
                    @* EDIT MODE *@
                    <div class="details-header">
                        <h2>Edit Device</h2>
                        <div class="header-actions">
                            <button class="btn-delete" @onclick="() => DeleteDeviceAsync(selectedDevice.Id)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z"/>
                                    <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z"/>
                                </svg>
                                Delete
                            </button>
                            <button class="btn-close" @onclick="CancelEdit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <EditForm Model="formDevice" OnSubmit="SaveAsync" class="device-form">
                        <div class="form-row two-columns">
                            <div class="form-group">
                                <label class="form-label">Device Name</label>
                                <InputText class="form-input" @bind-Value="formDevice.Name" placeholder="Enter device name" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Status</label>
                                <InputSelect class="form-select" @bind-Value="formDevice.Status">
                                    <option value="">Select status</option>
                                    @foreach (var status in Statuses)
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </InputSelect>
                            </div>
                        </div>

                        <div class="form-row two-columns">
                            <div class="form-group">
                                <label class="form-label">Active Until</label>
                                <InputDate class="form-input" @bind-Value="formDevice.ActiveTill" />
                                <small class="form-hint">Device will be inactive after this date</small>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Tenant</label>
                                <select class="form-select" @bind="TenantIdStr">
                                    <option value="">Select tenant</option>
                                    @foreach (var tenant in VisibleTenants)
                                    {
                                        <option value="@tenant.Id">@tenant.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="button" class="btn-secondary" @onclick="CancelEdit">Cancel</button>
                            <button type="submit" class="btn-primary" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner spinner-sm"></span>
                                    <span>Saving…</span>
                                }
                                else
                                {
                                    <span>Save Changes</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
                else
                {
                    @* VIEW MODE *@
                    <div class="details-header">
                        <h2>@selectedDevice.Name</h2>
                        <div class="header-actions">
                            @if (!IsDeviceActivated(selectedDevice))
                            {
                                <button class="btn-activate" @onclick="() => ActivateAsync(selectedDevice)">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                        <path d="M10.97 4.97a.235.235 0 0 0-.02.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05z"/>
                                    </svg>
                                    Activate
                                </button>
                            }
                            <button class="btn-edit" @onclick="StartEdit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                                </svg>
                                Edit
                            </button>
                        </div>
                    </div>

                    <div class="device-details">
                        <div class="detail-section">
                            <h3>Device Information</h3>
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <label>Device ID (Activation Code)</label>
                                    <div class="detail-value">
                                        <code class="activation-code">@selectedDevice.Id</code>
                                    </div>
                                </div>
                                <div class="detail-item">
                                    <label>Device Name</label>
                                    <div class="detail-value">@selectedDevice.Name</div>
                                </div>
                                <div class="detail-item">
                                    <label>Status</label>
                                    <div class="detail-value">
                                        <span class="status-badge status-@selectedDevice.Status?.ToLower()">@selectedDevice.Status</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="detail-section">
                            <h3>Activation Details</h3>
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <label>Active Until</label>
                                    <div class="detail-value">@selectedDevice.ActiveTill.ToString("MMMM dd, yyyy")</div>
                                </div>
                                <div class="detail-item">
                                    <label>Days Remaining</label>
                                    <div class="detail-value">
                                        @{
                                            var daysRemaining = (selectedDevice.ActiveTill - DateTime.UtcNow).Days;
                                            var colorClass = daysRemaining > 30 ? "days-good" : daysRemaining > 7 ? "days-warning" : "days-danger";
                                        }
                                        <span class="@colorClass">@Math.Max(0, daysRemaining) days</span>
                                    </div>
                                </div>
                                <div class="detail-item">
                                    <label>Tenant</label>
                                    <div class="detail-value">@ResolveTenantName(selectedDevice.TenantId)</div>
                                </div>
                            </div>
                        </div>

                        @if (IsDeviceActivated(selectedDevice))
                        {
                            <div class="info-box info-box-success">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                </svg>
                                <span>This device is currently <strong>active</strong> and operational</span>
                            </div>
                        }
                        else
                        {
                            <div class="info-box info-box-warning">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                                </svg>
                                <span>This device is <strong>not active</strong>. Click "Activate" to enable it.</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private static readonly string[] Statuses = ["Active", "Inactive", "Maintenance", "Retired"];

    private readonly List<DeviceDTO> devices = new();
    private DeviceDTO? selectedDevice = null;
    private DeviceDTO formDevice = CreateEmptyDevice();

    private string searchTerm = string.Empty;
    private string statusFilter = string.Empty;
    private bool isLoading;
    private bool isSaving;
    private bool isCreating;
    private bool isEditing;
    private string? pageError;
    private string? formError;

    private Guid? CurrentTenantId => TenantSelectionService.SelectedTenantId;

    private IReadOnlyList<TenantDTO> VisibleTenants => TenantSelectionService.AvailableTenants;

    private IEnumerable<DeviceDTO> FilteredDevices => devices
        .Where(device => TenantSelectionService.CanAccessTenant(device.TenantId))
        .Where(device => !CurrentTenantId.HasValue || device.TenantId == CurrentTenantId.Value);

    private IEnumerable<DeviceDTO> SearchFilteredDevices => FilteredDevices
        .Where(device => string.IsNullOrWhiteSpace(searchTerm)
            || (device.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            || (device.Status?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            || ResolveTenantName(device.TenantId).Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
            || device.Id.ToString().Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .Where(device => string.IsNullOrWhiteSpace(statusFilter) || device.Status == statusFilter)
        .OrderBy(device => device.Name);

    private string TenantIdStr
    {
        get => formDevice.TenantId == Guid.Empty ? string.Empty : formDevice.TenantId.ToString();
        set => formDevice.TenantId = Guid.TryParse(value, out var tenantId) ? tenantId : Guid.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        await TenantSelectionService.EnsureInitializedAsync();
        TenantSelectionService.Changed += OnTenantChanged;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        pageError = null;

        try
        {
            await TenantSelectionService.RefreshAsync();
            devices.Clear();
            devices.AddRange(await DeviceService.GetAllAsync());

            // Update selected device if it still exists
            if (selectedDevice != null)
            {
                var updated = devices.FirstOrDefault(d => d.Id == selectedDevice.Id);
                selectedDevice = updated;
            }
        }
        catch (Exception ex)
        {
            devices.Clear();
            pageError = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void SelectDevice(DeviceDTO device)
    {
        selectedDevice = device;
        formDevice = Clone(device);
        isCreating = false;
        isEditing = false;
        formError = null;
    }

    private void StartCreate()
    {
        formDevice = new DeviceDTO
        {
            Id = Guid.Empty,
            Name = string.Empty,
            Status = string.Empty,
            ActiveTill = DateTime.UtcNow.AddMonths(1),
            TenantId = CurrentTenantId ?? Guid.Empty
        };

        selectedDevice = null;
        formError = null;
        isCreating = true;
        isEditing = false;
    }

    private void CancelCreate()
    {
        isCreating = false;
        formError = null;
        isSaving = false;
        formDevice = CreateEmptyDevice();
    }

    private void StartEdit()
    {
        if (selectedDevice == null) return;

        formDevice = Clone(selectedDevice);
        isEditing = true;
        isCreating = false;
        formError = null;
    }

    private void CancelEdit()
    {
        if (selectedDevice == null) return;

        formDevice = Clone(selectedDevice);
        isEditing = false;
        formError = null;
        isSaving = false;
    }

    private async Task SaveAsync()
    {
        formError = null;

        if (string.IsNullOrWhiteSpace(formDevice.Name))
        {
            formError = "Name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(formDevice.Status))
        {
            formError = "Status is required.";
            return;
        }

        if (formDevice.TenantId == Guid.Empty)
        {
            formError = "Tenant is required.";
            return;
        }

        if (!TenantSelectionService.CanAccessTenant(formDevice.TenantId))
        {
            formError = "You can only manage devices for your assigned tenants.";
            return;
        }

        isSaving = true;

        try
        {
            if (isCreating)
            {
                var created = await DeviceService.CreateAsync(formDevice);
                devices.Add(created);
                selectedDevice = created;
                formDevice = Clone(created);
                isCreating = false;
            }
            else if (isEditing)
            {
                var updated = await DeviceService.UpdateAsync(formDevice.Id, formDevice);
                SyncToList(updated);
                selectedDevice = updated;
                formDevice = Clone(updated);
                isEditing = false;
            }
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteDeviceAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this device?\n\nThis action cannot be undone."))
        {
            return;
        }

        try
        {
            await DeviceService.DeleteAsync(id);
            devices.RemoveAll(device => device.Id == id);

            if (selectedDevice?.Id == id)
            {
                selectedDevice = null;
                isEditing = false;
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private bool IsDeviceActivated(DeviceDTO device) =>
        string.Equals(device.Status, "Active", StringComparison.OrdinalIgnoreCase)
        && device.ActiveTill > DateTime.UtcNow;

    private async Task ActivateAsync(DeviceDTO device)
    {
        if (!TenantSelectionService.CanAccessTenant(device.TenantId))
        {
            await JS.InvokeVoidAsync("alert", "You can only activate devices for your assigned tenants.");
            return;
        }

        var updatedDevice = Clone(device);
        updatedDevice.Status = "Active";
        updatedDevice.ActiveTill = DateTime.UtcNow.AddMonths(1);

        try
        {
            var updated = await DeviceService.UpdateAsync(device.Id, updatedDevice);
            SyncToList(updated);

            if (selectedDevice?.Id == updated.Id)
            {
                selectedDevice = updated;
                formDevice = Clone(updated);
            }

            await JS.InvokeVoidAsync("alert", $"Device activated successfully!\n\nActivation code: {updated.Id}\n\nThis device will remain active until {updated.ActiveTill:MMMM dd, yyyy}");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Activation failed: {ex.Message}");
        }
    }

    private void SyncToList(DeviceDTO updated)
    {
        var index = devices.FindIndex(device => device.Id == updated.Id);
        if (index >= 0)
        {
            devices[index] = updated;
        }
    }

    private string ResolveTenantName(Guid tenantId) =>
        VisibleTenants.FirstOrDefault(tenant => tenant.Id == tenantId)?.Name ?? "—";

    private static DeviceDTO Clone(DeviceDTO device) => new()
    {
        Id = device.Id,
        Name = device.Name,
        Status = device.Status,
        ActiveTill = device.ActiveTill,
        TenantId = device.TenantId,
        Tenant = device.Tenant
    };

    private static DeviceDTO CreateEmptyDevice() => new()
    {
        Id = Guid.Empty,
        Name = string.Empty,
        Status = string.Empty,
        ActiveTill = DateTime.UtcNow.AddMonths(1),
        TenantId = Guid.Empty
    };

    private void OnTenantChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadDataAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        TenantSelectionService.Changed -= OnTenantChanged;
    }
}
