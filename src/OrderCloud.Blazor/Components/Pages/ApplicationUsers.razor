@page "/users"
@implements IDisposable
@using OrderCloud.Shared.Models
@using OrderCloud.Blazor.Services
@inject IApplicationUserService ApplicationUserService
@inject ITenantService TenantService
@inject ITenantSelectionService TenantSelectionService
@rendermode InteractiveServer

<PageTitle>Application Users</PageTitle>

<div class="users-page">
    <div class="page-header">
        <div class="header-left">
            <h1 class="page-title">Application Users</h1>
            <span class="count-badge">@VisibleUsers.Count() user@(VisibleUsers.Count() == 1 ? "" : "s")</span>
        </div>
        <button class="btn-refresh" @onclick="LoadDataAsync" disabled="@isLoading" title="Refresh users and tenants">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z" />
            </svg>
            Refresh
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Loading users and tenants…</span>
        </div>
    }
    else if (!VisibleTenants.Any())
    {
        <div class="empty-state">
            <p>No tenants are assigned to your account.</p>
        </div>
    }
    else if (!VisibleUsers.Any())
    {
        <div class="empty-state">
            <p>No users are assigned to the selected tenant.</p>
        </div>
    }
    else
    {
        <div class="note">
            Assign one or more tenants to each application user. Changes are saved per user.
        </div>

        <div class="users-grid">
            @foreach (var user in VisibleUsers)
            {
                <div class="user-card">
                    <div class="user-card-header">
                        <div>
                            <div class="user-name">@user.UserName</div>
                            <div class="user-email">@user.Email</div>
                        </div>
                        <button class="btn-save" disabled="@IsSaving(user.Id)" @onclick="() => SaveAssignmentsAsync(user.Id)">
                            @if (IsSaving(user.Id))
                            {
                                <span class="spinner spinner-sm"></span>
                                <span>Saving…</span>
                            }
                            else
                            {
                                <span>Save</span>
                            }
                        </button>
                    </div>

                    <div class="mt-3">
                        <div class="text-muted small mb-2">Assigned tenants</div>
                        @if (AssignedTenants(user.Id).Any())
                        {
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var tenant in AssignedTenants(user.Id))
                                {
                                    <span class="badge bg-primary-subtle text-primary border">@tenant.Name</span>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-muted">No tenants assigned.</div>
                        }
                    </div>

                    <details class="mt-3">
                        <summary>Manage tenant assignments</summary>

                        @if (!VisibleTenants.Any())
                        {
                            <div class="empty-state">
                                <p>Create tenants first before assigning them to users.</p>
                            </div>
                        }
                        else
                        {
                            <div class="assignment-grid">
                                @foreach (var tenant in VisibleTenants)
                                {
                                    var isAssigned = IsAssigned(user.Id, tenant.Id);
                                    <label class="tenant-chip @(isAssigned ? "active" : "")">
                                        <input type="checkbox"
                                               checked="@isAssigned"
                                               @onchange="e => ToggleAssignment(user.Id, tenant.Id, e)" />
                                        <span>@tenant.Name</span>
                                    </label>
                                }
                            </div>
                        }
                    </details>

                    <div class="card-meta">
                        <span>@SelectedCount(user.Id) tenant@(SelectedCount(user.Id) == 1 ? "" : "s") assigned</span>
                        @if (assignmentErrors.TryGetValue(user.Id, out var error) && !string.IsNullOrEmpty(error))
                        {
                            <span class="field-error">@error</span>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<ApplicationUserAssignmentDTO> users = new();
    private List<TenantDTO> tenants = new();
    private readonly Dictionary<string, HashSet<Guid>> selections = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, bool> savingStates = new();
    private readonly Dictionary<string, string?> assignmentErrors = new();
    private bool isLoading = true;

    private Guid? CurrentTenantId => TenantSelectionService.SelectedTenantId;

    private IReadOnlyList<TenantDTO> VisibleTenants => TenantSelectionService.AvailableTenants;

    private IEnumerable<ApplicationUserAssignmentDTO> VisibleUsers => users
        .Where(UserMatchesCurrentTenant)
        .OrderBy(user => user.UserName);

    protected override async Task OnInitializedAsync()
    {
        await TenantSelectionService.EnsureInitializedAsync();
        TenantSelectionService.Changed += OnTenantChanged;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            await TenantSelectionService.RefreshAsync();
            tenants = await TenantService.GetAllAsync();
            users = await ApplicationUserService.GetAllAsync();
            SyncSelections();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void SyncSelections()
    {
        selections.Clear();
        assignmentErrors.Clear();
        savingStates.Clear();

        foreach (var user in users)
        {
            selections[user.Id] = user.TenantIds?.ToHashSet() ?? new();
        }
    }

    private IEnumerable<TenantDTO> AssignedTenants(string userId) =>
        selections.TryGetValue(userId, out var set)
            ? VisibleTenants.Where(tenant => set.Contains(tenant.Id)).OrderBy(tenant => tenant.Name)
            : Enumerable.Empty<TenantDTO>();

    private bool IsAssigned(string userId, Guid tenantId) =>
        selections.TryGetValue(userId, out var set) && set.Contains(tenantId);

    private int SelectedCount(string userId) =>
        selections.TryGetValue(userId, out var set)
            ? VisibleTenants.Count(tenant => set.Contains(tenant.Id))
            : 0;

    private void ToggleAssignment(string userId, Guid tenantId, ChangeEventArgs args)
    {
        var isChecked = args.Value switch
        {
            bool flag => flag,
            string str when bool.TryParse(str, out var parsed) => parsed,
            _ => !IsAssigned(userId, tenantId)
        };

        if (!selections.TryGetValue(userId, out var set))
        {
            set = new HashSet<Guid>();
            selections[userId] = set;
        }

        if (isChecked)
        {
            set.Add(tenantId);
        }
        else
        {
            set.Remove(tenantId);
        }
    }

    private bool IsSaving(string userId) =>
        savingStates.TryGetValue(userId, out var isSaving) && isSaving;

    private async Task SaveAssignmentsAsync(string userId)
    {
        if (!selections.TryGetValue(userId, out var set))
        {
            set = new HashSet<Guid>();
            selections[userId] = set;
        }

        assignmentErrors[userId] = null;
        savingStates[userId] = true;

        try
        {
            await ApplicationUserService.UpdateTenantsAsync(userId, set.ToList());
            var user = users.FirstOrDefault(u => u.Id == userId);
            if (user != null)
            {
                user.TenantIds = set.ToList();
            }
        }
        catch (Exception ex)
        {
            assignmentErrors[userId] = ex.Message;
        }
        finally
        {
            savingStates[userId] = false;
            StateHasChanged();
        }
    }

    private bool UserMatchesCurrentTenant(ApplicationUserAssignmentDTO user)
    {
        if (!VisibleTenants.Any())
        {
            return false;
        }

        var tenantIds = user.TenantIds ?? new List<Guid>();

        return CurrentTenantId.HasValue
            ? tenantIds.Contains(CurrentTenantId.Value)
            : tenantIds.Any(tenantId => VisibleTenants.Any(tenant => tenant.Id == tenantId));
    }

    private void OnTenantChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        TenantSelectionService.Changed -= OnTenantChanged;
    }
}

