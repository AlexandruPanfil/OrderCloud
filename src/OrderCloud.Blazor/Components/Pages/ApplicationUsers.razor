@page "/users"
@using OrderCloud.Shared.Models
@using OrderCloud.Blazor.Services
@inject IApplicationUserService ApplicationUserService
@inject ITenantService TenantService
@rendermode InteractiveServer

<PageTitle>Application Users</PageTitle>

<div class="users-page">
    <div class="page-header">
        <div class="header-left">
            <h1 class="page-title">Application Users</h1>
            <span class="count-badge">@VisibleUsers.Count() user@(VisibleUsers.Count() == 1 ? "" : "s")</span>
        </div>
        <button class="btn-refresh" @onclick="LoadDataAsync" disabled="@isLoading" title="Refresh users and tenants">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z" />
            </svg>
            Refresh
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Loading users and tenants…</span>
        </div>
    }
    else if (!VisibleUsers.Any())
    {
        <div class="empty-state">
            <p>No application users found.</p>
        </div>
    }
    else
    {
        <div class="master-detail-container">
            <div class="users-list-panel">
                <h2 class="panel-title">Users</h2>
                <div class="search-container">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                    </svg>
                    <input type="text" 
                           class="search-input" 
                           placeholder="Search users..." 
                           @bind="userSearchQuery"
                           @bind:event="oninput" />
                    @if (!string.IsNullOrWhiteSpace(userSearchQuery))
                    {
                        <button class="clear-search" @onclick="() => userSearchQuery = string.Empty" title="Clear search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                            </svg>
                        </button>
                    }
                </div>
                <div class="users-list">
                    @if (!FilteredUsers.Any())
                    {
                        <div class="no-results">No users match your search</div>
                    }
                    else
                    {
                        @foreach (var user in FilteredUsers)
                        {
                            <div class="user-list-item @(selectedUser?.Id == user.Id ? "selected" : "")" 
                                 @onclick="() => SelectUser(user)">
                                <div class="user-info">
                                    <div class="user-name">@user.UserName</div>
                                    <div class="user-email">@user.Email</div>
                                </div>
                                <div class="user-tenant-count">
                                    <span class="badge">@user.TenantIds.Count</span>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="user-details-panel">
                @if (selectedUser == null)
                {
                    <div class="empty-selection">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                            <path d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2zm12 1a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1v-1c0-1-1-4-6-4s-6 3-6 4v1a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h12z"/>
                        </svg>
                        <p>Select a user to manage their tenant assignments</p>
                    </div>
                }
                else
                {
                    <div class="details-header">
                        <div>
                            <h2>@selectedUser.UserName</h2>
                            <p class="text-muted">@selectedUser.Email</p>
                        </div>
                        <button class="btn-save" disabled="@isSaving" @onclick="SaveAssignmentsAsync">
                            @if (isSaving)
                            {
                                <span class="spinner spinner-sm"></span>
                                <span>Saving…</span>
                            }
                            else
                            {
                                <span>Save Changes</span>
                            }
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(saveError))
                    {
                        <div class="alert alert-danger">@saveError</div>
                    }
                    @if (saveSuccess)
                    {
                        <div class="alert alert-success">Tenant assignments saved successfully!</div>
                    }

                    <div class="assigned-tenants-section">
                        <h3>Assigned Tenants</h3>
                        @if (AssignedTenants().Any())
                        {
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @foreach (var tenant in AssignedTenants())
                                {
                                    <span class="badge bg-primary">@tenant.Name</span>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">No tenants assigned yet.</p>
                        }
                    </div>

                    <div class="tenant-selection-section">
                        <div class="section-header">
                            <h3>Manage Tenant Access</h3>
                            <div class="tenant-filters">
                                <label class="filter-option">
                                    <input type="radio" 
                                           name="tenantFilter" 
                                           value="all"
                                           checked="@(tenantFilter == "all")"
                                           @onchange="@(() => tenantFilter = "all")" />
                                    <span>All Tenants</span>
                                </label>
                                <label class="filter-option">
                                    <input type="radio" 
                                           name="tenantFilter" 
                                           value="selected"
                                           checked="@(tenantFilter == "selected")"
                                           @onchange="@(() => tenantFilter = "selected")" />
                                    <span>Selected Only</span>
                                </label>
                            </div>
                        </div>

                        <div class="search-container">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                            </svg>
                            <input type="text" 
                                   class="search-input" 
                                   placeholder="Search tenants..." 
                                   @bind="tenantSearchQuery"
                                   @bind:event="oninput" />
                            @if (!string.IsNullOrWhiteSpace(tenantSearchQuery))
                            {
                                <button class="clear-search" @onclick="() => tenantSearchQuery = string.Empty" title="Clear search">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                                    </svg>
                                </button>
                            }
                        </div>

                        @if (!VisibleTenants.Any())
                        {
                            <div class="empty-state">
                                <p>No tenants found. Create tenants first before assigning them to users.</p>
                            </div>
                        }
                        else if (!FilteredTenants.Any())
                        {
                            <div class="no-results">No tenants match your search or filter</div>
                        }
                        else
                        {
                            <div class="tenant-selection-grid">
                                @foreach (var tenant in FilteredTenants)
                                {
                                    var isAssigned = IsAssigned(tenant.Id);
                                    <label class="tenant-checkbox-item @(isAssigned ? "checked" : "")">
                                        <input type="checkbox"
                                               checked="@isAssigned"
                                               @onchange="e => ToggleAssignment(tenant.Id, e)" />
                                        <span class="tenant-label">@tenant.Name</span>
                                    </label>
                                }
                            </div>
                        }
                    </div>

                    <div class="details-footer">
                        <span class="text-muted">@SelectedCount() tenant@(SelectedCount() == 1 ? "" : "s") selected</span>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<ApplicationUserAssignmentDTO> users = new();
    private List<TenantDTO> tenants = new();
    private ApplicationUserAssignmentDTO? selectedUser = null;
    private HashSet<Guid> selectedTenantIds = new();
    private bool isLoading = true;
    private bool isSaving = false;
    private string? saveError = null;
    private bool saveSuccess = false;
    private string userSearchQuery = string.Empty;
    private string tenantSearchQuery = string.Empty;
    private string tenantFilter = "all";

    private IReadOnlyList<TenantDTO> VisibleTenants => tenants;

    private IEnumerable<ApplicationUserAssignmentDTO> VisibleUsers => users;

    private IEnumerable<ApplicationUserAssignmentDTO> FilteredUsers
    {
        get
        {
            if (string.IsNullOrWhiteSpace(userSearchQuery))
                return VisibleUsers;

            var query = userSearchQuery.Trim().ToLowerInvariant();
            return VisibleUsers.Where(u =>
                u.UserName.ToLowerInvariant().Contains(query) ||
                (u.Email?.ToLowerInvariant().Contains(query) ?? false));
        }
    }

    private IEnumerable<TenantDTO> FilteredTenants
    {
        get
        {
            var filtered = VisibleTenants.AsEnumerable();

            // Apply filter (all or selected only)
            if (tenantFilter == "selected")
            {
                filtered = filtered.Where(t => selectedTenantIds.Contains(t.Id));
            }

            // Apply search query
            if (!string.IsNullOrWhiteSpace(tenantSearchQuery))
            {
                var query = tenantSearchQuery.Trim().ToLowerInvariant();
                filtered = filtered.Where(t => t.Name.ToLowerInvariant().Contains(query));
            }

            return filtered.OrderBy(t => t.Name);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            tenants = (await TenantService.GetAllAsync())
                .OrderBy(tenant => tenant.Name)
                .ToList();

            Console.WriteLine($"[ApplicationUsers] Loaded {tenants.Count} tenants from API");
            foreach (var tenant in tenants)
            {
                Console.WriteLine($"  - Tenant: {tenant.Name} (ID: {tenant.Id})");
            }

            await ReloadUsersAsync();
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task ReloadUsersAsync()
    {
        users = (await ApplicationUserService.GetAllAsync())
            .OrderBy(user => user.UserName)
            .ToList();

        Console.WriteLine($"[ApplicationUsers] Loaded {users.Count} users from API");
        foreach (var user in users)
        {
            Console.WriteLine($"  - User: {user.UserName} ({user.Email}) - Tenants: {user.TenantIds.Count}");
        }

        // Update selected user data if one is selected
        if (selectedUser != null)
        {
            var updatedUser = users.FirstOrDefault(u => u.Id == selectedUser.Id);
            if (updatedUser != null)
            {
                selectedUser = updatedUser;
                selectedTenantIds = updatedUser.TenantIds?.ToHashSet() ?? new HashSet<Guid>();
            }
        }
    }

    private void SelectUser(ApplicationUserAssignmentDTO user)
    {
        selectedUser = user;
        selectedTenantIds = user.TenantIds?.ToHashSet() ?? new HashSet<Guid>();
        saveError = null;
        saveSuccess = false;
        tenantSearchQuery = string.Empty;
        tenantFilter = "all";
    }

    private IEnumerable<TenantDTO> AssignedTenants()
    {
        if (selectedUser == null)
            return Enumerable.Empty<TenantDTO>();

        return VisibleTenants
            .Where(tenant => selectedTenantIds.Contains(tenant.Id))
            .OrderBy(tenant => tenant.Name);
    }

    private bool IsAssigned(Guid tenantId)
    {
        return selectedTenantIds.Contains(tenantId);
    }

    private int SelectedCount()
    {
        return VisibleTenants.Count(tenant => selectedTenantIds.Contains(tenant.Id));
    }

    private void ToggleAssignment(Guid tenantId, ChangeEventArgs args)
    {
        var isChecked = args.Value switch
        {
            bool flag => flag,
            string str when bool.TryParse(str, out var parsed) => parsed,
            _ => !IsAssigned(tenantId)
        };

        if (isChecked)
        {
            selectedTenantIds.Add(tenantId);
        }
        else
        {
            selectedTenantIds.Remove(tenantId);
        }

        saveError = null;
        saveSuccess = false;
    }

    private async Task SaveAssignmentsAsync()
    {
        if (selectedUser == null)
            return;

        saveError = null;
        saveSuccess = false;
        isSaving = true;

        try
        {
            await ApplicationUserService.UpdateTenantsAsync(selectedUser.Id, selectedTenantIds.ToList());
            await ReloadUsersAsync();
            saveSuccess = true;

            // Auto-hide success message after 3 seconds
            _ = Task.Delay(3000).ContinueWith(_ => 
            {
                saveSuccess = false;
                InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            saveError = ex.Message;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }
}

