@page "/localusers"
@implements IDisposable
@using OrderCloud.Shared.Models
@using OrderCloud.Blazor.Services
@inject ILocalUserService LocalUserService
@inject IDeviceService DeviceService
@inject ITenantSelectionService TenantSelectionService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Local Users</PageTitle>

<div class="localusers-page">
    <div class="page-header">
        <div class="header-left">
            <h1 class="page-title">Local Users</h1>
            <span class="count-badge">@FilteredLocalUsers.Count() user@(FilteredLocalUsers.Count() == 1 ? "" : "s")</span>
        </div>
        <div class="header-actions">
            <button class="btn-refresh" @onclick="LoadDataAsync" disabled="@isLoading" title="Refresh local users">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                    <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z" />
                </svg>
                Refresh
            </button>
            <button class="btn-create" @onclick="StartCreate">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                </svg>
                New Local User
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(pageError))
    {
        <div class="alert alert-danger">@pageError</div>
    }

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Loading local users…</span>
        </div>
    }
    else if (!localUsers.Any())
    {
        <div class="empty-state">
            <p>No local users found. Create your first local user to get started.</p>
        </div>
    }
    else
    {
        <div class="master-detail-container">
            <div class="users-list-panel">
                <h2 class="panel-title">Local Users</h2>

                <div class="search-container">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                    </svg>
                    <input type="text" 
                           class="search-input" 
                           placeholder="Search users..." 
                           @bind="searchTerm"
                           @bind:event="oninput" />
                    @if (!string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <button class="clear-search" @onclick="() => searchTerm = string.Empty" title="Clear search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                            </svg>
                        </button>
                    }
                </div>

                <div class="users-list">
                    @if (!FilteredLocalUsers.Any())
                    {
                        <div class="no-results">No users match your search</div>
                    }
                    else
                    {
                        @foreach (var user in FilteredLocalUsers)
                        {
                            <div class="user-list-item @(selectedUser?.Id == user.Id ? "selected" : "")" 
                                 @onclick="() => SelectUser(user)">
                                <div class="user-info">
                                    <div class="user-name">@user.Name</div>
                                    <div class="user-meta">
                                        <span class="user-tenant">@ResolveTenantName(user.TenantId)</span>
                                        @if (user.DeviceId.HasValue)
                                        {
                                            <span class="user-separator">•</span>
                                            <span class="user-device">@ResolveDeviceName(user.DeviceId)</span>
                                        }
                                    </div>
                                </div>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                                </svg>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="user-details-panel">
                @if (isCreating)
                {
                    @* CREATE MODE *@
                    <div class="details-header">
                        <h2>Create New Local User</h2>
                        <button class="btn-close" @onclick="CancelCreate">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                            </svg>
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <EditForm Model="formUser" OnSubmit="SaveAsync" class="user-form">
                        <div class="form-row two-columns">
                            <div class="form-group">
                                <label class="form-label">Name</label>
                                <InputText class="form-input" @bind-Value="formUser.Name" placeholder="Enter user name" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">PIN Code</label>
                                <InputText class="form-input" type="password" @bind-Value="formUser.PinCode" placeholder="Enter 4-digit PIN" />
                                <small class="form-hint">4-digit numeric code for user authentication</small>
                            </div>
                        </div>

                        <div class="form-row two-columns">
                            <div class="form-group">
                                <label class="form-label">Tenant</label>
                                <select class="form-select" @bind="TenantIdStr">
                                    <option value="">Select tenant</option>
                                    @foreach (var tenant in VisibleTenants)
                                    {
                                        <option value="@tenant.Id">@tenant.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Device (Optional)</label>
                                <select class="form-select" @bind="DeviceIdStr" disabled="@(formUser.TenantId == Guid.Empty)">
                                    <option value="">No device assigned</option>
                                    @foreach (var device in AvailableDevices)
                                    {
                                        <option value="@device.Id">@device.Name</option>
                                    }
                                </select>
                                @if (formUser.TenantId == Guid.Empty)
                                {
                                    <small class="form-hint">Select a tenant first</small>
                                }
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="button" class="btn-secondary" @onclick="CancelCreate">Cancel</button>
                            <button type="submit" class="btn-primary" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner spinner-sm"></span>
                                    <span>Creating…</span>
                                }
                                else
                                {
                                    <span>Create Local User</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
                else if (selectedUser == null)
                {
                    @* EMPTY STATE *@
                    <div class="empty-selection">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                            <path d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z"/>
                        </svg>
                        <p>Select a local user to view details and manage</p>
                    </div>
                }
                else if (isEditing)
                {
                    @* EDIT MODE *@
                    <div class="details-header">
                        <h2>Edit Local User</h2>
                        <div class="header-actions">
                            <button class="btn-delete" @onclick="() => DeleteUserAsync(selectedUser.Id)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z"/>
                                    <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z"/>
                                </svg>
                                Delete
                            </button>
                            <button class="btn-close" @onclick="CancelEdit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                            </svg>
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <EditForm Model="formUser" OnSubmit="SaveAsync" class="user-form">
                        <div class="form-row two-columns">
                            <div class="form-group">
                                <label class="form-label">Name</label>
                                <InputText class="form-input" @bind-Value="formUser.Name" placeholder="Enter user name" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">PIN Code</label>
                                <InputText class="form-input" type="password" @bind-Value="formUser.PinCode" placeholder="Enter 4-digit PIN" />
                                <small class="form-hint">4-digit numeric code for user authentication</small>
                            </div>
                        </div>

                        <div class="form-row two-columns">
                            <div class="form-group">
                                <label class="form-label">Tenant</label>
                                <select class="form-select" @bind="TenantIdStr">
                                    <option value="">Select tenant</option>
                                    @foreach (var tenant in VisibleTenants)
                                    {
                                        <option value="@tenant.Id">@tenant.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Device (Optional)</label>
                                <select class="form-select" @bind="DeviceIdStr" disabled="@(formUser.TenantId == Guid.Empty)">
                                    <option value="">No device assigned</option>
                                    @foreach (var device in AvailableDevices)
                                    {
                                        <option value="@device.Id">@device.Name</option>
                                    }
                                </select>
                                @if (formUser.TenantId == Guid.Empty)
                                {
                                    <small class="form-hint">Select a tenant first</small>
                                }
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="button" class="btn-secondary" @onclick="CancelEdit">Cancel</button>
                            <button type="submit" class="btn-primary" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner spinner-sm"></span>
                                    <span>Saving…</span>
                                }
                                else
                                {
                                    <span>Save Changes</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
                else
                {
                    @* VIEW MODE *@
                    <div class="details-header">
                        <h2>@selectedUser.Name</h2>
                        <button class="btn-edit" @onclick="StartEdit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                            </svg>
                            Edit
                        </button>
                    </div>

                    <div class="user-details">
                        <div class="detail-section">
                            <h3>User Information</h3>
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <label>User ID</label>
                                    <div class="detail-value">
                                        <code>@selectedUser.Id</code>
                                    </div>
                                </div>
                                <div class="detail-item">
                                    <label>Name</label>
                                    <div class="detail-value">@selectedUser.Name</div>
                                </div>
                                <div class="detail-item">
                                    <label>PIN Code</label>
                                    <div class="detail-value">
                                        <span class="pin-masked">••••</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="detail-section">
                            <h3>Assignment</h3>
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <label>Tenant</label>
                                    <div class="detail-value">@ResolveTenantName(selectedUser.TenantId)</div>
                                </div>
                                <div class="detail-item">
                                    <label>Device</label>
                                    <div class="detail-value">
                                        @if (selectedUser.DeviceId.HasValue)
                                        {
                                            <span>@ResolveDeviceName(selectedUser.DeviceId)</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No device assigned</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (selectedUser.DeviceId.HasValue)
                        {
                            <div class="info-box">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
                                </svg>
                                <span>This user is assigned to device <strong>@ResolveDeviceName(selectedUser.DeviceId)</strong></span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<LocalUserDTO> localUsers = new();
    private List<DeviceDTO> devices = new();
    private LocalUserDTO? selectedUser = null;
    private LocalUserDTO formUser = CreateEmptyUser();

    private string searchTerm = string.Empty;
    private bool isLoading = true;
    private bool isSaving;
    private bool isCreating;
    private bool isEditing;
    private string? pageError;
    private string? formError;

    private string TenantIdStr
    {
        get => formUser.TenantId == Guid.Empty ? string.Empty : formUser.TenantId.ToString();
        set
        {
            formUser.TenantId = Guid.TryParse(value, out var tenantId) ? tenantId : Guid.Empty;

            if (formUser.DeviceId.HasValue &&
                !devices.Any(d => d.Id == formUser.DeviceId.Value && d.TenantId == formUser.TenantId))
            {
                formUser.DeviceId = null;
            }
        }
    }

    private string DeviceIdStr
    {
        get => formUser.DeviceId?.ToString() ?? string.Empty;
        set => formUser.DeviceId = Guid.TryParse(value, out var deviceId) ? deviceId : null;
    }

    private Guid? CurrentTenantId => TenantSelectionService.SelectedTenantId;

    private IReadOnlyList<TenantDTO> VisibleTenants => TenantSelectionService.AvailableTenants;

    private IEnumerable<LocalUserDTO> FilteredLocalUsers => localUsers.Where(user =>
        TenantSelectionService.CanAccessTenant(user.TenantId) &&
        (!CurrentTenantId.HasValue || user.TenantId == CurrentTenantId.Value) &&
        (string.IsNullOrWhiteSpace(searchTerm) ||
         user.Id.ToString().Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
         (user.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
         (user.PinCode?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
         ResolveTenantName(user.TenantId).Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
         ResolveDeviceName(user.DeviceId).Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
        .OrderBy(user => user.Name);

    private IEnumerable<DeviceDTO> AvailableDevices =>
        formUser.TenantId == Guid.Empty
            ? Enumerable.Empty<DeviceDTO>()
            : devices
                .Where(device => device.TenantId == formUser.TenantId && TenantSelectionService.CanAccessTenant(device.TenantId))
                .OrderBy(device => device.Name);

    protected override async Task OnInitializedAsync()
    {
        await TenantSelectionService.EnsureInitializedAsync();
        TenantSelectionService.Changed += OnTenantChanged;
        await LoadDataAsync();
    }

    private void OnTenantChanged()
    {
        if (isCreating)
        {
            formUser.TenantId = CurrentTenantId ?? Guid.Empty;
            if (formUser.DeviceId.HasValue && !AvailableDevices.Any(device => device.Id == formUser.DeviceId.Value))
            {
                formUser.DeviceId = null;
            }
        }

        _ = InvokeAsync(async () =>
        {
            await LoadDataAsync();
            StateHasChanged();
        });
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        pageError = null;

        try
        {
            await TenantSelectionService.RefreshAsync();
            localUsers = await LocalUserService.GetAllAsync();

            // Update selected user if it still exists
            if (selectedUser != null)
            {
                var updated = localUsers.FirstOrDefault(u => u.Id == selectedUser.Id);
                selectedUser = updated;
            }
        }
        catch (Exception ex)
        {
            localUsers = new();
            pageError = ex.Message;
        }

        try
        {
            devices = await DeviceService.GetAllAsync();
        }
        catch
        {
            devices = new();
        }

        isLoading = false;
        StateHasChanged();
    }

    private void SelectUser(LocalUserDTO user)
    {
        selectedUser = user;
        formUser = Clone(user);
        isCreating = false;
        isEditing = false;
        formError = null;
    }

    private void StartCreate()
    {
        formUser = CreateEmptyUser(CurrentTenantId);
        selectedUser = null;
        formError = null;
        isCreating = true;
        isEditing = false;
    }

    private void CancelCreate()
    {
        isCreating = false;
        formError = null;
        isSaving = false;
        formUser = CreateEmptyUser();
    }

    private void StartEdit()
    {
        if (selectedUser == null) return;

        formUser = Clone(selectedUser);
        isEditing = true;
        isCreating = false;
        formError = null;
    }

    private void CancelEdit()
    {
        if (selectedUser == null) return;

        formUser = Clone(selectedUser);
        isEditing = false;
        formError = null;
        isSaving = false;
    }

    private async Task SaveAsync()
    {
        formError = null;

        if (string.IsNullOrWhiteSpace(formUser.Name))
        {
            formError = "Name is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(formUser.PinCode))
        {
            formError = "PIN code is required.";
            return;
        }

        if (formUser.TenantId == Guid.Empty)
        {
            formError = "Tenant is required.";
            return;
        }

        if (!TenantSelectionService.CanAccessTenant(formUser.TenantId))
        {
            formError = "You can only manage local users for your assigned tenant.";
            return;
        }

        if (formUser.DeviceId.HasValue &&
            !devices.Any(device => device.Id == formUser.DeviceId.Value && device.TenantId == formUser.TenantId))
        {
            formError = "Selected device must belong to the selected tenant.";
            return;
        }

        isSaving = true;

        try
        {
            if (isCreating)
            {
                var created = await LocalUserService.CreateAsync(formUser);
                localUsers.Add(created);
                selectedUser = created;
                formUser = Clone(created);
                isCreating = false;
            }
            else if (isEditing)
            {
                var updated = await LocalUserService.UpdateAsync(formUser.Id, formUser);
                SyncToList(updated);
                selectedUser = updated;
                formUser = Clone(updated);
                isEditing = false;
            }
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteUserAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this local user?\n\nThis action cannot be undone."))
        {
            return;
        }

        try
        {
            await LocalUserService.DeleteAsync(id);
            localUsers.RemoveAll(user => user.Id == id);

            if (selectedUser?.Id == id)
            {
                selectedUser = null;
                isEditing = false;
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private void SyncToList(LocalUserDTO updated)
    {
        var index = localUsers.FindIndex(user => user.Id == updated.Id);
        if (index >= 0)
        {
            localUsers[index] = updated;
        }
    }

    private string ResolveTenantName(Guid tenantId) =>
        VisibleTenants.FirstOrDefault(tenant => tenant.Id == tenantId)?.Name ?? "—";

    private string ResolveDeviceName(Guid? deviceId) =>
        deviceId.HasValue
            ? devices.FirstOrDefault(device => device.Id == deviceId.Value)?.Name ?? "—"
            : "—";

    private static LocalUserDTO Clone(LocalUserDTO user) => new()
    {
        Id = user.Id,
        Name = user.Name,
        PinCode = user.PinCode,
        DeviceId = user.DeviceId,
        TenantId = user.TenantId,
        Device = user.Device,
        Tenant = user.Tenant
    };

    private static LocalUserDTO CreateEmptyUser(Guid? tenantId = null) => new()
    {
        Name = string.Empty,
        PinCode = string.Empty,
        DeviceId = null,
        TenantId = tenantId ?? Guid.Empty
    };

    public void Dispose()
    {
        TenantSelectionService.Changed -= OnTenantChanged;
    }
}

