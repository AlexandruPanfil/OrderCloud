@page "/items"
@implements IDisposable
@using OrderCloud.Shared.Models
@using OrderCloud.Blazor.Services
@inject ICatalogItemService ItemService
@inject ITenantSelectionService TenantSelectionService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Items</PageTitle>

<div class="items-page">
    <div class="page-header">
        <div class="header-left">
            <h1 class="page-title">Catalog Items</h1>
            <span class="count-badge">@VisibleItems.Count() item@(VisibleItems.Count() == 1 ? "" : "s")</span>
        </div>
        <div class="header-actions">
            <button class="btn-refresh" @onclick="LoadDataAsync" disabled="@isLoading" title="Refresh items">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                    <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z" />
                </svg>
                Refresh
            </button>
            <button class="btn-create" @onclick="StartCreate">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                </svg>
                New Item
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(pageError))
    {
        <div class="alert alert-danger">@pageError</div>
    }

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Loading items…</span>
        </div>
    }
    else if (!items.Any())
    {
        <div class="empty-state">
            <p>No items found. Create your first catalog item to get started.</p>
        </div>
    }
    else
    {
        <div class="master-detail-container">
            <div class="items-list-panel">
                <h2 class="panel-title">Items</h2>

                <div class="filters-container">
                    <div class="filter-group">
                        <label class="filter-label">Tenant</label>
                        <select class="filter-select" @bind="TenantFilterIdStr">
                            <option value="">All Tenants</option>
                            @foreach (var tenant in VisibleTenants)
                            {
                                <option value="@tenant.Id">@tenant.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="search-container">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                    </svg>
                    <input type="text" 
                           class="search-input" 
                           placeholder="Search items..." 
                           @bind="searchTerm"
                           @bind:event="oninput" />
                    @if (!string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <button class="clear-search" @onclick="() => searchTerm = string.Empty" title="Clear search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                            </svg>
                        </button>
                    }
                </div>

                <div class="items-list">
                    @if (!VisibleItems.Any())
                    {
                        <div class="no-results">No items match your search or filter</div>
                    }
                    else
                    {
                        @foreach (var item in VisibleItems)
                        {
                            <div class="item-list-item @(selectedItem?.Id == item.Id ? "selected" : "")" 
                                 @onclick="() => SelectItem(item)">
                                <div class="item-info">
                                    <div class="item-name">@item.Name</div>
                                    <div class="item-meta">
                                        <span class="item-price">$@item.Price.ToString("F2")</span>
                                        <span class="item-separator">•</span>
                                        <span class="item-tva">@item.TVA</span>
                                    </div>
                                    <div class="item-tenant">@ResolveTenantName(item.TenantId)</div>
                                </div>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                                </svg>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="item-details-panel">
                @if (isCreating)
                {
                    <div class="details-header">
                        <h2>Create New Item</h2>
                        <button class="btn-close" @onclick="CancelCreate">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                            </svg>
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <EditForm Model="formItem" OnSubmit="SaveAsync" class="item-form">
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Item Name</label>
                                <InputText class="form-input" @bind-Value="formItem.Name" placeholder="Enter item name" />
                            </div>
                        </div>

                        <div class="form-row two-columns">
                            <div class="form-group">
                                <label class="form-label">Price</label>
                                <InputNumber class="form-input" @bind-Value="formItem.Price" placeholder="0.00" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">TVA Rate</label>
                                <select class="form-select" @bind="formItem.TVA">
                                    <option value="">Select TVA</option>
                                    @foreach (var rate in TvaRates)
                                    {
                                        <option value="@rate">@rate</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Tenant</label>
                                <select class="form-select" @bind="ItemTenantIdStr">
                                    <option value="">Select tenant</option>
                                    @foreach (var tenant in VisibleTenants)
                                    {
                                        <option value="@tenant.Id">@tenant.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="button" class="btn-secondary" @onclick="CancelCreate">Cancel</button>
                            <button type="submit" class="btn-primary" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner spinner-sm"></span>
                                    <span>Creating…</span>
                                }
                                else
                                {
                                    <span>Create Item</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
                else if (selectedItem == null)
                {
                    <div class="empty-selection">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M2.97 1.35A1 1 0 0 1 3.73 1h8.54a1 1 0 0 1 .76.35l2.609 3.044A1.5 1.5 0 0 1 16 5.37v.255a2.375 2.375 0 0 1-4.25 1.458A2.371 2.371 0 0 1 9.875 8 2.37 2.37 0 0 1 8 7.083 2.37 2.37 0 0 1 6.125 8a2.37 2.37 0 0 1-1.875-.917A2.375 2.375 0 0 1 0 5.625V5.37a1.5 1.5 0 0 1 .361-.976l2.61-3.045zm1.78 4.275a1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0 1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0 1.375 1.375 0 1 0 2.75 0V5.37a.5.5 0 0 0-.12-.325L12.27 2H3.73L1.12 5.045A.5.5 0 0 0 1 5.37v.255a1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0zM1.5 8.5A.5.5 0 0 1 2 9v6h1v-5a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1v5h6V9a.5.5 0 0 1 1 0v6h.5a.5.5 0 0 1 0 1H.5a.5.5 0 0 1 0-1H1V9a.5.5 0 0 1 .5-.5zM4 15h3v-5H4v5zm5-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-3zm3 0h-2v3h2v-3z"/>
                        </svg>
                        <p>Select an item to view details and edit</p>
                    </div>
                }
                else if (isEditing)
                {
                    <div class="details-header">
                        <h2>Edit Item</h2>
                        <div class="header-actions">
                            <button class="btn-delete" @onclick="() => DeleteItemAsync(selectedItem.Id)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z"/>
                                    <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z"/>
                                </svg>
                                Delete
                            </button>
                            <button class="btn-close" @onclick="CancelEdit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <EditForm Model="formItem" OnSubmit="SaveAsync" class="item-form">
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Item Name</label>
                                <InputText class="form-input" @bind-Value="formItem.Name" placeholder="Enter item name" />
                            </div>
                        </div>

                        <div class="form-row two-columns">
                            <div class="form-group">
                                <label class="form-label">Price</label>
                                <InputNumber class="form-input" @bind-Value="formItem.Price" placeholder="0.00" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">TVA Rate</label>
                                <select class="form-select" @bind="formItem.TVA">
                                    <option value="">Select TVA</option>
                                    @foreach (var rate in TvaRates)
                                    {
                                        <option value="@rate">@rate</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Tenant</label>
                                <select class="form-select" @bind="ItemTenantIdStr">
                                    <option value="">Select tenant</option>
                                    @foreach (var tenant in VisibleTenants)
                                    {
                                        <option value="@tenant.Id">@tenant.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="button" class="btn-secondary" @onclick="CancelEdit">Cancel</button>
                            <button type="submit" class="btn-primary" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner spinner-sm"></span>
                                    <span>Saving…</span>
                                }
                                else
                                {
                                    <span>Save Changes</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
                else
                {
                    <div class="details-header">
                        <h2>@selectedItem.Name</h2>
                        <button class="btn-edit" @onclick="StartEdit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                            </svg>
                            Edit
                        </button>
                    </div>

                    <div class="item-details">
                        <div class="detail-section">
                            <h3>Item Information</h3>
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <label>Item ID</label>
                                    <div class="detail-value">
                                        <code>@selectedItem.Id</code>
                                    </div>
                                </div>
                                <div class="detail-item">
                                    <label>Name</label>
                                    <div class="detail-value">@selectedItem.Name</div>
                                </div>
                            </div>
                        </div>

                        <div class="detail-section">
                            <h3>Pricing</h3>
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <label>Price</label>
                                    <div class="detail-value price-value">$@selectedItem.Price.ToString("F2")</div>
                                </div>
                                <div class="detail-item">
                                    <label>TVA Rate</label>
                                    <div class="detail-value">@selectedItem.TVA</div>
                                </div>
                            </div>
                        </div>

                        <div class="detail-section">
                            <h3>Assignment</h3>
                            <div class="detail-grid">
                                <div class="detail-item full-width">
                                    <label>Tenant</label>
                                    <div class="detail-value">@ResolveTenantName(selectedItem.TenantId)</div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private static readonly string[] TvaRates = ["0%", "8%", "12%", "20%"];

    private List<CatalogItemDTO> items = new();
    private CatalogItemDTO? selectedItem = null;
    private CatalogItemDTO formItem = CreateEmptyItem();

    private string searchTerm = string.Empty;
    private string tenantFilterIdStr = string.Empty;
    private bool isLoading;
    private bool isSaving;
    private bool isCreating;
    private bool isEditing;
    private string? pageError;
    private string? formError;

    private Guid? CurrentTenantId => TenantSelectionService.SelectedTenantId;
    private IReadOnlyList<TenantDTO> VisibleTenants => TenantSelectionService.AvailableTenants;

    private Guid? TenantFilterId
    {
        get => Guid.TryParse(tenantFilterIdStr, out var tenantId) ? tenantId : null;
        set => tenantFilterIdStr = value?.ToString() ?? string.Empty;
    }

    private string TenantFilterIdStr
    {
        get => tenantFilterIdStr;
        set => tenantFilterIdStr = value;
    }

    private string ItemTenantIdStr
    {
        get => formItem.TenantId == Guid.Empty ? string.Empty : formItem.TenantId.ToString();
        set => formItem.TenantId = Guid.TryParse(value, out var tenantId) ? tenantId : Guid.Empty;
    }

    private IEnumerable<CatalogItemDTO> VisibleItems => items
        .Where(item => TenantSelectionService.CanAccessTenant(item.TenantId))
        .Where(item => !CurrentTenantId.HasValue || item.TenantId == CurrentTenantId.Value)
        .Where(item => !TenantFilterId.HasValue || item.TenantId == TenantFilterId.Value)
        .Where(item => string.IsNullOrWhiteSpace(searchTerm)
            || (item.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            || item.Price.ToString("F2").Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
            || (item.TVA?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(item => item.Name);

    protected override async Task OnInitializedAsync()
    {
        await TenantSelectionService.EnsureInitializedAsync();
        TenantSelectionService.Changed += OnTenantChanged;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        pageError = null;

        try
        {
            await TenantSelectionService.RefreshAsync();
            items = await ItemService.GetAllAsync();

            // Update selected item if it still exists
            if (selectedItem != null)
            {
                var updated = items.FirstOrDefault(i => i.Id == selectedItem.Id);
                selectedItem = updated;
            }
        }
        catch (Exception ex)
        {
            items = new();
            pageError = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void SelectItem(CatalogItemDTO item)
    {
        selectedItem = item;
        formItem = Clone(item);
        isCreating = false;
        isEditing = false;
        formError = null;
    }

    private void StartCreate()
    {
        formItem = new CatalogItemDTO
        {
            Id = Guid.Empty,
            Name = string.Empty,
            Price = 0,
            TVA = "0%",
            TenantId = CurrentTenantId ?? Guid.Empty
        };

        selectedItem = null;
        formError = null;
        isCreating = true;
        isEditing = false;
    }

    private void CancelCreate()
    {
        isCreating = false;
        formError = null;
        isSaving = false;
        formItem = CreateEmptyItem();
    }

    private void StartEdit()
    {
        if (selectedItem == null) return;

        formItem = Clone(selectedItem);
        isEditing = true;
        isCreating = false;
        formError = null;
    }

    private void CancelEdit()
    {
        if (selectedItem == null) return;

        formItem = Clone(selectedItem);
        isEditing = false;
        formError = null;
        isSaving = false;
    }

    private async Task SaveAsync()
    {
        formError = null;

        if (string.IsNullOrWhiteSpace(formItem.Name))
        {
            formError = "Name is required.";
            return;
        }

        if (formItem.Price < 0)
        {
            formError = "Price must be non-negative.";
            return;
        }

        if (string.IsNullOrWhiteSpace(formItem.TVA))
        {
            formError = "TVA is required.";
            return;
        }

        if (formItem.TenantId == Guid.Empty)
        {
            formError = "Tenant is required.";
            return;
        }

        if (!TenantSelectionService.CanAccessTenant(formItem.TenantId))
        {
            formError = "You can only manage items for your assigned tenants.";
            return;
        }

        isSaving = true;

        try
        {
            if (isCreating)
            {
                var created = await ItemService.CreateAsync(formItem);
                items.Add(created);
                selectedItem = created;
                formItem = Clone(created);
                isCreating = false;
            }
            else if (isEditing)
            {
                var updated = await ItemService.UpdateAsync(formItem.Id, formItem);
                SyncToList(updated);
                selectedItem = updated;
                formItem = Clone(updated);
                isEditing = false;
            }
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteItemAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this item?\n\nThis action cannot be undone."))
        {
            return;
        }

        try
        {
            await ItemService.DeleteAsync(id);
            items.RemoveAll(item => item.Id == id);

            if (selectedItem?.Id == id)
            {
                selectedItem = null;
                isEditing = false;
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private void SyncToList(CatalogItemDTO updated)
    {
        var index = items.FindIndex(item => item.Id == updated.Id);
        if (index >= 0)
        {
            items[index] = updated;
        }
    }

    private string ResolveTenantName(Guid tenantId) =>
        VisibleTenants.FirstOrDefault(tenant => tenant.Id == tenantId)?.Name ?? "—";

    private static CatalogItemDTO Clone(CatalogItemDTO item) => new()
    {
        Id = item.Id,
        Name = item.Name,
        Price = item.Price,
        TVA = item.TVA,
        TenantId = item.TenantId,
        Tenant = item.Tenant
    };

    private static CatalogItemDTO CreateEmptyItem() => new()
    {
        Id = Guid.Empty,
        Name = string.Empty,
        Price = 0,
        TVA = "0%",
        TenantId = Guid.Empty
    };

    private void OnTenantChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadDataAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        TenantSelectionService.Changed -= OnTenantChanged;
    }
}
