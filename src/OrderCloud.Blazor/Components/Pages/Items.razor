@page "/items"
@implements IDisposable
@using OrderCloud.Blazor.Models
@using OrderCloud.Blazor.Services
@inject ICatalogItemService ItemService
@inject ITenantSelectionService TenantSelectionService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Items</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-0">Items</h1>
            <div class="text-muted">@VisibleItems.Count() record@(VisibleItems.Count() == 1 ? "" : "s")</div>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary" @onclick="LoadDataAsync" disabled="@isLoading">Refresh</button>
            <button class="btn btn-primary" @onclick="StartCreate">New Item</button>
        </div>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-md-4">
            <label class="form-label">Tenant</label>
            <select class="form-select" @bind="TenantFilterIdStr">
                <option value="">All tenants</option>
                @foreach (var tenant in VisibleTenants)
                {
                    <option value="@tenant.Id">@tenant.Name</option>
                }
            </select>
        </div>

        <div class="col-md-5">
            <label class="form-label">Search</label>
            <input class="form-control" placeholder="Search by name, price, or TVA..."
                   @bind="searchTerm" @bind:event="oninput" />
        </div>

        <div class="col-md-3 d-flex align-items-end">
            <button class="btn btn-outline-secondary w-100" @onclick="LoadDataAsync" disabled="@isLoading">Refresh</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(pageError))
    {
        <div class="alert alert-danger">@pageError</div>
    }

    @if (isLoading)
    {
        <div class="alert alert-info">Loading items…</div>
    }
    else if (!VisibleItems.Any())
    {
        <div class="alert alert-warning">
            No items found.
        </div>
    }
    else
    {
        <div class="table-responsive mb-4">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Price</th>
                        <th>TVA</th>
                        <th>Tenant</th>
                        <th style="width: 220px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in VisibleItems)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>$@item.Price.ToString("F2")</td>
                            <td>@item.TVA</td>
                            <td>@ResolveTenantName(item.TenantId)</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ViewItem(item)">View</button>
                                <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => StartEdit(item)">Edit</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item.Id)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (showPanel)
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    @if (panelMode == PanelMode.Create)
                    {
                        <strong>New Item</strong>
                    }
                    else if (panelMode == PanelMode.Edit)
                    {
                        <strong>Edit Item</strong>
                    }
                    else
                    {
                        <strong>Item Details</strong>
                    }
                </div>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClosePanel">Close</button>
            </div>

            <div class="card-body">
                @if (panelMode == PanelMode.View)
                {
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Name</dt>
                        <dd class="col-sm-9">@formItem.Name</dd>

                        <dt class="col-sm-3">Price</dt>
                        <dd class="col-sm-9">$@formItem.Price.ToString("F2")</dd>

                        <dt class="col-sm-3">TVA</dt>
                        <dd class="col-sm-9">@formItem.TVA</dd>

                        <dt class="col-sm-3">Tenant</dt>
                        <dd class="col-sm-9">@ResolveTenantName(formItem.TenantId)</dd>

                        <dt class="col-sm-3">Id</dt>
                        <dd class="col-sm-9"><code>@formItem.Id</code></dd>
                    </dl>
                }
                else
                {
                    <EditForm Model="formItem" OnSubmit="SaveAsync">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Name</label>
                                <InputText class="form-control" @bind-Value="formItem.Name" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Price</label>
                                <InputNumber class="form-control" @bind-Value="formItem.Price" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">TVA</label>
                                <select class="form-select" @bind="formItem.TVA">
                                    <option value="">-- Select TVA --</option>
                                    @foreach (var rate in TvaRates)
                                    {
                                        <option value="@rate">@rate</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Tenant</label>
                                <select class="form-select" @bind="ItemTenantIdStr">
                                    <option value="">-- Select tenant --</option>
                                    @foreach (var tenant in VisibleTenants)
                                    {
                                        <option value="@tenant.Id">@tenant.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(formError))
                        {
                            <div class="alert alert-danger mt-3 mb-0">@formError</div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-3">
                            @if (panelMode == PanelMode.Edit)
                            {
                                <button type="button" class="btn btn-danger" @onclick="() => DeleteAsync(formItem.Id)">Delete</button>
                            }
                            <button type="button" class="btn btn-secondary" @onclick="ClosePanel">Cancel</button>
                            <button type="submit" class="btn btn-primary" disabled="@isSaving">
                                @(panelMode == PanelMode.Create ? "Create" : "Save")
                            </button>
                        </div>
                    </EditForm>
                }
            </div>
        </div>
    }
</div>

@code {
    private enum PanelMode { Create, Edit, View }

    private static readonly string[] TvaRates = ["0%", "8%", "12%", "20%"];

    private List<CatalogItemDTO> items = new();

    private string searchTerm = string.Empty;
    private string tenantFilterIdStr = string.Empty;
    private bool isLoading;
    private bool isSaving;
    private bool showPanel;
    private PanelMode panelMode;
    private string? pageError;
    private string? formError;
    private CatalogItemDTO formItem = CreateEmptyItem();

    private Guid? CurrentTenantId => TenantSelectionService.SelectedTenantId;
    private IReadOnlyList<TenantDTO> VisibleTenants => TenantSelectionService.AvailableTenants;

    private Guid? TenantFilterId
    {
        get => Guid.TryParse(tenantFilterIdStr, out var tenantId) ? tenantId : null;
        set => tenantFilterIdStr = value?.ToString() ?? string.Empty;
    }

    private string TenantFilterIdStr
    {
        get => tenantFilterIdStr;
        set => tenantFilterIdStr = value;
    }

    private string ItemTenantIdStr
    {
        get => formItem.TenantId == Guid.Empty ? string.Empty : formItem.TenantId.ToString();
        set => formItem.TenantId = Guid.TryParse(value, out var tenantId) ? tenantId : Guid.Empty;
    }

    private IEnumerable<CatalogItemDTO> VisibleItems => items
        .Where(item => TenantSelectionService.CanAccessTenant(item.TenantId))
        .Where(item => !CurrentTenantId.HasValue || item.TenantId == CurrentTenantId.Value)
        .Where(item => !TenantFilterId.HasValue || item.TenantId == TenantFilterId.Value)
        .Where(item => string.IsNullOrWhiteSpace(searchTerm)
            || (item.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            || item.Price.ToString("F2").Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
            || (item.TVA?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderBy(item => item.Name);

    protected override async Task OnInitializedAsync()
    {
        await TenantSelectionService.EnsureInitializedAsync();
        TenantSelectionService.Changed += OnTenantChanged;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        pageError = null;

        try
        {
            await TenantSelectionService.RefreshAsync();
            items = await ItemService.GetAllAsync();
        }
        catch (Exception ex)
        {
            items = new();
            pageError = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void StartCreate()
    {
        formItem = new CatalogItemDTO
        {
            Id = Guid.Empty,
            Name = string.Empty,
            Price = 0,
            TVA = "0%",
            TenantId = CurrentTenantId ?? Guid.Empty
        };

        formError = null;
        panelMode = PanelMode.Create;
        showPanel = true;
    }

    private void ViewItem(CatalogItemDTO item)
    {
        formItem = Clone(item);
        formError = null;
        panelMode = PanelMode.View;
        showPanel = true;
    }

    private void StartEdit(CatalogItemDTO item)
    {
        formItem = Clone(item);
        formError = null;
        panelMode = PanelMode.Edit;
        showPanel = true;
    }

    private void ClosePanel()
    {
        showPanel = false;
        formError = null;
        isSaving = false;
    }

    private async Task SaveAsync()
    {
        formError = null;

        if (string.IsNullOrWhiteSpace(formItem.Name))
        {
            formError = "Name is required.";
            return;
        }

        if (formItem.Price < 0)
        {
            formError = "Price must be non-negative.";
            return;
        }

        if (string.IsNullOrWhiteSpace(formItem.TVA))
        {
            formError = "TVA is required.";
            return;
        }

        if (formItem.TenantId == Guid.Empty)
        {
            formError = "Tenant is required.";
            return;
        }

        if (!TenantSelectionService.CanAccessTenant(formItem.TenantId))
        {
            formError = "You can only manage items for your assigned tenants.";
            return;
        }

        isSaving = true;

        try
        {
            if (panelMode == PanelMode.Create)
            {
                var created = await ItemService.CreateAsync(formItem);
                items.Add(created);
                formItem = Clone(created);
            }
            else
            {
                var updated = await ItemService.UpdateAsync(formItem.Id, formItem);
                SyncToList(updated);
                formItem = Clone(updated);
            }

            panelMode = PanelMode.View;
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this item? This cannot be undone."))
        {
            return;
        }

        try
        {
            await ItemService.DeleteAsync(id);
            items.RemoveAll(item => item.Id == id);

            if (showPanel && formItem.Id == id)
            {
                ClosePanel();
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private void SyncToList(CatalogItemDTO updated)
    {
        var index = items.FindIndex(item => item.Id == updated.Id);
        if (index >= 0)
        {
            items[index] = updated;
        }
    }

    private string ResolveTenantName(Guid tenantId) =>
        VisibleTenants.FirstOrDefault(tenant => tenant.Id == tenantId)?.Name ?? "—";

    private static CatalogItemDTO Clone(CatalogItemDTO item) => new()
    {
        Id = item.Id,
        Name = item.Name,
        Price = item.Price,
        TVA = item.TVA,
        TenantId = item.TenantId,
        Tenant = item.Tenant
    };

    private static CatalogItemDTO CreateEmptyItem() => new()
    {
        Id = Guid.Empty,
        Name = string.Empty,
        Price = 0,
        TVA = "0%",
        TenantId = Guid.Empty
    };

    private void OnTenantChanged()
    {
        // Reload data when tenant selection changes
        _ = InvokeAsync(async () =>
        {
            await LoadDataAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        TenantSelectionService.Changed -= OnTenantChanged;
    }
}