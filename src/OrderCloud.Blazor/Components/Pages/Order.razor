@page "/orders"
@using OrderCloud.Blazor.Models
@using OrderCloud.Blazor.Services
@inject IOrderService OrderService
@inject ITenantService TenantService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Orders</PageTitle>

<div class="orders-page">

    <div class="page-header">
        <div class="header-left">
            <h1 class="page-title">Orders</h1>
            <span class="count-badge">@orders.Count order@(orders.Count == 1 ? "" : "s")</span>
        </div>
        <button class="btn-create" @onclick="StartCreate">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2z" />
            </svg>
            New Order
        </button>
    </div>

    <div class="toolbar">
        <div class="search-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16" class="search-icon">
                <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.099zm-5.242 1.656a5.5 5.5 0 1 1 0-11 5.5 5.5 0 0 1 0 11z" />
            </svg>
            <input class="search-input" placeholder="Search by ID or status…" @bind="searchTerm" @bind:event="oninput" />
        </div>
        <select class="filter-select" @bind="statusFilter">
            <option value="">All statuses</option>
            @foreach (var s in Statuses)
            {
                <option value="@s">@s</option>
            }
        </select>
        <button class="btn-refresh" @onclick="LoadOrdersAsync" title="Refresh">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z" />
            </svg>
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Loading orders…</span>
        </div>
    }
    else if (!FilteredOrders.Any())
    {
        <div class="empty-state">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16" class="empty-icon">
                <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l1.313 7h8.17l1.313-7zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4M5 13a1 1 0 1 1 0 2 1 1 0 0 1 0-2m7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2" />
            </svg>
            <p>@(string.IsNullOrEmpty(searchTerm) && string.IsNullOrEmpty(statusFilter)
                ? "No orders yet. Create your first one."
                : "No orders match the current filters.")</p>
        </div>
    }
    else
    {
        <div class="orders-grid">
            @foreach (var o in FilteredOrders)
            {
                <div class="order-card" @onclick="() => ViewOrder(o)">
                    <div class="card-accent @StatusCss(o.Status)"></div>
                    <div class="card-body">
                        <div class="card-main">
                            <div class="order-id-label">
                                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16" style="opacity:.5;margin-right:4px;vertical-align:-1px">
                                    <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l1.313 7h8.17l1.313-7z" />
                                </svg>
                                #@o.Id.ToString()[..8]
                            </div>
                            <span class="status-pill @StatusCss(o.Status)">@o.Status</span>
                        </div>
                        <div class="card-stats">
                            <div class="card-stat">
                                <span class="stat-label">Total</span>
                                <span class="stat-val money-val">$@o.Total.ToString("F2")</span>
                            </div>
                            <div class="card-stat">
                                <span class="stat-label">Items</span>
                                <span class="stat-val">@(o.Items?.Count ?? 0)</span>
                            </div>
                            <div class="card-stat">
                                <span class="stat-label">Created</span>
                                <span class="stat-val">@(o.CreatedAt == default ? "—" : o.CreatedAt.ToString("MMM dd, yyyy"))</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-actions" @onclick:stopPropagation="true">
                        <button class="btn-icon btn-view" title="View details" @onclick="() => ViewOrder(o)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                            </svg>
                        </button>
                        <button class="btn-icon btn-edit" title="Edit order" @onclick="() => StartEdit(o)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.499.499 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z" />
                            </svg>
                        </button>
                        <button class="btn-icon btn-delete" title="Delete order" @onclick="() => DeleteAsync(o.Id)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" />
                                <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z" />
                            </svg>
                        </button>
                    </div>
                </div>
            }
        </div>
    }

</div>

@if (showModal)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-panel @(modalMode != ModalMode.Create ? "modal-wide" : "")" @onclick:stopPropagation="true">

            <div class="modal-header">
                <div class="modal-title-group">
                    @if (modalMode != ModalMode.Create)
                    {
                        <span class="status-pill @StatusCss(formOrder.Status)" style="font-size:0.72rem;padding:0.2rem 0.6rem">@formOrder.Status</span>
                    }
                    <h2 class="modal-title">
                        @(modalMode == ModalMode.Create
                            ? "New Order"
                            : modalMode == ModalMode.Edit
                                ? $"Edit  ·  #{formOrder.Id.ToString()[..8]}"
                                : $"Order  ·  #{formOrder.Id.ToString()[..8]}")
                    </h2>
                </div>
                <div class="modal-header-right">
                    @if (modalMode == ModalMode.View)
                    {
                        <button class="btn-inline-edit" @onclick="SwitchToEdit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.499.499 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z" />
                            </svg>
                            Edit
                        </button>
                    }
                    <button class="modal-close" @onclick="CloseModal">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="modal-body">

                @if (modalMode == ModalMode.View)
                {
                    <div class="view-layout">
                        <div class="view-col">
                            <h4 class="section-heading">Order Details</h4>
                            <div class="detail-list">
                                <div class="detail-item">
                                    <span class="detail-key">Status</span>
                                    <span class="status-pill @StatusCss(formOrder.Status)">@formOrder.Status</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-key">Total</span>
                                    <span class="detail-val money-val">$@formOrder.Total.ToString("F2")</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-key">Tenant</span>
                                    <span class="detail-val">@(tenants.FirstOrDefault(t => t.Id == formOrder.TenantId)?.Name ?? "—")</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-key">Created</span>
                                    <span class="detail-val">@(formOrder.CreatedAt == default ? "—" : formOrder.CreatedAt.ToString("MMM dd, yyyy  HH:mm"))</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-key">Updated</span>
                                    <span class="detail-val">@(formOrder.UpdatedAt == default ? "—" : formOrder.UpdatedAt.ToString("MMM dd, yyyy  HH:mm"))</span>
                                </div>
                                <div class="detail-item">
                                    <span class="detail-key">Order ID</span>
                                    <span class="detail-val mono">@formOrder.Id</span>
                                </div>
                            </div>
                        </div>

                        <div class="view-col">
                            <h4 class="section-heading">
                                Items
                                <span class="section-count">@(formOrder.Items?.Count ?? 0)</span>
                            </h4>
                            @if (formOrder.Items?.Any() == true) 
                            {
                                <table class="items-table">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Price</th>
                                            <th>Qty</th>
                                            <th>TVA</th>
                                            <th>Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in formOrder.Items)
                                        {
                                            <tr>
                                                <td>@item.Name</td>
                                                <td>$@item.Price.ToString("F2")</td>
                                                <td>@item.Quantity</td>
                                                <td>@item.TVA</td>
                                                <td class="total-cell">$@item.Total.ToString("F2")</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr class="tfoot-total">
                                            <td colspan="4">Order Total</td>
                                            <td class="total-cell">$@formOrder.Total.ToString("F2")</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            }
                            else
                            {
                                <div class="no-items-msg">No items in this order.</div>
                            }
                        </div>
                    </div>

                    <div class="modal-footer">
                        <button type="button" class="btn-danger-action" @onclick="() => DeleteFromModal(formOrder.Id)">Delete Order</button>
                        <button type="button" class="btn-secondary-action" @onclick="CloseModal">Close</button>
                        <button type="button" class="btn-primary-action" @onclick="SwitchToEdit">Edit Order</button>
                    </div>
                }
                else
                {
                    <EditForm Model="formOrder" OnValidSubmit="HandleSubmitAsync">

                        <div class="form-row">
                            <div class="field-group">
                                <label class="field-label">Status <span class="required">*</span></label>
                                <select class="field-input" @bind="formOrder.Status">
                                    @foreach (var s in Statuses)
                                    {
                                        <option value="@s">@s</option>
                                    }
                                </select>
                            </div>
                            <div class="field-group">
                                <label class="field-label">Tenant <span class="required">*</span></label>
                                <select class="field-input @(formOrder.TenantId == Guid.Empty && submitted ? "input-error" : "")"
                                        @bind="TenantIdStr">
                                    <option value="">— Select a tenant —</option>
                                    @foreach (var t in tenants)
                                    {
                                        <option value="@t.Id">@t.Name</option>
                                    }
                                </select>
                                @if (formOrder.TenantId == Guid.Empty && submitted)
                                {
                                    <span class="field-error">Please select a tenant.</span>
                                }
                            </div>
                        </div>

                        @if (modalMode == ModalMode.Edit)
                        {
                            <div class="section-sep">
                                <span class="section-sep-label">Items</span>
                            </div>

                            @if (formOrder.Items?.Any() == true)
                            {
                                <table class="items-table editable-table">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Price</th>
                                            <th>Qty</th>
                                            <th>TVA</th>
                                            <th>Total</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in formOrder.Items.ToList())
                                        {
                                            <tr>
                                                <td>@item.Name</td>
                                                <td>$@item.Price.ToString("F2")</td>
                                                <td>@item.Quantity</td>
                                                <td>@item.TVA</td>
                                                <td class="total-cell">$@item.Total.ToString("F2")</td>
                                                <td>
                                                    <button type="button" class="btn-rm-item" title="Remove item"
                                                            @onclick="() => RemoveItemAsync(item.Id)">
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16">
                                                            <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z" />
                                                        </svg>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr class="tfoot-total">
                                            <td colspan="4">Order Total</td>
                                            <td class="total-cell">$@formOrder.Total.ToString("F2")</td>
                                            <td></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            }
                            else
                            {
                                <div class="no-items-msg">No items yet — add one below.</div>
                            }

                            <div class="add-item-box">
                                <h5 class="add-item-heading">Add Item</h5>
                                <div class="add-item-row">
                                    <input class="field-input" placeholder="Item name *" @bind="newItem.Name" />
                                    <input type="number" class="field-input" placeholder="Price" @bind="newItem.Price" min="0" step="0.01" />
                                    <input type="number" class="field-input" placeholder="Qty" @bind="newItem.Quantity" min="1" step="1" />
                                    <select class="field-input" @bind="newItem.TVA">
                                        <option value="0%">0%</option>
                                        <option value="8%">8%</option>
                                        <option value="12%">12%</option>
                                        <option value="20%">20%</option>
                                    </select>
                                    <button type="button" class="btn-add-item" @onclick="AddItemAsync">+ Add</button>
                                </div>
                                @if (!string.IsNullOrEmpty(itemError))
                                {
                                    <span class="field-error">@itemError</span>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(formError))
                        {
                            <div class="alert-error">@formError</div>
                        }

                        <div class="modal-footer">
                            @if (modalMode == ModalMode.Edit)
                            {
                                <button type="button" class="btn-danger-action" @onclick="() => DeleteFromModal(formOrder.Id)">Delete</button>
                            }
                            <button type="button" class="btn-secondary-action" @onclick="CloseModal">Cancel</button>
                            <button type="submit" class="btn-primary-action" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner-sm"></span>
                                }
                                @(modalMode == ModalMode.Create ? "Create Order" : "Save Changes")
                            </button>
                        </div>

                    </EditForm>
                }

            </div>
        </div>
    </div>
}

@code {
    private enum ModalMode { Create, View, Edit }

    private List<OrderDTO>  orders  = new();
    private List<TenantDTO> tenants = new();

    private string searchTerm   = string.Empty;
    private string statusFilter = string.Empty;

    private OrderDTO formOrder = new() { Status = "Draft", Items = new() };
    private ItemDTO  newItem   = new() { Quantity = 1, TVA = "0%" };

    private bool   isLoading   = false;
    private bool   isSubmitting = false;
    private string? formError;
    private string? itemError;
    private bool   submitted   = false;
    private bool   showModal   = false;
    private ModalMode modalMode;

    // Safe Guid <-> string bridge for the tenant <select>
    private string TenantIdStr
    {
        get => formOrder.TenantId == Guid.Empty ? "" : formOrder.TenantId.ToString();
        set => formOrder.TenantId = Guid.TryParse(value, out var g) ? g : Guid.Empty;
    }

    private static readonly string[] Statuses =
        ["Draft", "Pending", "Processing", "Completed", "Cancelled"];

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadOrdersAsync(), LoadTenantsAsync());
    }

    private IEnumerable<OrderDTO> FilteredOrders => orders.Where(o =>
        (string.IsNullOrEmpty(searchTerm) ||
         o.Id.ToString().Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
         (o.Status?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)) &&
        (string.IsNullOrEmpty(statusFilter) || o.Status == statusFilter));

    // ── Data Loading ─────────────────────────────────────────────────────────

    private async Task LoadOrdersAsync()
    {
        isLoading = true;
        try   { orders = await OrderService.GetAllAsync(); }
        catch { orders = new(); }
        finally { isLoading = false; StateHasChanged(); }
    }

    private async Task LoadTenantsAsync()
    {
        try   { tenants = await TenantService.GetAllAsync(); }
        catch { tenants = new(); }
    }

    // ── Modal Open Helpers ────────────────────────────────────────────────────

    private void StartCreate()
    {
        formOrder  = new() { Status = "Draft", Items = new() };
        formError  = null;
        submitted  = false;
        modalMode  = ModalMode.Create;
        showModal  = true;
    }

    private void ViewOrder(OrderDTO o)
    {
        formOrder = Clone(o);
        formError = null;
        modalMode = ModalMode.View;
        showModal = true;
    }

    private void StartEdit(OrderDTO o)
    {
        formOrder = Clone(o);
        newItem   = new() { Quantity = 1, TVA = "0%" };
        formError = null;
        itemError = null;
        submitted = false;
        modalMode = ModalMode.Edit;
        showModal = true;
    }

    private void SwitchToEdit()
    {
        newItem   = new() { Quantity = 1, TVA = "0%" };
        formError = null;
        itemError = null;
        submitted = false;
        modalMode = ModalMode.Edit;
    }

    private void CloseModal()
    {
        showModal = false;
        formError = null;
        itemError = null;
        submitted = false;
    }

    // ── Create / Update ───────────────────────────────────────────────────────

    private async Task HandleSubmitAsync()
    {
        submitted = true;
        if (string.IsNullOrWhiteSpace(formOrder.Status))
        {
            formError = "Status is required.";
            return;
        }
        if (formOrder.TenantId == Guid.Empty)
        {
            formError = "Please select a tenant.";
            return;
        }

        isSubmitting = true;
        formError    = null;
        try
        {
            if (modalMode == ModalMode.Create)
            {
                var created  = await OrderService.CreateAsync(formOrder);
                orders.Add(created);
                formOrder = Clone(created);
                // Stay in Edit mode so the user can immediately add items
                newItem   = new() { Quantity = 1, TVA = "0%" };
                modalMode = ModalMode.Edit;
            }
            else
            {
                var updated = await OrderService.UpdateAsync(formOrder.Id, formOrder);
                SyncToList(updated);
                formOrder = Clone(updated);
                modalMode = ModalMode.View;
            }
            submitted = false;
        }
        catch (Exception ex) { formError = ex.Message; }
        finally { isSubmitting = false; StateHasChanged(); }
    }

    // ── Item Management ───────────────────────────────────────────────────────

    private async Task AddItemAsync()
    {
        itemError = null;
        if (string.IsNullOrWhiteSpace(newItem.Name)) { itemError = "Item name is required."; return; }
        if (newItem.Price < 0)                        { itemError = "Price must be non-negative."; return; }
        if (newItem.Quantity <= 0)                    { itemError = "Quantity must be at least 1."; return; }

        try
        {
            var added = await OrderService.AddItemAsync(formOrder.Id, newItem);
            formOrder.Items ??= new();
            formOrder.Items.Add(added);
            formOrder.Total = formOrder.Items.Sum(i => i.Total);
            SyncToList(formOrder);
            newItem = new() { Quantity = 1, TVA = "0%" };
            StateHasChanged();
        }
        catch (Exception ex) { itemError = ex.Message; }
    }

    private async Task RemoveItemAsync(Guid itemId)
    {
        itemError = null;
        try
        {
            await OrderService.DeleteItemAsync(formOrder.Id, itemId);
            formOrder.Items?.RemoveAll(i => i.Id == itemId);
            formOrder.Total = formOrder.Items?.Sum(i => i.Total) ?? 0;
            SyncToList(formOrder);
            StateHasChanged();
        }
        catch (Exception ex) { itemError = ex.Message; }
    }

    // ── Delete ────────────────────────────────────────────────────────────────

    private async Task DeleteAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this order? This cannot be undone.")) return;
        try
        {
            await OrderService.DeleteAsync(id);
            orders.RemoveAll(o => o.Id == id);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private async Task DeleteFromModal(Guid id)
    {
        CloseModal();
        await DeleteAsync(id);
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private void SyncToList(OrderDTO updated)
    {
        var idx = orders.FindIndex(o => o.Id == updated.Id);
        if (idx >= 0) orders[idx] = Clone(updated);
    }

    private static string StatusCss(string? status) => status switch
    {
        "Draft"      => "s-draft",
        "Pending"    => "s-pending",
        "Processing" => "s-processing",
        "Completed"  => "s-completed",
        "Cancelled"  => "s-cancelled",
        _            => "s-draft"
    };

    private static OrderDTO Clone(OrderDTO o) => new()
    {
        Id          = o.Id,
        Status      = o.Status,
        Total       = o.Total,
        CreatedAt   = o.CreatedAt,
        UpdatedAt   = o.UpdatedAt,
        TenantId    = o.TenantId,
        LocalUserId = o.LocalUserId,
        Items = o.Items?.Select(i => new ItemDTO
        {
            Id       = i.Id,
            Name     = i.Name,
            Price    = i.Price,
            Quantity = i.Quantity,
            Total    = i.Total,
            TVA      = i.TVA,
            OrderId  = i.OrderId
        }).ToList() ?? new()
    };
}
