@page "/customers"
@implements IDisposable
@using OrderCloud.Shared.Models
@using OrderCloud.Blazor.Services
@inject ICustomerService CustomerService
@inject ITenantSelectionService TenantSelectionService
@inject IJSRuntime JS
@inject ILogger<Customers> Logger
@rendermode InteractiveServer

<PageTitle>Customers</PageTitle>

<div class="customers-page">
    <div class="page-header">
        <div class="header-left">
            <h1 class="page-title">Customers</h1>
            <span class="count-badge">@FilteredCustomers.Count() customer@(FilteredCustomers.Count() == 1 ? "" : "s")</span>
        </div>
        <div class="header-actions">
            <button class="btn-refresh" @onclick="LoadDataAsync" disabled="@isLoading" title="Refresh customers">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                    <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z" />
                </svg>
                Refresh
            </button>
            <button class="btn-create" @onclick="StartCreate">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                </svg>
                New Customer
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(pageError))
    {
        <div class="alert alert-danger">@pageError</div>
    }

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Loading customers…</span>
        </div>
    }
    else if (!customers.Any())
    {
        <div class="empty-state">
            <p>No customers found. Create your first customer to get started.</p>
        </div>
    }
    else
    {
        <div class="master-detail-container">
            <div class="customers-list-panel">
                <h2 class="panel-title">Customers</h2>

                <div class="search-container">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                    </svg>
                    <input type="text" 
                           class="search-input" 
                           placeholder="Search customers..." 
                           @bind="searchTerm"
                           @bind:event="oninput" />
                    @if (!string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <button class="clear-search" @onclick="() => searchTerm = string.Empty" title="Clear search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                            </svg>
                        </button>
                    }
                </div>

                <div class="customers-list">
                    @if (!FilteredCustomers.Any())
                    {
                        <div class="no-results">No customers match your search</div>
                    }
                    else
                    {
                        @foreach (var customer in FilteredCustomers)
                        {
                            <div class="customer-list-item @(selectedCustomer?.Id == customer.Id ? "selected" : "")" 
                                 @onclick="() => SelectCustomer(customer)">
                                <div class="customer-info">
                                    <div class="customer-name">@customer.Name</div>
                                    @if (!string.IsNullOrWhiteSpace(customer.IDNO))
                                    {
                                        <div class="customer-idno">IDNO: @customer.IDNO</div>
                                    }
                                </div>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                                </svg>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="customer-details-panel">
                @if (isCreating)
                {
                    @* CREATE MODE *@
                    <div class="details-header">
                        <h2>Create New Customer</h2>
                        <button class="btn-close" @onclick="CancelCreate">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                            </svg>
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <EditForm Model="formCustomer" OnSubmit="SaveAsync" class="customer-form">
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Tenant</label>
                                <InputSelect class="form-input" @bind-Value="CustomerTenantIdStr">
                                    <option value="">-- Select Tenant --</option>
                                    @foreach (var tenant in VisibleTenants)
                                    {
                                        <option value="@tenant.Id">@tenant.Name</option>
                                    }
                                </InputSelect>
                                <small class="form-hint">Select the tenant this customer belongs to</small>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Customer Name</label>
                                <InputText class="form-input" @bind-Value="formCustomer.Name" placeholder="Enter customer name" />
                                <small class="form-hint">Full name or company name</small>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">IDNO (Optional)</label>
                                <InputText class="form-input" @bind-Value="formCustomer.IDNO" placeholder="Enter identification number" />
                                <small class="form-hint">Tax ID, VAT number, or personal identification number</small>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="button" class="btn-secondary" @onclick="CancelCreate">Cancel</button>
                            <button type="submit" class="btn-primary" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner spinner-sm"></span>
                                    <span>Creating…</span>
                                }
                                else
                                {
                                    <span>Create Customer</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
                else if (selectedCustomer == null)
                {
                    @* EMPTY STATE *@
                    <div class="empty-selection">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H3Zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"/>
                        </svg>
                        <p>Select a customer to view details and manage</p>
                    </div>
                }
                else if (isEditing)
                {
                    @* EDIT MODE *@
                    <div class="details-header">
                        <h2>Edit Customer</h2>
                        <div class="header-actions">
                            <button class="btn-delete" @onclick="() => DeleteCustomerAsync(selectedCustomer.Id)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z"/>
                                    <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z"/>
                                </svg>
                                Delete
                            </button>
                            <button class="btn-close" @onclick="CancelEdit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <EditForm Model="formCustomer" OnSubmit="SaveAsync" class="customer-form">
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Tenant</label>
                                <InputSelect class="form-input" @bind-Value="CustomerTenantIdStr">
                                    <option value="">-- Select Tenant --</option>
                                    @foreach (var tenant in VisibleTenants)
                                    {
                                        <option value="@tenant.Id">@tenant.Name</option>
                                    }
                                </InputSelect>
                                <small class="form-hint">Select the tenant this customer belongs to</small>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">Customer Name</label>
                                <InputText class="form-input" @bind-Value="formCustomer.Name" placeholder="Enter customer name" />
                                <small class="form-hint">Full name or company name</small>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">IDNO (Optional)</label>
                                <InputText class="form-input" @bind-Value="formCustomer.IDNO" placeholder="Enter identification number" />
                                <small class="form-hint">Tax ID, VAT number, or personal identification number</small>
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="button" class="btn-secondary" @onclick="CancelEdit">Cancel</button>
                            <button type="submit" class="btn-primary" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner spinner-sm"></span>
                                    <span>Saving…</span>
                                }
                                else
                                {
                                    <span>Save Changes</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
                else
                {
                    @* VIEW MODE *@
                    <div class="details-header">
                        <h2>@selectedCustomer.Name</h2>
                        <button class="btn-edit" @onclick="StartEdit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                            </svg>
                            Edit
                        </button>
                    </div>

                    <div class="customer-details">
                        <div class="detail-section">
                            <h3>Customer Information</h3>
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <label>Customer ID</label>
                                    <div class="detail-value">
                                        <code>@selectedCustomer.Id</code>
                                    </div>
                                </div>
                                <div class="detail-item">
                                    <label>Name</label>
                                    <div class="detail-value">@selectedCustomer.Name</div>
                                </div>
                                @if (selectedCustomer.Tenant != null)
                                {
                                    <div class="detail-item">
                                        <label>Tenant</label>
                                        <div class="detail-value">@selectedCustomer.Tenant.Name</div>
                                    </div>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(selectedCustomer.IDNO))
                        {
                            <div class="detail-section">
                                <h3>Identification</h3>
                                <div class="detail-grid">
                                    <div class="detail-item">
                                        <label>IDNO</label>
                                        <div class="detail-value">
                                            <code class="idno-code">@selectedCustomer.IDNO</code>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="info-box">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16zm.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
                            </svg>
                            <span>Customer record created. Use this information for orders and invoicing.</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private readonly List<CustomerDTO> customers = new();
    private CustomerDTO? selectedCustomer = null;
    private CustomerDTO formCustomer = CreateEmptyCustomer();

    private string searchTerm = string.Empty;
    private bool isLoading;
    private bool isSaving;
    private bool isCreating;
    private bool isEditing;
    private string? pageError;
    private string? formError;

    private Guid? CurrentTenantId => TenantSelectionService.SelectedTenantId;
    private IReadOnlyList<TenantDTO> VisibleTenants => TenantSelectionService.AvailableTenants;

    private string CustomerTenantIdStr
    {
        get => formCustomer.TenantId == Guid.Empty ? string.Empty : formCustomer.TenantId.ToString();
        set => formCustomer.TenantId = Guid.TryParse(value, out var tenantId) ? tenantId : Guid.Empty;
    }

    private IEnumerable<CustomerDTO> FilteredCustomers => customers
        .Where(customer => TenantSelectionService.CanAccessTenant(customer.TenantId))
        .Where(customer => !CurrentTenantId.HasValue || customer.TenantId == CurrentTenantId.Value)
        .Where(customer => string.IsNullOrWhiteSpace(searchTerm)
            || (customer.Name?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            || (customer.IDNO?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            || customer.Id.ToString().Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
        .OrderBy(customer => customer.Name);

    protected override async Task OnInitializedAsync()
    {
        await TenantSelectionService.EnsureInitializedAsync();
        TenantSelectionService.Changed += OnTenantChanged;
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        pageError = null;
        StateHasChanged();

        try
        {
            await TenantSelectionService.RefreshAsync();
            customers.Clear();
            customers.AddRange(await CustomerService.GetAllAsync());
            Logger.LogInformation("Loaded {Count} customers", customers.Count);

            // Update selected customer if it still exists
            if (selectedCustomer != null)
            {
                var updated = customers.FirstOrDefault(c => c.Id == selectedCustomer.Id);
                selectedCustomer = updated;
            }
        }
        catch (Exception ex)
        {
            customers.Clear();
            pageError = $"Failed to load customers: {ex.Message}";
            Logger.LogError(ex, "Error loading customers");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void SelectCustomer(CustomerDTO customer)
    {
        selectedCustomer = customer;
        formCustomer = Clone(customer);
        isCreating = false;
        isEditing = false;
        formError = null;
    }

    private void StartCreate()
    {
        formCustomer = CreateEmptyCustomer();
        if (CurrentTenantId.HasValue)
        {
            formCustomer.TenantId = CurrentTenantId.Value;
        }
        selectedCustomer = null;
        formError = null;
        isCreating = true;
        isEditing = false;
    }

    private void CancelCreate()
    {
        isCreating = false;
        formError = null;
        isSaving = false;
        formCustomer = CreateEmptyCustomer();
    }

    private void StartEdit()
    {
        if (selectedCustomer == null) return;

        formCustomer = Clone(selectedCustomer);
        isEditing = true;
        isCreating = false;
        formError = null;
    }

    private void CancelEdit()
    {
        if (selectedCustomer == null) return;

        formCustomer = Clone(selectedCustomer);
        isEditing = false;
        formError = null;
        isSaving = false;
    }

    private async Task SaveAsync()
    {
        formError = null;

        if (string.IsNullOrWhiteSpace(formCustomer.Name))
        {
            formError = "Name is required.";
            return;
        }

        if (formCustomer.TenantId == Guid.Empty)
        {
            formError = "Tenant is required.";
            return;
        }

        isSaving = true;

        try
        {
            if (isCreating)
            {
                var created = await CustomerService.CreateAsync(formCustomer);
                customers.Add(created);
                selectedCustomer = created;
                formCustomer = Clone(created);
                isCreating = false;
            }
            else if (isEditing)
            {
                var updated = await CustomerService.UpdateAsync(formCustomer.Id, formCustomer);
                SyncToList(updated);
                selectedCustomer = updated;
                formCustomer = Clone(updated);
                isEditing = false;
            }
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task DeleteCustomerAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this customer?\n\nThis action cannot be undone."))
        {
            return;
        }

        try
        {
            await CustomerService.DeleteAsync(id);
            customers.RemoveAll(customer => customer.Id == id);

            if (selectedCustomer?.Id == id)
            {
                selectedCustomer = null;
                isEditing = false;
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private void SyncToList(CustomerDTO updated)
    {
        var index = customers.FindIndex(customer => customer.Id == updated.Id);
        if (index >= 0)
        {
            customers[index] = updated;
        }
    }

    private static CustomerDTO Clone(CustomerDTO customer) => new()
    {
        Id = customer.Id,
        Name = customer.Name,
        IDNO = customer.IDNO,
        TenantId = customer.TenantId
    };

    private static CustomerDTO CreateEmptyCustomer() => new()
    {
        Id = Guid.Empty,
        Name = string.Empty,
        IDNO = string.Empty,
        TenantId = Guid.Empty
    };

    private void OnTenantChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadDataAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        TenantSelectionService.Changed -= OnTenantChanged;
    }
}
