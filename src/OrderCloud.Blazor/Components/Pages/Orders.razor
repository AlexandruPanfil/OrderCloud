@page "/orders"
@implements IDisposable
@using OrderCloud.Blazor.Models
@using OrderCloud.Blazor.Services
@inject IOrderService OrderService
@inject ITenantSelectionService TenantSelectionService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Orders</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-0">Orders</h1>
            <div class="text-muted">@FilteredOrders.Count() order@(FilteredOrders.Count() == 1 ? "" : "s")</div>
        </div>
        <button class="btn btn-primary" @onclick="StartCreate">New Order</button>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-md-6">
            <input class="form-control" placeholder="Search by ID or status..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <div class="col-md-3">
            <select class="form-select" @bind="statusFilter">
                <option value="">All statuses</option>
                @foreach (var status in Statuses)
                {
                    <option value="@status">@status</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <button class="btn btn-outline-secondary w-100" @onclick="LoadOrdersAsync" disabled="@isLoading">Refresh</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(formError) && !showPanel)
    {
        <div class="alert alert-danger">@formError</div>
    }

    @if (showPanel)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>@(panelMode == PanelMode.Create ? "Create Order" : panelMode == PanelMode.Edit ? "Edit Order" : "View Order")</strong>
                <div class="d-flex gap-2">
                    @if (panelMode == PanelMode.View)
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="SwitchToEdit">Edit</button>
                    }
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ClosePanel">Close</button>
                </div>
            </div>
            <div class="card-body">
                @if (panelMode == PanelMode.View)
                {
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">@formOrder.Status</dd>
                        <dt class="col-sm-3">Tenant</dt>
                        <dd class="col-sm-9">@ResolveTenantName(formOrder.TenantId)</dd>
                        <dt class="col-sm-3">Total</dt>
                        <dd class="col-sm-9">$@formOrder.Total.ToString("F2")</dd>
                        <dt class="col-sm-3">Created</dt>
                        <dd class="col-sm-9">@(formOrder.CreatedAt == default ? "—" : formOrder.CreatedAt.ToString("MMM dd, yyyy HH:mm"))</dd>
                    </dl>
                }
                else
                {
                    <EditForm Model="formOrder" OnSubmit="HandleSubmitAsync">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Status</label>
                                <select class="form-select" @bind="formOrder.Status">
                                    @foreach (var status in Statuses)
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tenant</label>
                                <select class="form-select" @bind="TenantIdStr">
                                    <option value="">-- Select tenant --</option>
                                    @foreach (var tenant in tenants)
                                    {
                                        <option value="@tenant.Id">@tenant.Name</option>
                                    }
                                </select>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(formError))
                        {
                            <div class="alert alert-danger mt-3 mb-0">@formError</div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-3">
                            @if (panelMode == PanelMode.Edit)
                            {
                                <button type="button" class="btn btn-danger" @onclick="() => DeleteFromPanel(formOrder.Id)">Delete</button>
                            }
                            <button type="button" class="btn btn-secondary" @onclick="ClosePanel">Cancel</button>
                            <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                @(panelMode == PanelMode.Create ? "Create" : "Save")
                            </button>
                        </div>
                    </EditForm>
                }
            </div>
        </div>
    }

    <div class="card">
        <div class="card-header">All Orders</div>
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Status</th>
                        <th>Tenant</th>
                        <th>Total</th>
                        <th>Created</th>
                        <th style="width: 220px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredOrders.Any())
                    {
                        @foreach (var order in FilteredOrders)
                        {
                            <tr>
                                <td><code>@order.Id.ToString()[..8]</code></td>
                                <td>@order.Status</td>
                                <td>@ResolveTenantName(order.TenantId)</td>
                                <td>$@order.Total.ToString("F2")</td>
                                <td>@(order.CreatedAt == default ? "—" : order.CreatedAt.ToString("MMM dd, yyyy"))</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ViewOrder(order)">View</button>
                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => StartEdit(order)">Edit</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(order.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No orders found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private enum PanelMode { Create, Edit, View }

    private static readonly string[] Statuses = ["Draft", "Pending", "Processing", "Completed", "Cancelled"];

    private readonly List<OrderDTO> orders = new();
    private List<TenantDTO> tenants = new();
    private string searchTerm = string.Empty;
    private string statusFilter = string.Empty;
    private bool isLoading;
    private bool isSubmitting;
    private bool showPanel;
    private string? formError;
    private PanelMode panelMode;
    private OrderDTO formOrder = CreateEmptyOrder();

    private string TenantIdStr
    {
        get => formOrder.TenantId == Guid.Empty ? string.Empty : formOrder.TenantId.ToString();
        set => formOrder.TenantId = Guid.TryParse(value, out var tenantId) ? tenantId : Guid.Empty;
    }

    private Guid? CurrentTenantId => TenantSelectionService.SelectedTenantId;

    private IEnumerable<OrderDTO> FilteredOrders => orders
        .Where(order => TenantSelectionService.CanAccessTenant(order.TenantId))
        .Where(order => !CurrentTenantId.HasValue || order.TenantId == CurrentTenantId.Value)
        .Where(order => string.IsNullOrWhiteSpace(searchTerm)
            || order.Id.ToString().Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
            || (order.Status?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(order => string.IsNullOrWhiteSpace(statusFilter) || order.Status == statusFilter)
        .OrderByDescending(order => order.CreatedAt);

    protected override async Task OnInitializedAsync()
    {
        await TenantSelectionService.EnsureInitializedAsync();
        TenantSelectionService.Changed += OnTenantChanged;
        await LoadOrdersAsync();
        LoadTenants();
    }

    private void OnTenantChanged()
    {
        LoadTenants();
        if (showPanel && panelMode == PanelMode.Create)
        {
            formOrder.TenantId = CurrentTenantId ?? Guid.Empty;
        }

        _ = InvokeAsync(StateHasChanged);
    }

    private async Task LoadOrdersAsync()
    {
        isLoading = true;
        formError = null;

        try
        {
            await TenantSelectionService.RefreshAsync();
            LoadTenants();

            var loadedOrders = await OrderService.GetAllAsync();
            orders.Clear();
            orders.AddRange(loadedOrders);
        }
        catch (Exception ex)
        {
            orders.Clear();
            formError = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void LoadTenants()
    {
        tenants = TenantSelectionService.AvailableTenants.OrderBy(tenant => tenant.Name).ToList();
    }

    private void StartCreate()
    {
        formOrder = CreateEmptyOrder(CurrentTenantId);
        formError = null;
        panelMode = PanelMode.Create;
        showPanel = true;
    }

    private void ViewOrder(OrderDTO order)
    {
        formOrder = Clone(order);
        formError = null;
        panelMode = PanelMode.View;
        showPanel = true;
    }

    private void StartEdit(OrderDTO order)
    {
        formOrder = Clone(order);
        formError = null;
        panelMode = PanelMode.Edit;
        showPanel = true;
    }

    private void SwitchToEdit()
    {
        panelMode = PanelMode.Edit;
        formError = null;
    }

    private void ClosePanel()
    {
        showPanel = false;
        formError = null;
        isSubmitting = false;
    }

    private async Task HandleSubmitAsync()
    {
        formError = null;

        if (string.IsNullOrWhiteSpace(formOrder.Status))
        {
            formError = "Status is required.";
            return;
        }

        if (formOrder.TenantId == Guid.Empty)
        {
            formError = "Tenant is required.";
            return;
        }

        if (!TenantSelectionService.CanAccessTenant(formOrder.TenantId))
        {
            formError = "You can only manage orders for your assigned tenant.";
            return;
        }

        formOrder.Tenant = tenants.FirstOrDefault(tenant => tenant.Id == formOrder.TenantId);
        if (formOrder.Tenant == null)
        {
            formError = "Selected tenant is not available.";
            return;
        }

        isSubmitting = true;

        try
        {
            if (panelMode == PanelMode.Create)
            {
                var created = await OrderService.CreateAsync(formOrder);
                orders.Add(created);
                formOrder = Clone(created);
            }
            else
            {
                var updated = await OrderService.UpdateAsync(formOrder.Id, formOrder);
                SyncToList(updated);
                formOrder = Clone(updated);
            }

            panelMode = PanelMode.View;
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task DeleteAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this order? This cannot be undone."))
        {
            return;
        }

        try
        {
            await OrderService.DeleteAsync(id);
            orders.RemoveAll(order => order.Id == id);

            if (showPanel && formOrder.Id == id)
            {
                ClosePanel();
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private async Task DeleteFromPanel(Guid id)
    {
        ClosePanel();
        await DeleteAsync(id);
    }

    private void SyncToList(OrderDTO updated)
    {
        var index = orders.FindIndex(order => order.Id == updated.Id);
        if (index >= 0)
        {
            orders[index] = updated;
        }
    }

    private string ResolveTenantName(Guid tenantId) =>
        tenants.FirstOrDefault(tenant => tenant.Id == tenantId)?.Name ?? "—";

    private static OrderDTO Clone(OrderDTO order) => new()
    {
        Id = order.Id,
        Status = order.Status,
        Total = order.Total,
        CreatedAt = order.CreatedAt,
        UpdatedAt = order.UpdatedAt,
        TenantId = order.TenantId,
        LocalUserId = order.LocalUserId,
        CustomerId = order.CustomerId,
        Tenant = order.Tenant,
        LocalUser = order.LocalUser,
        Customer = order.Customer,
        Items = order.Items?.Select(item => new ItemDTO
        {
            Id = item.Id,
            Name = item.Name,
            Price = item.Price,
            Quantity = item.Quantity,
            Total = item.Total,
            TVA = item.TVA,
            OrderId = item.OrderId
        }).ToList() ?? new()
    };

    private static OrderDTO CreateEmptyOrder(Guid? tenantId = null) => new()
    {
        Status = "Draft",
        TenantId = tenantId ?? Guid.Empty,
        Items = new()
    };

    public void Dispose()
    {
        TenantSelectionService.Changed -= OnTenantChanged;
    }
}
