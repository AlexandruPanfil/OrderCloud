@page "/orders"
@implements IDisposable
@using OrderCloud.Shared.Models
@using OrderCloud.Blazor.Services
@inject IOrderService OrderService
@inject ILocalUserService LocalUserService
@inject ITenantSelectionService TenantSelectionService
@inject ICustomerService CustomerService
@inject ICatalogItemService CatalogItemService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Orders</PageTitle>

<div class="orders-page">
    <div class="page-header">
        <div class="header-left">
            <h1 class="page-title">Orders</h1>
            <span class="count-badge">@FilteredOrders.Count() order@(FilteredOrders.Count() == 1 ? "" : "s")</span>
        </div>
        <div class="header-actions">
            <button class="btn-refresh" @onclick="LoadOrdersAsync" disabled="@isLoading" title="Refresh orders">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                    <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466z" />
                </svg>
                Refresh
            </button>
            <button class="btn-create" @onclick="StartCreate">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                </svg>
                New Order
            </button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(formError) && !isCreating && !isEditing && selectedOrder == null)
    {
        <div class="alert alert-danger">@formError</div>
    }

    @if (isLoading)
    {
        <div class="loading-state">
            <div class="spinner"></div>
            <span>Loading orders…</span>
        </div>
    }
    else if (!orders.Any())
    {
        <div class="empty-state">
            <p>No orders found. Create your first order to get started.</p>
        </div>
    }
    else
    {
        <div class="master-detail-container">
            <div class="orders-list-panel">
                <h2 class="panel-title">Orders</h2>

                <div class="filters-container">
                    <div class="filter-group">
                        <label class="filter-label">Status</label>
                        <select class="filter-select" @bind="statusFilter">
                            <option value="">All Statuses</option>
                            @foreach (var status in Statuses)
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="search-container">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                    </svg>
                    <input type="text" 
                           class="search-input" 
                           placeholder="Search orders..." 
                           @bind="searchTerm"
                           @bind:event="oninput" />
                    @if (!string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <button class="clear-search" @onclick="() => searchTerm = string.Empty" title="Clear search">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                            </svg>
                        </button>
                    }
                </div>

                <div class="orders-list">
                    @if (!FilteredOrders.Any())
                    {
                        <div class="no-results">No orders match your search or filter</div>
                    }
                    else
                    {
                        @foreach (var order in FilteredOrders)
                        {
                            <div class="order-list-item @(selectedOrder?.Id == order.Id ? "selected" : "")" 
                                 @onclick="() => SelectOrder(order)">
                                <div class="order-info">
                                    <div class="order-header">
                                        <span class="order-id">#@order.Id.ToString()[..8]</span>
                                        <span class="status-badge status-@order.Status?.ToLower()">@order.Status</span>
                                    </div>
                                    <div class="order-meta">
                                        <span class="order-total">$@order.Total.ToString("F2")</span>
                                        <span class="order-separator">•</span>
                                        <span class="order-items">@order.Items?.Count ?? 0 item@((order.Items?.Count ?? 0) == 1 ? "" : "s")</span>
                                    </div>
                                    <div class="order-tenant">@ResolveTenantName(order.TenantId)</div>
                                </div>
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                                </svg>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="order-details-panel">
                @if (isCreating)
                {
                    @* CREATE MODE *@
                    <div class="details-header">
                        <h2>Create New Order</h2>
                        <button class="btn-close" @onclick="CancelCreate">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                            </svg>
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <EditForm Model="formOrder" OnSubmit="HandleSubmitAsync" class="order-form">
                        <div class="form-section">
                            <h3>Order Information</h3>
                            <div class="form-row two-columns">
                                <div class="form-group">
                                    <label class="form-label">Status</label>
                                    <select class="form-select" @bind="formOrder.Status">
                                        @foreach (var status in Statuses)
                                        {
                                            <option value="@status">@status</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Tenant</label>
                                    <select class="form-select" @bind="TenantIdStr">
                                        <option value="">Select tenant</option>
                                        @foreach (var tenant in tenants)
                                        {
                                            <option value="@tenant.Id">@tenant.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="form-row two-columns">
                                <div class="form-group">
                                    <label class="form-label">Local User</label>
                                    <select class="form-select" @bind="LocalUserIdStr" disabled="@(formOrder.TenantId == Guid.Empty)">
                                        <option value="">Select local user</option>
                                        @foreach (var localUser in AvailableLocalUsers)
                                        {
                                            <option value="@localUser.Id">@localUser.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3>Customer (Optional)</h3>
                            <div class="form-row two-columns">
                                <div class="form-group">
                                    <label class="form-label">Select Customer</label>
                                    <select class="form-select" @bind="SelectedCustomerIdStr">
                                        <option value="">-- No Customer / New Customer --</option>
                                        @foreach (var customer in AvailableCustomers)
                                        {
                                            <option value="@customer.Id">@customer.Name @(!string.IsNullOrWhiteSpace(customer.IDNO) ? $"({customer.IDNO})" : "")</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            @if (string.IsNullOrEmpty(SelectedCustomerIdStr))
                            {
                                <div class="form-row two-columns">
                                    <div class="form-group">
                                        <label class="form-label">New Customer Name</label>
                                        <InputText class="form-input" @bind-Value="formCustomerName" placeholder="Enter new customer name" />
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">New Customer IDNO</label>
                                        <InputText class="form-input" @bind-Value="formCustomerIdNo" placeholder="Enter IDNO (optional)" />
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="form-section">
                            <div class="section-header-with-action">
                                <h3>Order Items</h3>
                                <div style="display: flex; gap: 8px;">
                                    <select class="form-select" style="width: 250px;" @bind="SelectedCatalogItemIdStr">
                                        <option value="">-- Select item from catalog --</option>
                                        @foreach (var catalogItem in AvailableCatalogItems)
                                        {
                                            <option value="@catalogItem.Id">@catalogItem.Name - $@catalogItem.Price.ToString("F2")</option>
                                        }
                                    </select>
                                    <button type="button" class="btn-add-item" @onclick="AddSelectedCatalogItem" disabled="@string.IsNullOrEmpty(SelectedCatalogItemIdStr)">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                                        </svg>
                                        Add from Catalog
                                    </button>
                                    <button type="button" class="btn-add-item" @onclick="AddItem">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                                        </svg>
                                        Add Custom Item
                                    </button>
                                </div>
                            </div>

                            @if (!formOrder.Items.Any())
                            {
                                <div class="empty-items">No items added yet</div>
                            }
                            else
                            {
                                <div class="items-table">
                                    @foreach (var item in formOrder.Items)
                                    {
                                        <div class="item-row">
                                            <div class="item-field item-name">
                                                <label>Name</label>
                                                <InputText class="form-input" @bind-Value="item.Name" required />
                                            </div>
                                            <div class="item-field item-price">
                                                <label>Price</label>
                                                <InputNumber class="form-input" @bind-Value="item.Price" @bind-Value:after="RecalculateTotal" />
                                            </div>
                                            <div class="item-field item-qty">
                                                <label>Qty</label>
                                                <InputNumber class="form-input" @bind-Value="item.Quantity" @bind-Value:after="RecalculateTotal" />
                                            </div>
                                            <div class="item-field item-tva">
                                                <label>TVA</label>
                                                <select class="form-select" @bind="item.TVA">
                                                    <option value="0%">0%</option>
                                                    <option value="8%">8%</option>
                                                    <option value="12%">12%</option>
                                                    <option value="20%">20%</option>
                                                </select>
                                            </div>
                                            <div class="item-field item-total">
                                                <label>Total</label>
                                                <div class="total-value">$@((item.Price * item.Quantity).ToString("F2"))</div>
                                            </div>
                                            <button type="button" class="btn-remove-item" @onclick="() => RemoveItem(item)" title="Remove item">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                                                </svg>
                                            </button>
                                        </div>
                                    }
                                </div>
                                <div class="order-total-display">
                                    <span>Order Total:</span>
                                    <span class="total-amount">$@formOrder.Total.ToString("F2")</span>
                                </div>
                            }
                        </div>

                        <div class="form-actions">
                            <button type="button" class="btn-secondary" @onclick="CancelCreate">Cancel</button>
                            <button type="submit" class="btn-primary" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner spinner-sm"></span>
                                    <span>Creating…</span>
                                }
                                else
                                {
                                    <span>Create Order</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
                else if (selectedOrder == null)
                {
                    @* EMPTY STATE *@
                    <div class="empty-selection">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                        </svg>
                        <p>Select an order to view details and manage</p>
                    </div>
                }
                else if (isEditing)
                {
                    @* EDIT MODE *@
                    <div class="details-header">
                        <h2>Edit Order</h2>
                        <div class="header-actions">
                            <button class="btn-delete" @onclick="() => DeleteOrderAsync(selectedOrder.Id)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5Zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6Z"/>
                                    <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1ZM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118ZM2.5 3h11V2h-11v1Z"/>
                                </svg>
                                Delete
                            </button>
                            <button class="btn-close" @onclick="CancelEdit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }

                    <EditForm Model="formOrder" OnSubmit="HandleSubmitAsync" class="order-form">
                        <div class="form-section">
                            <h3>Order Information</h3>
                            <div class="form-row two-columns">
                                <div class="form-group">
                                    <label class="form-label">Status</label>
                                    <select class="form-select" @bind="formOrder.Status">
                                        @foreach (var status in Statuses)
                                        {
                                            <option value="@status">@status</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Tenant</label>
                                    <select class="form-select" @bind="TenantIdStr">
                                        <option value="">Select tenant</option>
                                        @foreach (var tenant in tenants)
                                        {
                                            <option value="@tenant.Id">@tenant.Name</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="form-row two-columns">
                                <div class="form-group">
                                    <label class="form-label">Local User</label>
                                    <select class="form-select" @bind="LocalUserIdStr" disabled="@(formOrder.TenantId == Guid.Empty)">
                                        <option value="">Select local user</option>
                                        @foreach (var localUser in AvailableLocalUsers)
                                        {
                                            <option value="@localUser.Id">@localUser.Name</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Created At</label>
                                    <div class="form-value">@(formOrder.CreatedAt == default ? "—" : formOrder.CreatedAt.ToString("MMM dd, yyyy HH:mm"))</div>
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <h3>Customer (Optional)</h3>
                            <div class="form-row two-columns">
                                <div class="form-group">
                                    <label class="form-label">Customer Name</label>
                                    <InputText class="form-input" @bind-Value="formCustomerName" placeholder="Optional" />
                                </div>
                                <div class="form-group">
                                    <label class="form-label">Customer IDNO</label>
                                    <InputText class="form-input" @bind-Value="formCustomerIdNo" placeholder="Optional" />
                                </div>
                            </div>
                        </div>

                        <div class="form-section">
                            <div class="section-header-with-action">
                                <h3>Order Items</h3>
                                <button type="button" class="btn-add-item" @onclick="AddItem">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                        <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4z"/>
                                    </svg>
                                    Add Item
                                </button>
                            </div>

                            @if (!formOrder.Items.Any())
                            {
                                <div class="empty-items">No items added yet</div>
                            }
                            else
                            {
                                <div class="items-table">
                                    @foreach (var item in formOrder.Items)
                                    {
                                        <div class="item-row">
                                            <div class="item-field item-name">
                                                <label>Name</label>
                                                <InputText class="form-input" @bind-Value="item.Name" required />
                                            </div>
                                            <div class="item-field item-price">
                                                <label>Price</label>
                                                <InputNumber class="form-input" @bind-Value="item.Price" @bind-Value:after="RecalculateTotal" />
                                            </div>
                                            <div class="item-field item-qty">
                                                <label>Qty</label>
                                                <InputNumber class="form-input" @bind-Value="item.Quantity" @bind-Value:after="RecalculateTotal" />
                                            </div>
                                            <div class="item-field item-tva">
                                                <label>TVA</label>
                                                <select class="form-select" @bind="item.TVA">
                                                    <option value="0%">0%</option>
                                                    <option value="8%">8%</option>
                                                    <option value="12%">12%</option>
                                                    <option value="20%">20%</option>
                                                </select>
                                            </div>
                                            <div class="item-field item-total">
                                                <label>Total</label>
                                                <div class="total-value">$@((item.Price * item.Quantity).ToString("F2"))</div>
                                            </div>
                                            <button type="button" class="btn-remove-item" @onclick="() => RemoveItem(item)" title="Remove item">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                                    <path d="M2.146 2.854a.5.5 0 1 1 .708-.708L8 7.293l5.146-5.147a.5.5 0 0 1 .708.708L8.707 8l5.147 5.146a.5.5 0 0 1-.708.708L8 8.707l-5.146 5.147a.5.5 0 0 1-.708-.708L7.293 8 2.146 2.854Z"/>
                                                </svg>
                                            </button>
                                        </div>
                                    }
                                </div>
                                <div class="order-total-display">
                                    <span>Order Total:</span>
                                    <span class="total-amount">$@formOrder.Total.ToString("F2")</span>
                                </div>
                            }
                        </div>

                        <div class="form-actions">
                            <button type="button" class="btn-secondary" @onclick="CancelEdit">Cancel</button>
                            <button type="submit" class="btn-primary" disabled="@isSubmitting">
                                @if (isSubmitting)
                                {
                                    <span class="spinner spinner-sm"></span>
                                    <span>Saving…</span>
                                }
                                else
                                {
                                    <span>Save Changes</span>
                                }
                            </button>
                        </div>
                    </EditForm>
                }
                else
                {
                    @* VIEW MODE *@
                    <div class="details-header">
                        <h2>Order #@selectedOrder.Id.ToString()[..8]</h2>
                        @if (selectedOrder.Status != "Completed")
                        {
                            <button class="btn-edit" @onclick="StartEdit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M12.146.146a.5.5 0 0 1 .708 0l3 3a.5.5 0 0 1 0 .708l-10 10a.5.5 0 0 1-.168.11l-5 2a.5.5 0 0 1-.65-.65l2-5a.5.5 0 0 1 .11-.168l10-10zM11.207 2.5 13.5 4.793 14.793 3.5 12.5 1.207 11.207 2.5zm1.586 3L10.5 3.207 4 9.707V10h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.293l6.5-6.5zm-9.761 5.175-.106.106-1.528 3.821 3.821-1.528.106-.106A.5.5 0 0 1 5 12.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.468-.325z"/>
                                </svg>
                                Edit
                            </button>
                        }
                    </div>

                    <div class="order-details">
                        <div class="detail-section">
                            <h3>Order Information</h3>
                            <div class="detail-grid">
                                <div class="detail-item">
                                    <label>Order ID</label>
                                    <div class="detail-value"><code>@selectedOrder.Id</code></div>
                                </div>
                                <div class="detail-item">
                                    <label>Status</label>
                                    <div class="detail-value">
                                        <span class="status-badge status-@selectedOrder.Status?.ToLower()">@selectedOrder.Status</span>
                                    </div>
                                </div>
                                <div class="detail-item">
                                    <label>Tenant</label>
                                    <div class="detail-value">@ResolveTenantName(selectedOrder.TenantId)</div>
                                </div>
                                <div class="detail-item">
                                    <label>Local User</label>
                                    <div class="detail-value">@(selectedOrder.LocalUser?.Name ?? "—")</div>
                                </div>
                                <div class="detail-item">
                                    <label>Created At</label>
                                    <div class="detail-value">@(selectedOrder.CreatedAt == default ? "—" : selectedOrder.CreatedAt.ToString("MMM dd, yyyy HH:mm"))</div>
                                </div>
                                <div class="detail-item">
                                    <label>Total Amount</label>
                                    <div class="detail-value price-value">$@selectedOrder.Total.ToString("F2")</div>
                                </div>
                            </div>
                        </div>

                        @if (selectedOrder.Customer != null && !string.IsNullOrWhiteSpace(selectedOrder.Customer.Name))
                        {
                            <div class="detail-section">
                                <h3>Customer Information</h3>
                                <div class="detail-grid">
                                    <div class="detail-item">
                                        <label>Customer Name</label>
                                        <div class="detail-value">@selectedOrder.Customer.Name</div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(selectedOrder.Customer.IDNO))
                                    {
                                        <div class="detail-item">
                                            <label>Customer IDNO</label>
                                            <div class="detail-value">@selectedOrder.Customer.IDNO</div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <div class="detail-section">
                            <h3>Order Items</h3>
                            @if (!selectedOrder.Items?.Any() ?? true)
                            {
                                <div class="empty-items">No items in this order</div>
                            }
                            else
                            {
                                <div class="items-detail-table">
                                    <div class="items-detail-header">
                                        <span>Name</span>
                                        <span>Price</span>
                                        <span>Qty</span>
                                        <span>TVA</span>
                                        <span>Total</span>
                                    </div>
                                    @foreach (var item in selectedOrder.Items)
                                    {
                                        <div class="items-detail-row">
                                            <span class="item-name">@item.Name</span>
                                            <span>$@item.Price.ToString("F2")</span>
                                            <span>@item.Quantity</span>
                                            <span>@item.TVA</span>
                                            <span class="item-total">$@((item.Price * item.Quantity).ToString("F2"))</span>
                                        </div>
                                    }
                                    <div class="items-detail-footer">
                                        <span>Order Total:</span>
                                        <span class="total-amount">$@selectedOrder.Total.ToString("F2")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private static readonly string[] Statuses = ["Draft", "Pending", "Processing", "Completed", "Cancelled"];

    private readonly List<OrderDTO> orders = new();
    private List<TenantDTO> tenants = new();
    private List<LocalUserDTO> localUsers = new();
    private List<CustomerDTO> customers = new();
    private List<CatalogItemDTO> catalogItems = new();

    private OrderDTO? selectedOrder = null;
    private OrderDTO formOrder = CreateEmptyOrder();

    private string searchTerm = string.Empty;
    private string statusFilter = string.Empty;
    private bool isLoading;
    private bool isSubmitting;
    private bool isCreating;
    private bool isEditing;
    private string? formError;

    private string formCustomerName = string.Empty;
    private string? formCustomerIdNo;
    private string SelectedCustomerIdStr = string.Empty;
    private string SelectedCatalogItemIdStr = string.Empty;

    private string TenantIdStr
    {
        get => formOrder.TenantId == Guid.Empty ? string.Empty : formOrder.TenantId.ToString();
        set
        {
            formOrder.TenantId = Guid.TryParse(value, out var tenantId) ? tenantId : Guid.Empty;
            if (formOrder.TenantId != Guid.Empty)
            {
                formOrder.LocalUserId = null;
                formOrder.LocalUser = null;
            }
        }
    }

    private string LocalUserIdStr
    {
        get => formOrder.LocalUserId?.ToString() ?? string.Empty;
        set
        {
            formOrder.LocalUserId = Guid.TryParse(value, out var localUserId) ? localUserId : null;
            formOrder.LocalUser = formOrder.LocalUserId.HasValue
                ? AvailableLocalUsers.FirstOrDefault(u => u.Id == formOrder.LocalUserId.Value)
                : null;
        }
    }

    private Guid? CurrentTenantId => TenantSelectionService.SelectedTenantId;

    private IEnumerable<OrderDTO> FilteredOrders => orders
        .Where(order => TenantSelectionService.CanAccessTenant(order.TenantId))
        .Where(order => !CurrentTenantId.HasValue || order.TenantId == CurrentTenantId.Value)
        .Where(order => string.IsNullOrWhiteSpace(searchTerm)
            || order.Id.ToString().Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
            || (order.Status?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(order => string.IsNullOrWhiteSpace(statusFilter) || order.Status == statusFilter)
        .OrderByDescending(order => order.CreatedAt);

    private IEnumerable<LocalUserDTO> AvailableLocalUsers =>
        localUsers
            .Where(u => u.TenantId == formOrder.TenantId)
            .OrderBy(u => u.Name);

    private IEnumerable<CustomerDTO> AvailableCustomers =>
        customers
            .OrderBy(c => c.Name);

    private IEnumerable<CatalogItemDTO> AvailableCatalogItems
    {
        get
        {
            var addedItemNames = formOrder.Items?
                .Select(i => i.Name.Trim().ToLowerInvariant())
                .ToHashSet() ?? new HashSet<string>();

            return catalogItems
                .Where(i => formOrder.TenantId == Guid.Empty || i.TenantId == formOrder.TenantId)
                .Where(i => TenantSelectionService.CanAccessTenant(i.TenantId))
                .Where(i => !addedItemNames.Contains(i.Name.Trim().ToLowerInvariant()))
                .OrderBy(i => i.Name);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await TenantSelectionService.EnsureInitializedAsync();
        TenantSelectionService.Changed += OnTenantChanged;
        await LoadOrdersAsync();
    }

    private void OnTenantChanged()
    {
        LoadTenants();

        if (isCreating)
        {
            formOrder.TenantId = CurrentTenantId ?? Guid.Empty;
            formOrder.LocalUserId = null;
            formOrder.LocalUser = null;
        }

        _ = ReloadAllDataAsync();
    }

    private async Task ReloadAllDataAsync()
    {
        await LoadLocalUsersAsync();
        await LoadCustomersAsync();
        await LoadCatalogItemsAsync();
        await LoadOrdersAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadOrdersAsync()
    {
        isLoading = true;
        formError = null;

        try
        {
            await TenantSelectionService.RefreshAsync();
            LoadTenants();
            await LoadLocalUsersAsync();
            await LoadCustomersAsync();
            await LoadCatalogItemsAsync();

            var loadedOrders = await OrderService.GetAllAsync();
            orders.Clear();
            orders.AddRange(loadedOrders);

            // Update selected order if it still exists
            if (selectedOrder != null)
            {
                var updated = orders.FirstOrDefault(o => o.Id == selectedOrder.Id);
                selectedOrder = updated;
            }
        }
        catch (Exception ex)
        {
            orders.Clear();
            formError = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void LoadTenants()
    {
        tenants = TenantSelectionService.AvailableTenants.OrderBy(t => t.Name).ToList();
    }

    private async Task LoadLocalUsersAsync()
    {
        var users = await LocalUserService.GetAllAsync();
        localUsers = users
            .Where(u => TenantSelectionService.CanAccessTenant(u.TenantId))
            .OrderBy(u => u.Name)
            .ToList();
    }

    private async Task LoadCustomersAsync()
    {
        try
        {
            var allCustomers = await CustomerService.GetAllAsync();
            customers = allCustomers
                .OrderBy(c => c.Name)
                .ToList();
        }
        catch
        {
            customers = new List<CustomerDTO>();
        }
    }

    private async Task LoadCatalogItemsAsync()
    {
        try
        {
            var allItems = await CatalogItemService.GetAllAsync();
            catalogItems = allItems
                .Where(i => TenantSelectionService.CanAccessTenant(i.TenantId))
                .OrderBy(i => i.Name)
                .ToList();
        }
        catch
        {
            catalogItems = new List<CatalogItemDTO>();
        }
    }

    private void SelectOrder(OrderDTO order)
    {
        selectedOrder = order;
        formOrder = Clone(order);
        formCustomerName = order.Customer?.Name ?? string.Empty;
        formCustomerIdNo = order.Customer?.IDNO;
        SelectedCustomerIdStr = order.Customer?.Id.ToString() ?? string.Empty;
        SelectedCatalogItemIdStr = string.Empty;
        isCreating = false;
        isEditing = false;
        formError = null;
    }

    private void StartCreate()
    {
        formOrder = CreateEmptyOrder(CurrentTenantId);
        formCustomerName = string.Empty;
        formCustomerIdNo = null;
        SelectedCustomerIdStr = string.Empty;
        SelectedCatalogItemIdStr = string.Empty;
        selectedOrder = null;
        formError = null;
        isCreating = true;
        isEditing = false;
    }

    private void CancelCreate()
    {
        isCreating = false;
        formError = null;
        isSubmitting = false;
        formOrder = CreateEmptyOrder();
    }

    private void StartEdit()
    {
        if (selectedOrder == null || selectedOrder.Status == "Completed") return;

        formOrder = Clone(selectedOrder);
        formCustomerName = selectedOrder.Customer?.Name ?? string.Empty;
        formCustomerIdNo = selectedOrder.Customer?.IDNO;
        SelectedCustomerIdStr = selectedOrder.Customer?.Id.ToString() ?? string.Empty;
        SelectedCatalogItemIdStr = string.Empty;
        isEditing = true;
        isCreating = false;
        formError = null;
    }

    private void CancelEdit()
    {
        if (selectedOrder == null) return;

        formOrder = Clone(selectedOrder);
        formCustomerName = selectedOrder.Customer?.Name ?? string.Empty;
        formCustomerIdNo = selectedOrder.Customer?.IDNO;
        SelectedCustomerIdStr = selectedOrder.Customer?.Id.ToString() ?? string.Empty;
        SelectedCatalogItemIdStr = string.Empty;
        isEditing = false;
        formError = null;
        isSubmitting = false;
    }

    private void AddItem()
    {
        formOrder.Items ??= new List<ItemDTO>();
        formOrder.Items.Add(new ItemDTO 
        { 
            Id = Guid.NewGuid(), 
            Name = "New Item", 
            Quantity = 1, 
            Price = 0, 
            TVA = "0%" 
        });
        RecalculateTotal();
    }

    private void AddSelectedCatalogItem()
    {
        if (string.IsNullOrEmpty(SelectedCatalogItemIdStr)) return;

        if (!Guid.TryParse(SelectedCatalogItemIdStr, out var catalogItemId)) return;

        var catalogItem = catalogItems.FirstOrDefault(i => i.Id == catalogItemId);
        if (catalogItem == null) return;

        formOrder.Items ??= new List<ItemDTO>();
        formOrder.Items.Add(new ItemDTO
        {
            Id = Guid.NewGuid(),
            Name = catalogItem.Name,
            Quantity = 1,
            Price = catalogItem.Price,
            TVA = "20%"
        });

        SelectedCatalogItemIdStr = string.Empty;
        RecalculateTotal();
    }

    private void RemoveItem(ItemDTO item)
    {
        formOrder.Items?.Remove(item);
        RecalculateTotal();
    }

    private void RecalculateTotal()
    {
        formOrder.Total = 0;
        if (formOrder.Items == null) return;

        foreach (var item in formOrder.Items)
        {
            item.Total = item.Price * item.Quantity;
            formOrder.Total += item.Total;
        }
    }

    private async Task HandleSubmitAsync()
    {
        formError = null;
        RecalculateTotal();

        if (string.IsNullOrWhiteSpace(formOrder.Status))
        {
            formError = "Status is required.";
            return;
        }

        if (formOrder.TenantId == Guid.Empty)
        {
            formError = "Tenant is required.";
            return;
        }

        var selectedTenant = tenants.FirstOrDefault(t => t.Id == formOrder.TenantId);
        if (selectedTenant == null)
        {
            formError = "Selected tenant is not available.";
            return;
        }

        if (!formOrder.LocalUserId.HasValue)
        {
            formError = "Local user is required.";
            return;
        }

        var selectedLocalUser = localUsers.FirstOrDefault(u => u.Id == formOrder.LocalUserId.Value);
        if (selectedLocalUser == null || selectedLocalUser.TenantId != formOrder.TenantId)
        {
            formError = "Selected local user is not available for the chosen tenant.";
            return;
        }

        CustomerDTO? customer = null;
        if (!string.IsNullOrEmpty(SelectedCustomerIdStr) && Guid.TryParse(SelectedCustomerIdStr, out var customerId))
        {
            customer = customers.FirstOrDefault(c => c.Id == customerId);
        }
        else if (!string.IsNullOrWhiteSpace(formCustomerName))
        {
            customer = new CustomerDTO
            {
                Id = Guid.Empty,
                Name = formCustomerName.Trim(),
                IDNO = formCustomerIdNo ?? string.Empty
            };
        }

        formOrder.TenantId = selectedTenant.Id;
        formOrder.Tenant = null;

        formOrder.LocalUserId = selectedLocalUser.Id;
        formOrder.LocalUser = new LocalUserDTO { Id = selectedLocalUser.Id, Name = selectedLocalUser.Name, TenantId = selectedTenant.Id };

        formOrder.Customer = customer;
        formOrder.CustomerId = null;

        if (!TenantSelectionService.CanAccessTenant(formOrder.TenantId))
        {
            formError = "You can only manage orders for your assigned tenant.";
            return;
        }

        isSubmitting = true;

        try
        {
            if (isCreating)
            {
                var created = await OrderService.CreateAsync(formOrder);
                orders.Add(created);
                selectedOrder = created;
                formOrder = Clone(created);
                isCreating = false;
            }
            else if (isEditing)
            {
                var updated = await OrderService.UpdateAsync(formOrder.Id, formOrder);
                SyncToList(updated);
                selectedOrder = updated;
                formOrder = Clone(updated);
                isEditing = false;
            }
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task DeleteOrderAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this order?\n\nThis action cannot be undone."))
        {
            return;
        }

        try
        {
            await OrderService.DeleteAsync(id);
            orders.RemoveAll(order => order.Id == id);

            if (selectedOrder?.Id == id)
            {
                selectedOrder = null;
                isEditing = false;
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private void SyncToList(OrderDTO updated)
    {
        var index = orders.FindIndex(order => order.Id == updated.Id);
        if (index >= 0)
        {
            orders[index] = updated;
        }
    }

    private string ResolveTenantName(Guid tenantId) =>
        tenants.FirstOrDefault(t => t.Id == tenantId)?.Name ?? "—";

    private static OrderDTO Clone(OrderDTO order) => new()
    {
        Id = order.Id,
        Status = order.Status,
        Total = order.Total,
        CreatedAt = order.CreatedAt,
        UpdatedAt = order.UpdatedAt,
        TenantId = order.TenantId,
        LocalUserId = order.LocalUserId,
        CustomerId = order.CustomerId,
        Tenant = order.Tenant,
        LocalUser = order.LocalUser,
        Customer = order.Customer,
        Items = order.Items?.Select(item => new ItemDTO
        {
            Id = item.Id,
            Name = item.Name,
            Price = item.Price,
            Quantity = item.Quantity,
            Total = item.Total,
            TVA = item.TVA,
            OrderId = item.OrderId
        }).ToList() ?? new()
    };

    private static OrderDTO CreateEmptyOrder(Guid? tenantId = null) => new()
    {
        Status = "Draft",
        TenantId = tenantId ?? Guid.Empty,
        Items = new()
    };

    public void Dispose()
    {
        TenantSelectionService.Changed -= OnTenantChanged;
    }
}

