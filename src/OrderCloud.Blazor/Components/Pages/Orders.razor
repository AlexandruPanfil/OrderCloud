@page "/orders"
@implements IDisposable
@using OrderCloud.Shared.Models
@using OrderCloud.Blazor.Services
@inject IOrderService OrderService
@inject ILocalUserService LocalUserService
@inject ITenantSelectionService TenantSelectionService
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Orders</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-0">Orders</h1>
            <div class="text-muted">@FilteredOrders.Count() order@(FilteredOrders.Count() == 1 ? "" : "s")</div>
        </div>
        <button class="btn btn-primary" @onclick="StartCreate">New Order</button>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-md-6">
            <input class="form-control" placeholder="Search by ID or status..." @bind="searchTerm" @bind:event="oninput" />
        </div>
        <div class="col-md-3">
            <select class="form-select" @bind="statusFilter">
                <option value="">All statuses</option>
                @foreach (var status in Statuses)
                {
                    <option value="@status">@status</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <button class="btn btn-outline-secondary w-100" @onclick="LoadOrdersAsync" disabled="@isLoading">Refresh</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(formError) && !showPanel)
    {
        <div class="alert alert-danger">@formError</div>
    }

    @if (showPanel)
    {
        <!-- Размытый фон позади формы -->
        <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 1000;" @onclick="ClosePanel"></div>
        
        <!-- Контейнер формы поверх списка -->
        <div style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 95%; max-width: 900px; max-height: 90vh; overflow-y: auto; z-index: 1001; border-radius: var(--bs-border-radius);">
            <div class="card shadow-lg m-0">
                <div class="card-header d-flex justify-content-between align-items-center sticky-top bg-light border-bottom" style="z-index: 1020;">
                    <strong>@(panelMode == PanelMode.Create ? "Create Order" : panelMode == PanelMode.Edit ? "Edit Order" : "View Order")</strong>
                    <div class="d-flex gap-2">
                        @if (panelMode == PanelMode.View && formOrder.Status != "Completed")
                        {
                            <button class="btn btn-outline-primary btn-sm" @onclick="SwitchToEdit">Edit</button>
                        }
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ClosePanel">Close</button>
                    </div>
                </div>
                <div class="card-body">
                    <EditForm Model="formOrder" OnSubmit="HandleSubmitAsync">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Status</label>
                                <select class="form-select" @bind="formOrder.Status" disabled="@IsReadOnly">
                                    @foreach (var status in Statuses)
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </select>
                            </div>
                            
                            <div class="col-md-6">
                                <label class="form-label">Tenant</label>
                                <select class="form-select" @bind="TenantIdStr" disabled="@IsReadOnly">
                                    <option value="">-- Select tenant --</option>
                                    @foreach (var tenant in tenants)
                                    {
                                        <option value="@tenant.Id">@tenant.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Local User</label>
                                <select class="form-select" @bind="LocalUserIdStr" disabled="@(IsReadOnly || formOrder.TenantId == Guid.Empty)">
                                    <option value="">-- Select local user --</option>
                                    @foreach (var localUser in AvailableLocalUsers)
                                    {
                                        <option value="@localUser.Id">@localUser.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Customer Name</label>
                                <InputText class="form-control" @bind-Value="formCustomerName" disabled="@IsReadOnly" placeholder="Optional" />
                            </div>

                            <div class="col-md-3">
                                <label class="form-label">Customer IDNO</label>
                                <InputText class="form-control" @bind-Value="formCustomerIdNo" disabled="@IsReadOnly" placeholder="Optional" />
                            </div>
                            
                            @if (panelMode != PanelMode.Create)
                            {
                                <div class="col-md-6">
                                    <label class="form-label">Created At</label>
                                    <div class="form-control bg-light">@(formOrder.CreatedAt == default ? "—" : formOrder.CreatedAt.ToString("MMM dd, yyyy HH:mm"))</div>
                                </div>
                            }
                        </div>

                        <hr class="my-4" />
                        
                        <h5 class="mb-3">Order Items</h5>
                        <div class="table-responsive mb-3">
                            <table class="table table-sm table-bordered align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Name</th>
                                        <th style="width: 120px;">Price</th>
                                        <th style="width: 100px;">Qty</th>
                                        <th style="width: 120px;">TVA</th>
                                        <th style="width: 120px;">Total</th>
                                        @if (!IsReadOnly)
                                        {
                                            <th style="width: 50px;"></th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in formOrder.Items)
                                    {
                                        <tr>
                                            <td>
                                                @if (IsReadOnly)
                                                {
                                                    @item.Name
                                                }
                                                else
                                                {
                                                    <InputText class="form-control form-control-sm" @bind-Value="item.Name" required />
                                                }
                                            </td>
                                            <td>
                                                @if (IsReadOnly)
                                                {
                                                    @item.Price.ToString("F2")
                                                }
                                                else
                                                {
                                                    <InputNumber class="form-control form-control-sm" @bind-Value="item.Price" @bind-Value:after="RecalculateTotal" />
                                                }
                                            </td>
                                            <td>
                                                @if (IsReadOnly)
                                                {
                                                    @item.Quantity
                                                }
                                                else
                                                {
                                                    <InputNumber class="form-control form-control-sm" @bind-Value="item.Quantity" @bind-Value:after="RecalculateTotal" />
                                                }
                                            </td>
                                            <td>
                                                @if (IsReadOnly)
                                                {
                                                    @item.TVA
                                                }
                                                else
                                                {
                                                    <select class="form-select form-select-sm" @bind="item.TVA">
                                                        <option value="0%">0%</option>
                                                        <option value="8%">8%</option>
                                                        <option value="12%">12%</option>
                                                        <option value="20%">20%</option>
                                                    </select>
                                                }
                                            </td>
                                            <td>$@((item.Price * item.Quantity).ToString("F2"))</td>
                                            @if (!IsReadOnly)
                                            {
                                                <td class="text-center">
                                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveItem(item)">
                                                        <i class="bi bi-trash"></i> &times;
                                                    </button>
                                                </td>
                                            }
                                        </tr>
                                    }
                                    @if (!formOrder.Items.Any())
                                    {
                                        <tr>
                                            <td colspan="@(IsReadOnly ? 5 : 6)" class="text-center text-muted py-3">No items added.</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="4" class="text-end fw-bold align-middle">Order Total:</td>
                                        <td class="fw-bold fs-5">$@formOrder.Total.ToString("F2")</td>
                                        @if (!IsReadOnly) { <td></td> }
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        @if (!IsReadOnly)
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary mb-3" @onclick="AddItem">Add Item</button>
                        }

                        @if (!string.IsNullOrWhiteSpace(formError))
                        {
                            <div class="alert alert-danger mt-3 mb-0">@formError</div>
                        }

                        <div class="d-flex justify-content-end gap-2 mt-3">
                            @if (panelMode == PanelMode.Edit)
                            {
                                <button type="button" class="btn btn-danger" @onclick="() => DeleteFromPanel(formOrder.Id)">Delete Order</button>
                            }
                            
                            <button type="button" class="btn btn-secondary" @onclick="ClosePanel">Close</button>
                            
                            @if (!IsReadOnly)
                            {
                                <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                                    @(panelMode == PanelMode.Create ? "Create Order" : "Save Changes")
                                </button>
                            }
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    }

    <div class="card">
        <div class="card-header">All Orders</div>
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Status</th>
                        <th>Tenant</th>
                        <th>Total</th>
                        <th>Created</th>
                        <th style="width: 220px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (FilteredOrders.Any())
                    {
                        @foreach (var order in FilteredOrders)
                        {
                            <tr>
                                <td><code>@order.Id.ToString()[..8]</code></td>
                                <td>
                                    <span class="badge @(order.Status == "Completed" ? "bg-success" : "bg-primary")">
                                        @order.Status
                                    </span>
                                </td>
                                <td>@ResolveTenantName(order.TenantId)</td>
                                <td>$@order.Total.ToString("F2")</td>
                                <td>@(order.CreatedAt == default ? "—" : order.CreatedAt.ToString("MMM dd, yyyy"))</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => ViewOrder(order)">View</button>
                                    @if (order.Status != "Completed")
                                    {
                                        <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => StartEdit(order)">Edit</button>
                                    }
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(order.Id)">Delete</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No orders found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private enum PanelMode { Create, Edit, View }

    private static readonly string[] Statuses = ["Draft", "Pending", "Processing", "Completed", "Cancelled"];

    private readonly List<OrderDTO> orders = new();
    private List<TenantDTO> tenants = new();
    private List<LocalUserDTO> localUsers = new();
    
    private string searchTerm = string.Empty;
    private string statusFilter = string.Empty;
    private bool isLoading;
    private bool isSubmitting;
    private bool showPanel;
    private string? formError;
    private PanelMode panelMode;
    private OrderDTO formOrder = CreateEmptyOrder();

    private string formCustomerName = string.Empty;
    private string? formCustomerIdNo;

    private bool IsReadOnly => panelMode == PanelMode.View || formOrder.Status == "Completed";

    private string TenantIdStr
    {
        get => formOrder.TenantId == Guid.Empty ? string.Empty : formOrder.TenantId.ToString();
        set
        {
            formOrder.TenantId = Guid.TryParse(value, out var tenantId) ? tenantId : Guid.Empty;
            if (formOrder.TenantId != Guid.Empty)
            {
                formOrder.LocalUserId = null;
                formOrder.LocalUser = null;
            }
        }
    }

    private string LocalUserIdStr
    {
        get => formOrder.LocalUserId?.ToString() ?? string.Empty;
        set
        {
            formOrder.LocalUserId = Guid.TryParse(value, out var localUserId) ? localUserId : null;
            formOrder.LocalUser = formOrder.LocalUserId.HasValue
                ? AvailableLocalUsers.FirstOrDefault(u => u.Id == formOrder.LocalUserId.Value)
                : null;
        }
    }

    private Guid? CurrentTenantId => TenantSelectionService.SelectedTenantId;

    private IEnumerable<OrderDTO> FilteredOrders => orders
        .Where(order => TenantSelectionService.CanAccessTenant(order.TenantId))
        .Where(order => !CurrentTenantId.HasValue || order.TenantId == CurrentTenantId.Value)
        .Where(order => string.IsNullOrWhiteSpace(searchTerm)
            || order.Id.ToString().Contains(searchTerm, StringComparison.OrdinalIgnoreCase)
            || (order.Status?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(order => string.IsNullOrWhiteSpace(statusFilter) || order.Status == statusFilter)
        .OrderByDescending(order => order.CreatedAt);

    private IEnumerable<LocalUserDTO> AvailableLocalUsers =>
        localUsers
            .Where(u => u.TenantId == formOrder.TenantId)
            .OrderBy(u => u.Name);

    protected override async Task OnInitializedAsync()
    {
        await TenantSelectionService.EnsureInitializedAsync();
        TenantSelectionService.Changed += OnTenantChanged;
        await LoadOrdersAsync();
    }

    private void OnTenantChanged()
    {
        LoadTenants();
        
        if (showPanel && panelMode == PanelMode.Create)
        {
            formOrder.TenantId = CurrentTenantId ?? Guid.Empty;
            formOrder.LocalUserId = null;
            formOrder.LocalUser = null;
        }

        _ = ReloadAllDataAsync();
    }

    private async Task ReloadAllDataAsync()
    {
        await LoadLocalUsersAsync();
        await LoadOrdersAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ReloadLocalUsersAndRefreshAsync()
    {
        await LoadLocalUsersAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadOrdersAsync()
    {
        isLoading = true;
        formError = null;

        try
        {
            await TenantSelectionService.RefreshAsync();
            LoadTenants();
            await LoadLocalUsersAsync();

            var loadedOrders = await OrderService.GetAllAsync();
            orders.Clear();
            orders.AddRange(loadedOrders);
        }
        catch (Exception ex)
        {
            orders.Clear();
            formError = ex.Message;
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void LoadTenants()
    {
        tenants = TenantSelectionService.AvailableTenants.OrderBy(t => t.Name).ToList();
    }

    private async Task LoadLocalUsersAsync()
    {
        var users = await LocalUserService.GetAllAsync();
        localUsers = users
            .Where(u => TenantSelectionService.CanAccessTenant(u.TenantId))
            .OrderBy(u => u.Name)
            .ToList();
    }

    private void StartCreate()
    {
        formOrder = CreateEmptyOrder(CurrentTenantId);
        formCustomerName = string.Empty;
        formCustomerIdNo = null;
        formError = null;
        panelMode = PanelMode.Create;
        showPanel = true;
    }

    private void ViewOrder(OrderDTO order)
    {
        formOrder = Clone(order);
        formCustomerName = order.Customer?.Name ?? string.Empty;
        formCustomerIdNo = order.Customer?.IDNO;
        formError = null;
        panelMode = PanelMode.View;
        showPanel = true;
    }

    private void StartEdit(OrderDTO order)
    {
        if (order.Status == "Completed")
        {
            ViewOrder(order);
            return;
        }
        
        formOrder = Clone(order);
        formCustomerName = order.Customer?.Name ?? string.Empty;
        formCustomerIdNo = order.Customer?.IDNO;
        formError = null;
        panelMode = PanelMode.Edit;
        showPanel = true;
    }

    private void SwitchToEdit()
    {
        if (formOrder.Status == "Completed") return;
        panelMode = PanelMode.Edit;
        formError = null;
    }

    private void ClosePanel()
    {
        showPanel = false;
        formError = null;
        isSubmitting = false;
    }
    
    private void AddItem()
    {
        if (IsReadOnly) return;
        formOrder.Items ??= new List<ItemDTO>();
        formOrder.Items.Add(new ItemDTO 
        { 
            Id = Guid.NewGuid(), 
            Name = "New Item", 
            Quantity = 1, 
            Price = 0, 
            TVA = "0%" 
        });
        RecalculateTotal();
    }

    private void RemoveItem(ItemDTO item)
    {
        if (IsReadOnly) return;
        formOrder.Items?.Remove(item);
        RecalculateTotal();
    }

    private void RecalculateTotal()
    {
        formOrder.Total = 0;
        if (formOrder.Items == null) return;
        
        foreach (var item in formOrder.Items)
        {
            item.Total = item.Price * item.Quantity;
            formOrder.Total += item.Total;
        }
    }

    private async Task HandleSubmitAsync()
    {
        if (IsReadOnly) return;

        formError = null;
        RecalculateTotal();

        if (string.IsNullOrWhiteSpace(formOrder.Status))
        {
            formError = "Status is required.";
            return;
        }

        if (formOrder.TenantId == Guid.Empty)
        {
            formError = "Tenant is required.";
            return;
        }

        var selectedTenant = tenants.FirstOrDefault(t => t.Id == formOrder.TenantId);
        if (selectedTenant == null)
        {
            formError = "Selected tenant is not available.";
            return;
        }

        if (!formOrder.LocalUserId.HasValue)
        {
            formError = "Local user is required.";
            return;
        }

        var selectedLocalUser = localUsers.FirstOrDefault(u => u.Id == formOrder.LocalUserId.Value);
        if (selectedLocalUser == null || selectedLocalUser.TenantId != formOrder.TenantId)
        {
            formError = "Selected local user is not available for the chosen tenant.";
            return;
        }

        CustomerDTO? customer = null;
        if (!string.IsNullOrWhiteSpace(formCustomerName))
        {
            customer = new CustomerDTO
            {
                Id = Guid.Empty,
                Name = formCustomerName.Trim(),
                IDNO = formCustomerIdNo ?? string.Empty
            };
        }

        formOrder.Tenant = selectedTenant;
        formOrder.LocalUser = selectedLocalUser;
        formOrder.Customer = customer;
        formOrder.CustomerId = null;

        if (!TenantSelectionService.CanAccessTenant(formOrder.TenantId))
        {
            formError = "You can only manage orders for your assigned tenant.";
            return;
        }

        isSubmitting = true;

        try
        {
            if (panelMode == PanelMode.Create)
            {
                var created = await OrderService.CreateAsync(formOrder);
                orders.Add(created);
                formOrder = Clone(created);
            }
            else
            {
                var updated = await OrderService.UpdateAsync(formOrder.Id, formOrder);
                SyncToList(updated);
                formOrder = Clone(updated);
            }

            panelMode = PanelMode.View;
        }
        catch (Exception ex)
        {
            formError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task DeleteAsync(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this order? This cannot be undone."))
        {
            return;
        }

        try
        {
            await OrderService.DeleteAsync(id);
            orders.RemoveAll(order => order.Id == id);

            if (showPanel && formOrder.Id == id)
            {
                ClosePanel();
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private async Task DeleteFromPanel(Guid id)
    {
        ClosePanel();
        await DeleteAsync(id);
    }

    private void SyncToList(OrderDTO updated)
    {
        var index = orders.FindIndex(order => order.Id == updated.Id);
        if (index >= 0)
        {
            orders[index] = updated;
        }
    }

    private string ResolveTenantName(Guid tenantId) =>
        tenants.FirstOrDefault(t => t.Id == tenantId)?.Name ?? "—";

    private static OrderDTO Clone(OrderDTO order) => new()
    {
        Id = order.Id,
        Status = order.Status,
        Total = order.Total,
        CreatedAt = order.CreatedAt,
        UpdatedAt = order.UpdatedAt,
        TenantId = order.TenantId,
        LocalUserId = order.LocalUserId,
        CustomerId = order.CustomerId,
        Tenant = order.Tenant,
        LocalUser = order.LocalUser,
        Customer = order.Customer,
        Items = order.Items?.Select(item => new ItemDTO
        {
            Id = item.Id,
            Name = item.Name,
            Price = item.Price,
            Quantity = item.Quantity,
            Total = item.Total,
            TVA = item.TVA,
            OrderId = item.OrderId
        }).ToList() ?? new()
    };

    private static OrderDTO CreateEmptyOrder(Guid? tenantId = null) => new()
    {
        Status = "Draft",
        TenantId = tenantId ?? Guid.Empty,
        Items = new()
    };

    public void Dispose()
    {
        TenantSelectionService.Changed -= OnTenantChanged;
    }
}

